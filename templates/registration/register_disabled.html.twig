{% extends 'base.html.twig' %}

{% block title %}Registration Closed{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto py-16 px-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-blue-50 text-blue-700">
            <i class="bi bi-qr-code-scan text-2xl"></i>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">Public sign-up is currently closed</h1>
        <p class="mt-3 text-slate-600">
            Please use an official QR registration link from the alumni office to create your account.
        </p>
        <a href="{{ path('app_login') }}" class="mt-6 inline-flex rounded-lg bg-blue-700 px-5 py-3 font-semibold text-white no-underline hover:bg-blue-800">
            Back to Sign In
        </a>
    </div>
</div>
{% endblock %}
