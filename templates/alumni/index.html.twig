{% extends 'base.html.twig' %}

{% block title %}Alumni Directory{% endblock %}

{% block body %}
{# ══════════════════════════════════════════════
   HEADER
   ══════════════════════════════════════════════ #}
<div class="flex justify-between items-start mb-4">
    <div>
        {% if isStaffPortal|default(false) %}
            <h4 class="font-bold mb-0"><i class="bi bi-patch-check-fill mr-2"></i>Alumni Verification Portal</h4>
            <p class="text-gray-500 text-sm mb-0">Review and verify graduate records only.</p>
        {% else %}
            <h4 class="font-bold mb-0"><i class="bi bi-people-fill mr-2"></i>Alumni Directory</h4>
            <p class="text-gray-500 text-sm mb-0">Manage and browse all alumni records</p>
        {% endif %}
    </div>
    {% if canCreateAlumni|default(false) %}
    <button type="button" id="toggleAddForm" class="btn-norsu">
        <i class="bi bi-plus-lg mr-1"></i> Add Alumni
    </button>
    {% endif %}
</div>

{# ══════════════════════════════════════════════
   ADD ALUMNI FORM (collapsible)
   ══════════════════════════════════════════════ #}
{% if form is defined and form %}
<div id="addAlumniSection" class="{% if not form.vars.submitted or form.vars.valid %}hidden{% endif %} mb-4">
    <div class="card">
        <div class="card-header-norsu flex justify-between items-center">
            <h6 class="font-bold mb-0 text-white"><i class="bi bi-person-plus-fill mr-1"></i> Add New Alumni</h6>
            <button type="button" id="closeAddForm" class="text-white/80 hover:text-white bg-transparent border-0 cursor-pointer text-lg"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
            {# Tab navigation #}
            <div class="flex border-b border-gray-200 mb-4 gap-1 overflow-x-auto" id="alumniFormTabs">
                <button type="button" data-tab-target="#tab-personal" class="alumni-tab px-4 py-2 text-sm font-semibold border-b-2 border-norsu text-norsu whitespace-nowrap">
                    <i class="bi bi-person mr-1"></i>Personal
                </button>
                <button type="button" data-tab-target="#tab-academic" class="alumni-tab px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-norsu whitespace-nowrap">
                    <i class="bi bi-mortarboard mr-1"></i>Academic
                </button>
                <button type="button" data-tab-target="#tab-employment" class="alumni-tab px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-norsu whitespace-nowrap">
                    <i class="bi bi-briefcase mr-1"></i>Employment
                </button>
                <button type="button" data-tab-target="#tab-career" class="alumni-tab px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-norsu whitespace-nowrap">
                    <i class="bi bi-graph-up mr-1"></i>Career
                </button>
                <button type="button" data-tab-target="#tab-feedback" class="alumni-tab px-4 py-2 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-norsu whitespace-nowrap">
                    <i class="bi bi-chat-dots mr-1"></i>Feedback
                </button>
            </div>

            {# Personal Info Tab #}
            <div id="tab-personal" class="alumni-tab-pane">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                    <div class="md:col-span-4">{{ form_row(form.studentNumber) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.firstName) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.lastName) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.middleName) }}</div>
                    <div class="md:col-span-2">{{ form_row(form.suffix) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.sex) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.civilStatus) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.dateOfBirth) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.contactNumber) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.province) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.emailAddress) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.homeAddress) }}</div>
                </div>
            </div>

            {# Academic Tab #}
            <div id="tab-academic" class="alumni-tab-pane hidden">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                    <div class="md:col-span-4">{{ form_row(form.course) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.college) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.degreeProgram) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.major) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.yearGraduated) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.dateGraduated) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.latinHonor) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.honorsReceived) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.gwa) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.scholarshipGranted) }}</div>
                </div>
            </div>

            {# Employment Tab #}
            <div id="tab-employment" class="alumni-tab-pane hidden">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                    <div class="md:col-span-4">{{ form_row(form.employmentStatus) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.employmentType) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.jobLevel) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.jobTitle) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.companyName) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.industry) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.monthlySalary) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.dateHired) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.companyAddress) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.yearsInCompany) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.countryOfEmployment) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.isFirstJob) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.workAbroad) }}</div>
                </div>
            </div>

            {# Career Tab #}
            <div id="tab-career" class="alumni-tab-pane hidden">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                    <div class="md:col-span-4">{{ form_row(form.jobRelatedToCourse) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.promotionReceived) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.datePromoted) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.skillsUsedInJob) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.trainingsAttended) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.licensesObtained) }}</div>
                    <div class="md:col-span-6">{{ form_row(form.certifications) }}</div>
                    <div class="md:col-span-12">{{ form_row(form.careerAchievements) }}</div>
                </div>
            </div>

            {# Feedback Tab #}
            <div id="tab-feedback" class="alumni-tab-pane hidden">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                    <div class="md:col-span-4">{{ form_row(form.furtherStudies) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.postgraduateDegree) }}</div>
                    <div class="md:col-span-4">{{ form_row(form.schoolForFurtherStudies) }}</div>
                    <div class="md:col-span-12">{{ form_row(form.suggestionsForUniversity) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.recommendNorsu) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.willingForSeminar) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.willingForDonation) }}</div>
                    <div class="md:col-span-3">{{ form_row(form.willingForMentorship) }}</div>
                </div>
            </div>

            <div class="flex gap-2 mt-4 pt-4 border-t border-gray-200">
                <button type="submit" class="btn-norsu"><i class="bi bi-check-lg mr-1"></i>Save Alumni Record</button>
                <button type="button" id="cancelAddForm" class="btn-secondary">Cancel</button>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endif %}

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 mb-4">
    <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">Unregistered</div>
        <div class="mt-2 text-2xl font-bold text-slate-800">{{ registrationStateCounts.unregistered|default(0) }}</div>
        <div class="text-xs text-slate-500">Imported or added alumni without an account</div>
    </div>
    <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-wide text-amber-700">Pending Approval</div>
        <div class="mt-2 text-2xl font-bold text-amber-900">{{ registrationStateCounts.pending|default(0) }}</div>
        <div class="text-xs text-amber-700">Registrants waiting for review</div>
    </div>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Active Accounts</div>
        <div class="mt-2 text-2xl font-bold text-emerald-900">{{ registrationStateCounts.active|default(0) }}</div>
        <div class="text-xs text-emerald-700">Approved and signed-up alumni</div>
    </div>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-wide text-rose-700">Inactive Accounts</div>
        <div class="mt-2 text-2xl font-bold text-rose-900">{{ registrationStateCounts.inactive|default(0) }}</div>
        <div class="text-xs text-rose-700">Denied, suspended, or otherwise restricted accounts</div>
    </div>
</div>

{# ══════════════════════════════════════════════
   SEARCH & FILTERS
   ══════════════════════════════════════════════ #}
<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="{{ path('alumni_index') }}">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-2 items-end">
                <div class="md:col-span-3">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Search</label>
                    <input type="text" name="q" value="{{ search }}" class="form-input" placeholder="Name, student no...">
                </div>
                <div class="md:col-span-2">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Course</label>
                    <select name="course" class="form-select">
                        <option value="">All Courses</option>
                        {% for courseOption in courses %}
                            <option value="{{ courseOption }}" {{ filter_course == courseOption ? 'selected' }}>{{ courseOption }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Campus</label>
                    <input type="text" name="campus" value="{{ filter_campus|default('') }}" class="form-input" placeholder="e.g. College of Education">
                </div>
                <div class="md:col-span-1">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Year</label>
                    <select name="year" class="form-select">
                        <option value="">All Years</option>
                        {% for y in years %}<option value="{{ y }}" {{ filter_year == y ? 'selected' }}>{{ y }}</option>{% endfor %}
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Registration</label>
                    <select name="registration_state" class="form-select">
                        <option value="">All States</option>
                        <option value="unregistered" {{ filter_registration_state == 'unregistered' ? 'selected' }}>Unregistered</option>
                        <option value="pending" {{ filter_registration_state == 'pending' ? 'selected' }}>Pending</option>
                        <option value="active" {{ filter_registration_state == 'active' ? 'selected' }}>Active</option>
                        <option value="inactive" {{ filter_registration_state == 'inactive' ? 'selected' }}>Inactive</option>
                    </select>
                </div>
                <div class="md:col-span-1">
                    <label class="form-label uppercase text-xs font-bold tracking-wide text-gray-500">Employment</label>
                    <select name="status" class="form-select">
                        <option value="">All</option>
                        <option value="Employed" {{ filter_status == 'Employed' ? 'selected' }}>Employed</option>
                        <option value="Self-Employed" {{ filter_status == 'Self-Employed' ? 'selected' }}>Self-Employed</option>
                        <option value="Unemployed" {{ filter_status == 'Unemployed' ? 'selected' }}>Unemployed</option>
                        <option value="Freelance" {{ filter_status == 'Freelance' ? 'selected' }}>Freelance</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <button class="btn-norsu w-full"><i class="bi bi-search mr-1"></i>Filter</button>
                </div>
            </div>
        </form>
    </div>
</div>

{# ══════════════════════════════════════════════
   PRINT / EXPORT ACTIONS
   ══════════════════════════════════════════════ #}
<div class="flex justify-between items-center mb-3 no-print">
    <p class="text-sm text-gray-500 mb-0">
        Showing <strong>{{ totalCount }}</strong> alumni record{{ totalCount != 1 ? 's' : '' }}
        {% if filter_course or filter_year or filter_campus or filter_status or filter_province or filter_registration_state or search %}
            <span class="text-gray-400">
                (filtered{% if filter_course %}, course: {{ filter_course }}{% endif %}{% if filter_campus %}, campus: {{ filter_campus }}{% endif %}{% if filter_year %}, year: {{ filter_year }}{% endif %}{% if filter_registration_state %}, registration: {{ filter_registration_state|replace({'_': ' ', '-': ' '})|title }}{% endif %}{% if filter_status %}, employment: {{ filter_status }}{% endif %}{% if filter_province %}, province: {{ filter_province }}{% endif %}{% if search %}, search: "{{ search }}"{% endif %})
            </span>
        {% endif %}
    </p>
    <div class="flex gap-2">
        {% if is_granted('ROLE_STAFF') %}
        <a href="{{ path('report_export', {course: filter_course, year: filter_year, campus: filter_campus, status: filter_status, province: filter_province, registration_state: filter_registration_state}) }}" class="inline-flex items-center gap-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
            <i class="bi bi-file-earmark-spreadsheet"></i>Export CSV
        </a>
        {% endif %}
        <button onclick="window.print()" class="inline-flex items-center gap-1 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
            <i class="bi bi-printer"></i>Print
        </button>
    </div>
</div>

{# ── Print-only header (visible only when printing) ── #}
<div class="hidden print-header" style="display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <h2 style="margin:0; font-size:18pt; font-weight:bold;">Negros Oriental State University</h2>
        <h3 style="margin:4px 0; font-size:14pt;">Alumni Directory</h3>
        <p style="margin:4px 0; font-size:10pt; color:#555;">
            Printed on: {{ 'now'|date('F d, Y') }}
            {% if filter_course %} | Course: {{ filter_course }}{% endif %}
            {% if filter_campus %} | Campus: {{ filter_campus }}{% endif %}
            {% if filter_year %} | Year: {{ filter_year }}{% endif %}
            {% if filter_registration_state %} | Registration: {{ filter_registration_state|replace({'_': ' ', '-': ' '})|title }}{% endif %}
            {% if filter_status %} | Employment: {{ filter_status }}{% endif %}
            {% if filter_province %} | Province: {{ filter_province }}{% endif %}
            {% if search %} | Search: "{{ search }}"{% endif %}
        </p>
        <p style="margin:2px 0; font-size:10pt; color:#555;">Total Records: {{ totalCount }}</p>
        <hr style="margin-top:10px;">
    </div>
</div>

{# ══════════════════════════════════════════════
   ALUMNI TABLE
   ══════════════════════════════════════════════ #}
<div class="card">
    <div class="p-0 overflow-x-auto">
        <table class="table-norsu">
            <thead>
                <tr>
                    <th class="pl-4">Student No</th>
                    <th>Name</th>
                    <th>Course</th>
                    <th>Year</th>
                    <th>Province</th>
                    <th>Registration</th>
                    <th>Employment</th>
                    <th class="text-right pr-4 no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for alumni in alumnis %}
                <tr>
                    <td class="pl-4"><span class="badge badge-secondary">{{ alumni.studentNumber }}</span></td>
                    <td>
                        <div class="font-semibold text-sm">{{ alumni.lastName }}, {{ alumni.firstName }}{% if alumni.suffix %} {{ alumni.suffix }}{% endif %}</div>
                        <span class="text-gray-500 text-[0.72rem]">{{ alumni.emailAddress }}</span>
                    </td>
                    <td class="text-sm">{{ alumni.course }}</td>
                    <td class="text-sm">{{ alumni.yearGraduated ?? '—' }}</td>
                    <td class="text-sm">{{ alumni.province ?? '—' }}</td>
                    <td>
                        {% if alumni.user is null %}
                            <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-[0.72rem] font-semibold text-slate-700">Unregistered</span>
                        {% elseif alumni.user.accountStatus == 'pending' %}
                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-1 text-[0.72rem] font-semibold text-amber-800">Pending Approval</span>
                        {% elseif alumni.user.accountStatus == 'active' %}
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-1 text-[0.72rem] font-semibold text-emerald-800">Active Account</span>
                        {% else %}
                            <span class="inline-flex items-center rounded-full bg-rose-100 px-2.5 py-1 text-[0.72rem] font-semibold text-rose-800">{{ alumni.user.accountStatus|replace({'_': ' ', '-': ' '})|title }}</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if alumni.employmentStatus == 'Employed' %}
                            <span class="badge badge-employed">Employed</span>
                        {% elseif alumni.employmentStatus == 'Self-Employed' %}
                            <span class="badge badge-self-employed">Self-Employed</span>
                        {% elseif alumni.employmentStatus == 'Unemployed' %}
                            <span class="badge badge-unemployed">Unemployed</span>
                        {% elseif alumni.employmentStatus == 'Freelance' %}
                            <span class="badge badge-freelance">Freelance</span>
                        {% else %}
                            <span class="badge badge-secondary">{{ alumni.employmentStatus ?? 'N/A' }}</span>
                        {% endif %}
                    </td>
                    <td class="text-right pr-4 no-print">
                        <div class="flex justify-end gap-1">
                            <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="icon-action icon-action-view" title="View" aria-label="View alumni"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit alumni"><i class="bi bi-pencil"></i></a>
                            {% if is_granted('ROLE_ADMIN') %}
                            <form method="post" action="{{ path('alumni_delete', {id: alumni.id}) }}" class="inline"
                                  onsubmit="return confirm('Delete this alumni record?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ alumni.id) }}">
                                <button type="submit" class="icon-action icon-action-delete icon-action-btn" title="Delete" aria-label="Delete alumni"><i class="bi bi-trash"></i></button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center text-gray-500 py-10">
                        <i class="bi bi-search text-gray-300 text-4xl block mb-2"></i>
                        No alumni records found.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% include '_pagination.html.twig' with {
    currentPage: currentPage,
    totalPages: totalPages,
    route: 'alumni_index',
    routeParams: {q: search, course: filter_course, campus: filter_campus, year: filter_year, status: filter_status, province: filter_province, registration_state: filter_registration_state}
} %}

{# ── Tab and toggle JS ── #}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Toggle add form
    var section = document.getElementById('addAlumniSection');
    var toggleAddForm = document.getElementById('toggleAddForm');
    var closeAddForm = document.getElementById('closeAddForm');
    var cancelAddForm = document.getElementById('cancelAddForm');

    if (section && toggleAddForm && closeAddForm && cancelAddForm) {
        toggleAddForm.addEventListener('click', function() {
            section.classList.toggle('hidden');
            if (!section.classList.contains('hidden')) {
                section.scrollIntoView({behavior: 'smooth', block: 'start'});
            }
        });
        closeAddForm.addEventListener('click', function() { section.classList.add('hidden'); });
        cancelAddForm.addEventListener('click', function() { section.classList.add('hidden'); });
    }

    // Tab switching for the alumni form
    document.querySelectorAll('#alumniFormTabs .alumni-tab').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('#alumniFormTabs .alumni-tab').forEach(function(t) {
                t.classList.remove('border-norsu', 'text-norsu');
                t.classList.add('border-transparent', 'text-gray-500');
            });
            btn.classList.remove('border-transparent', 'text-gray-500');
            btn.classList.add('border-norsu', 'text-norsu');
            document.querySelectorAll('.alumni-tab-pane').forEach(function(p) { p.classList.add('hidden'); });
            document.querySelector(btn.getAttribute('data-tab-target')).classList.remove('hidden');
        });
    });
});
</script>
{% endblock %}
