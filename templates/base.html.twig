<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta http-equiv="X-Content-Type-Options" content="nosniff">
        <meta name="referrer" content="strict-origin-when-cross-origin">
        <title>{% block title %}NORSU Alumni Tracker{% endblock %}</title>
        <link rel="icon" type="image/webp" href="{{ asset('images/norsu-logo.webp') }}">

        <script>
            document.documentElement.classList.add('ui-preload');
        </script>

        {# ── Bootstrap Icons (icon font only — not Bootstrap CSS/JS) ── #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+" crossorigin="anonymous">
        <link rel="stylesheet" href="{{ asset('skilline/vendor/poppins.css') }}">

        <!-- Print-friendly styles -->
        <style>
            @media print {
                /* Hide navigation, sidebar, and non-essential UI */
                nav, .sidebar, .no-print, footer, .btn, button,
                form:not(.print-form), .pagination, .alert,
                .bi, [class*="bi-"] { display: none !important; }

                /* Full width content */
                .main-content, .container, .card {
                    width: 100% !important;
                    margin: 0 !important;
                    padding: 0 !important;
                    box-shadow: none !important;
                    border: none !important;
                }

                body {
                    background: white !important;
                    color: black !important;
                    font-size: 12pt !important;
                }

                /* Table styling for print */
                table { border-collapse: collapse !important; width: 100% !important; }
                th, td { border: 1px solid #333 !important; padding: 4px 8px !important; }
                th { background: #eee !important; }

                /* Page breaks */
                .page-break { page-break-before: always; }
                tr { page-break-inside: avoid; }

                /* Show print header */
                .print-header { display: block !important; }

                a { text-decoration: none !important; color: black !important; }
            }

            body.no-navbar .pt-\[64px\] {
                padding-top: 0 !important;
            }
        </style>

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        {% set showWorkspaceSidebar = app.user and (is_granted('ROLE_STAFF') or is_granted('ROLE_ADMIN')) %}
        {# ── TOP NAVBAR ── #}
        <nav class="fixed top-0 left-0 right-0 z-[1030] shadow-[0_3px_16px_rgba(30,64,175,0.3)] min-h-[64px] py-1.5 norsu-topbar"
             id="mainNavbar">
            <div class="w-full px-3 flex items-center min-h-[56px]">
                {% if app.user %}
                    {# ─ Logged-in: sidebar toggle + brand + user initials ─ #}
                    {% if showWorkspaceSidebar %}
                        <button class="text-white lg:hidden mr-2 p-0 bg-transparent border-0 cursor-pointer" id="sidebarToggle" type="button" aria-label="Toggle sidebar">
                            <i class="bi bi-list text-2xl"></i>
                        </button>
                    {% endif %}
                    <a class="norsu-brand flex items-center gap-2.5 text-white no-underline font-extrabold text-lg hover:text-white mr-auto" href="{{ path('app_home') }}">
                        <span class="norsu-brand-logo-wrap flex items-center justify-center flex-shrink-0">
                            <img src="{{ asset('images/norsu-navbar-logo.webp') }}" alt="NORSU Logo" class="norsu-brand-logo object-contain shadow-sm">
                        </span>
                        <span class="leading-tight">
                            NORSU Alumni Tracker
                            <span class="block text-[0.65rem] font-medium opacity-70 tracking-wider -mt-0.5">Negros Oriental State University</span>
                        </span>
                    </a>
                    <div class="relative ml-2" id="userDropdownWrap">
                        <button type="button" id="userDropdownBtn" class="w-[36px] h-[36px] rounded-full bg-white inline-flex items-center justify-center text-xs font-bold text-blue-800 cursor-pointer border-2 border-white/60 hover:ring-2 hover:ring-white/50 transition-all shadow-md" title="Account menu">
                            {% if app.user.profileImage %}
                                <img src="{{ asset('uploads/profile/' ~ app.user.profileImage) }}" alt="Profile" class="w-full h-full rounded-full object-cover">
                            {% else %}
                                {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                            {% endif %}
                        </button>
                        <div id="userDropdownMenu" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg ring-1 ring-black/5 py-1 z-[1050]">
                            <div class="px-4 py-3 border-b border-gray-100">
                                <p class="text-sm font-semibold text-gray-800 truncate">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                                <p class="text-xs text-gray-500 truncate">{{ app.user.email }}</p>
                            </div>
                            <a href="{{ path('app_profile') }}" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 no-underline">
                                <i class="bi bi-person-circle"></i> My Profile
                            </a>
                            <div class="border-t border-gray-100"></div>
                            <a href="{{ path('app_logout') }}" class="flex items-center gap-2 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 no-underline">
                                <i class="bi bi-box-arrow-left"></i> Logout
                            </a>
                        </div>
                    </div>
                {% else %}
                    {# ─ Guest: brand + collapsible Login / Register ─ #}
                    <a class="norsu-brand flex items-center gap-2.5 text-white no-underline font-extrabold text-lg hover:text-white" href="{{ path('app_home') }}">
                        <span class="norsu-brand-logo-wrap flex items-center justify-center flex-shrink-0">
                            <img src="{{ asset('images/norsu-navbar-logo.webp') }}" alt="NORSU Logo" class="norsu-brand-logo object-contain shadow-sm">
                        </span>
                        <span>
                            NORSU Alumni Tracker
                            <span class="block text-[0.65rem] font-medium opacity-70 tracking-wider -mt-0.5">Negros Oriental State University</span>
                        </span>
                    </a>
                    <button class="lg:hidden ml-auto text-white p-1.5 rounded border border-white/30 bg-transparent cursor-pointer" type="button" id="guestNavToggle" aria-label="Toggle navigation">
                        <i class="bi bi-list text-xl"></i>
                    </button>
                    {% set guestRoute = app.request.attributes.get('_route')|default('') %}
                    <div class="hidden lg:flex items-center ml-auto norsu-guest-desktop" id="guestNavDesktop">
                        <a class="norsu-guest-link text-white {{ guestRoute == 'app_home' ? '' : 'text-white/85 hover:text-white' }} font-bold text-xs uppercase tracking-wide no-underline" href="{{ path('app_home') }}">Home</a>
                        <a class="norsu-guest-link text-white {{ guestRoute == 'app_about' ? '' : 'text-white/85 hover:text-white' }} font-bold text-xs uppercase tracking-wide no-underline" href="{{ path('app_about') }}">About</a>
                        <a class="norsu-guest-link text-white {{ guestRoute == 'app_contact' ? '' : 'text-white/85 hover:text-white' }} font-bold text-xs uppercase tracking-wide no-underline" href="{{ path('app_contact') }}">Contact Us</a>
                        <a class="norsu-guest-link text-white {{ guestRoute == 'app_faq' ? '' : 'text-white/85 hover:text-white' }} font-bold text-xs uppercase tracking-wide no-underline" href="{{ path('app_faq') }}">FAQ</a>
                        <a class="norsu-guest-cta inline-flex items-center justify-center bg-white text-blue-800 hover:bg-gray-100 font-bold text-xs uppercase tracking-wide no-underline px-3 py-2 rounded-lg" href="{{ path('app_register') }}">Join Now</a>
                    </div>
                    {# Mobile guest menu #}
                    <div class="hidden absolute top-full left-0 right-0 bg-blue-900/95 backdrop-blur-sm shadow-lg lg:hidden z-50" id="guestNavMobile">
                        <div class="px-4 py-3 flex flex-col gap-2">
                            <a class="text-white/90 hover:text-white font-semibold py-2 no-underline" href="{{ path('app_home') }}">Home</a>
                            <a class="text-white/90 hover:text-white font-semibold py-2 no-underline" href="{{ path('app_about') }}">About</a>
                            <a class="text-white/90 hover:text-white font-semibold py-2 no-underline" href="{{ path('app_contact') }}">Contact Us</a>
                            <a class="text-white/90 hover:text-white font-semibold py-2 no-underline" href="{{ path('app_faq') }}">FAQ</a>
                            <a class="mt-1 inline-flex items-center justify-center rounded-lg bg-white text-blue-900 font-bold py-2.5 no-underline" href="{{ path('app_register') }}"><i class="bi bi-person-plus mr-1"></i>Join Now</a>
                        </div>
                    </div>
                {% endif %}
            </div>
        </nav>

        {% if showWorkspaceSidebar %}
        {# ── SIDEBAR (logged-in only) ── #}
        <div class="hidden fixed inset-0 bg-black/30 z-[1019]" id="sidebarBackdrop"></div>
        <aside class="norsu-sidebar fixed left-0 top-[84px] w-[220px] xl:w-[248px] h-[calc(100vh-84px)] bg-white border-r border-gray-200 z-[1020] overflow-y-auto shadow-[2px_0_8px_rgba(0,0,0,0.04)] transition-transform duration-300 -translate-x-full lg:translate-x-0" id="sidebar">
            <div class="sidebar-section-title pt-5 pb-3 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Main Menu</div>
            <nav class="flex flex-col">
                     <a class="sidebar-link {% if app.request.attributes.get('_route') in ['app_home', 'staff_dashboard', 'admin_dashboard'] %}active{% endif %}"
                         href="{% if is_granted('ROLE_ADMIN') %}{{ path('admin_dashboard') }}{% elseif is_granted('ROLE_STAFF') %}{{ path('staff_dashboard') }}{% else %}{{ path('app_home') }}{% endif %}">
                    <i class="bi bi-speedometer2 sidebar-icon"></i> Dashboard
                </a>

                {% if not is_granted('ROLE_ADMIN') %}
                <a class="sidebar-link {% if 'announcement_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('announcement_index') }}">
                    <i class="bi bi-megaphone-fill sidebar-icon"></i> Announcements
                </a>

                <a class="sidebar-link {% if 'job_board_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('job_board_index') }}">
                    <i class="bi bi-briefcase-fill sidebar-icon"></i> Job Announcements
                </a>

                <a class="sidebar-link {% if app.request.attributes.get('_route') == 'feedback_submit' %}active{% endif %}"
                   href="{{ path('feedback_submit') }}">
                    <i class="bi bi-chat-dots sidebar-icon"></i> Submit Feedback
                </a>
                {% endif %}

                {% if is_granted('ROLE_USER') and not is_granted('ROLE_STAFF') %}
                <a class="sidebar-link {% if 'gts_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('gts_new') }}">
                    <i class="bi bi-clipboard2-check sidebar-icon"></i> GTS Survey
                </a>
                {% endif %}

                {% if is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN') %}
                <a class="sidebar-link {% if app.request.attributes.get('_route')|default('') == 'report_index' or app.request.attributes.get('_route')|default('') == 'report_export' %}active{% endif %}"
                   href="{{ path('report_index') }}">
                    <i class="bi bi-bar-chart-line sidebar-icon"></i> Reports
                </a>
                <a class="sidebar-link {% if 'report_import' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('report_import') }}">
                    <i class="bi bi-upload sidebar-icon"></i> Import Data
                </a>
                <a class="sidebar-link {% if app.request.attributes.get('_route') == 'gts_index' %}active{% endif %}"
                   href="{{ path('gts_index') }}">
                    <i class="bi bi-clipboard2-data sidebar-icon"></i> GTS Responses
                </a>
                {% endif %}
            </nav>

            {% if is_granted('ROLE_USER') and not is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN') %}
            <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Account</div>
            <nav class="flex flex-col">
                <a class="sidebar-link {% if 'app_profile' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('app_profile') }}">
                    <i class="bi bi-person-circle sidebar-icon"></i> My Profile
                </a>
                <a class="sidebar-link text-red-500 hover:bg-red-50 hover:text-red-700"
                   href="{{ path('app_logout') }}">
                    <i class="bi bi-box-arrow-left sidebar-icon"></i> Logout
                </a>
            </nav>
            {% endif %}

            {% if is_granted('ROLE_STAFF') and not is_granted('ROLE_ADMIN') %}
                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Staff Management</div>
                <a class="sidebar-link {% if 'admin_verification' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('admin_verification') }}">
                    <i class="bi bi-patch-check-fill sidebar-icon"></i> Verify Users
                </a>
                <a class="sidebar-link {% if app.request.attributes.get('_route') starts with 'staff_gts_survey' or app.request.attributes.get('_route') starts with 'staff_gts_question' %}active{% endif %}"
                   href="{{ path('staff_gts_surveys_index') }}">
                    <i class="bi bi-ui-checks-grid sidebar-icon"></i> Survey Builder
                </a>
                <a class="sidebar-link {% if 'tracer_' in app.request.attributes.get('_route')|default('') %}active{% endif %}"
                   href="{{ path('tracer_index') }}">
                    <i class="bi bi-clipboard-data sidebar-icon"></i> Tracer Study
                </a>
                <a class="sidebar-link {% if app.request.attributes.get('_route')|default('') starts with 'job_board_' %}active{% endif %}"
                   href="{{ path('job_board_manage') }}">
                    <i class="bi bi-briefcase-fill sidebar-icon"></i> Manage Jobs
                </a>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
                {% set currentRoute = app.request.attributes.get('_route')|default('') %}

                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Alumni Management</div>
                <a class="sidebar-link {% if currentRoute starts with 'alumni_' %}active{% endif %}"
                   href="{{ path('alumni_index') }}">
                    <i class="bi bi-people sidebar-icon"></i> Alumni Directory
                </a>
                <a class="sidebar-link {% if currentRoute starts with 'admin_verification' or (currentRoute == 'admin_users' and app.request.query.get('role') != 'staff') %}active{% endif %}"
                   href="{{ path('admin_users') }}">
                    <i class="bi bi-patch-check-fill sidebar-icon"></i> User Management
                </a>
                <a class="sidebar-link {% if currentRoute == 'report_import' or currentRoute == 'report_export' %}active{% endif %}"
                   href="{{ path('report_import') }}">
                    <i class="bi bi-upload sidebar-icon"></i> Import / Export Data
                </a>
                     <a class="sidebar-link {% if currentRoute == 'admin_qr_registration' %}active{% endif %}"
                         href="{{ path('admin_qr_registration') }}">
                          <i class="bi bi-qr-code sidebar-icon"></i> QR Registration
                     </a>

                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Graduate Tracer Study</div>
                <a class="sidebar-link {% if currentRoute starts with 'admin_gts_survey' or currentRoute starts with 'admin_gts_question' or currentRoute starts with 'staff_gts_survey' or currentRoute starts with 'staff_gts_question' %}active{% endif %}"
                   href="{{ path('admin_gts_surveys_index') }}">
                    <i class="bi bi-ui-checks-grid sidebar-icon"></i> Survey Builder
                </a>
                <a class="sidebar-link {% if currentRoute in ['gts_index', 'gts_show'] %}active{% endif %}"
                   href="{{ path('gts_index') }}">
                    <i class="bi bi-clipboard2-data sidebar-icon"></i> GTS Responses
                </a>

                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Communications</div>
                <a class="sidebar-link {% if 'announcement_' in currentRoute %}active{% endif %}"
                   href="{{ path('announcement_index') }}">
                    <i class="bi bi-megaphone-fill sidebar-icon"></i> Announcements
                </a>
                <a class="sidebar-link {% if currentRoute starts with 'job_board_' %}active{% endif %}"
                   href="{{ path('job_board_manage') }}">
                    <i class="bi bi-briefcase-fill sidebar-icon"></i> Job Board
                </a>
                <a class="sidebar-link {% if currentRoute starts with 'admin_email' %}active{% endif %}"
                   href="{{ path('admin_email_index') }}">
                    <i class="bi bi-envelope-paper sidebar-icon"></i> Email Campaigns
                </a>

                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Reports and Analytics</div>
                <a class="sidebar-link {% if currentRoute in ['admin_analytics_hub', 'report_index', 'report_export', 'report_import', 'gts_index', 'gts_show'] or currentRoute starts with 'tracer_' or currentRoute starts with 'admin_survey' %}active{% endif %}"
                   href="{{ path('admin_analytics_hub') }}">
                    <i class="bi bi-grid-1x2-fill sidebar-icon"></i> Analytics Hub
                </a>
                <div class="sidebar-helper-note px-4 pb-1 text-[0.68rem] text-gray-400">Employment, Tracer, GTS, and CHED compliance reports are grouped in Analytics Hub.</div>

                <div class="sidebar-section-title pt-3 pb-2 px-4 text-[0.7rem] uppercase tracking-[1.5px] text-gray-400 font-bold select-none">Academic Management</div>
                <a class="sidebar-link {% if currentRoute starts with 'admin_college' %}active{% endif %}"
                   href="{{ path('admin_colleges') }}">
                    <i class="bi bi-building sidebar-icon"></i> Colleges
                </a>
                <a class="sidebar-link {% if currentRoute starts with 'admin_department' %}active{% endif %}"
                   href="{{ path('admin_departments') }}">
                    <i class="bi bi-diagram-3 sidebar-icon"></i> Departments
                </a>

                <a class="sidebar-link {% if app.request.attributes.get('_route') starts with 'admin_audit' %}active{% endif %}" href="{{ path('admin_audit_log') }}">
                    <i class="bi bi-journal-text sidebar-icon"></i> Audit Log
                </a>
            {% endif %}
            </nav>
        </aside>
        {% endif %}

        {# ── MAIN CONTENT ── #}
        <div class="norsu-main-content {% if showWorkspaceSidebar %}lg:ml-[220px] xl:ml-[248px] pt-[84px] px-4 pb-4 xl:px-6 xl:pb-6{% elseif app.user %}pt-[84px] px-4 pb-4 xl:px-6 xl:pb-6{% else %}pt-[64px]{% endif %} min-h-screen transition-[margin-left] duration-300">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="{% if app.user %}{% else %}max-w-7xl mx-auto px-4{% endif %} mt-3">
                        <div class="alert alert-{{ label }}">
                            <span class="flex-1">{{ message }}</span>
                            <button type="button" class="text-current opacity-50 hover:opacity-100 ml-2 cursor-pointer bg-transparent border-0 text-lg leading-none" onclick="this.parentElement.remove()">&times;</button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        {# Sidebar & Turbo logic in assets/app.js (ES module) #}

        <script>
            document.addEventListener('click', function(e) {
                var btn = e.target.closest('.password-toggle-btn');
                if (!btn) return;
                e.preventDefault();
                var input = btn.parentElement.querySelector('input');
                var icon = btn.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('bi-eye-slash');
                    icon.classList.add('bi-eye');
                } else {
                    input.type = 'password';
                    icon.classList.remove('bi-eye');
                    icon.classList.add('bi-eye-slash');
                }
            });
        </script>
    </body>
</html>
