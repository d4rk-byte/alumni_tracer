{% extends 'base.html.twig' %}

{% block title %}Staff Dashboard — NORSU Alumni Tracker{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('skilline/vendor/poppins.css') }}">
{% endblock %}

{% block body %}
<style>
    .staff-dashboard {
        --staff-primary: #1d4ed8;
        --staff-primary-strong: #1e40af;
        --staff-accent: #0284c7;
        --staff-bg: #edf5ff;
        --staff-border: #d9e6fb;
        --staff-text: #0f172a;
        --staff-muted: #64748b;
        font-family: "Poppins", "Segoe UI", sans-serif;
        color: var(--staff-text);
    }

    .staff-dashboard .staff-shell {
        position: relative;
        padding: 1rem;
        border-radius: 1.55rem;
        border: 1px solid #deebff;
        background:
            radial-gradient(circle at 90% 8%, rgba(59, 130, 246, 0.18), transparent 42%),
            radial-gradient(circle at 12% 92%, rgba(14, 165, 233, 0.15), transparent 44%),
            linear-gradient(180deg, #f8fbff 0%, var(--staff-bg) 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
        overflow: hidden;
    }

    .staff-dashboard .staff-shell::before {
        content: "";
        position: absolute;
        left: -12%;
        top: -14%;
        width: 34%;
        height: 34%;
        border-radius: 999px;
        background: rgba(37, 99, 235, 0.08);
        pointer-events: none;
    }

    .staff-dashboard .welcome-banner,
    .staff-dashboard .card,
    .staff-dashboard .stat-card,
    .staff-dashboard .dashboard-footer {
        position: relative;
        z-index: 1;
    }

    .staff-dashboard .welcome-banner {
        border-radius: 1.4rem;
        box-shadow: 0 20px 38px rgba(30, 64, 175, 0.32);
    }

    .staff-dashboard .banner-main {
        padding: 1.35rem 1.5rem;
    }

    .staff-dashboard .banner-bottom {
        background: rgba(15, 23, 42, 0.16);
        border-top: 1px solid rgba(255, 255, 255, 0.16);
        padding: 0.72rem 1.5rem;
    }

    .staff-dashboard .hero-link {
        border-radius: 999px;
        padding: 0.58rem 1.02rem;
        font-size: 0.78rem;
        letter-spacing: 0.01em;
        font-weight: 700;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .staff-dashboard .hero-link:hover {
        transform: translateY(-1px) scale(1.03);
    }

    .staff-dashboard .hero-link-soft {
        background: #fff;
        color: #1e3a8a;
        box-shadow: 0 8px 18px rgba(30, 64, 175, 0.18);
    }

    .staff-dashboard .hero-link-soft:hover {
        background: #eff6ff;
    }

    .staff-dashboard .hero-link-ghost {
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.08);
    }

    .staff-dashboard .hero-link-ghost:hover {
        background: rgba(255, 255, 255, 0.22);
    }

    .staff-dashboard .card,
    .staff-dashboard .stat-card {
        border: 1px solid var(--staff-border);
        border-radius: 1.06rem;
        box-shadow: 0 12px 26px rgba(30, 64, 175, 0.08);
        transition: transform 0.16s ease, box-shadow 0.16s ease;
    }

    .staff-dashboard .card:hover,
    .staff-dashboard .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 30px rgba(30, 64, 175, 0.12);
    }

    .staff-dashboard .card-header-norsu {
        background: linear-gradient(118deg, #1d4ed8 0%, #1e40af 52%, #0284c7 100%);
        color: #fff;
    }

    .staff-dashboard .stat-icon {
        border-radius: 0.92rem;
    }

    .staff-dashboard .stat-label {
        color: #64748b;
        letter-spacing: 0.01em;
    }

    .staff-dashboard .quick-action-card {
        border: 1px solid var(--staff-border);
        border-radius: 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
        transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    }

    .staff-dashboard .quick-action-card:hover {
        border-color: #94baff;
        transform: translateY(-1px);
        box-shadow: 0 14px 24px rgba(30, 64, 175, 0.14);
    }

    .staff-dashboard .action-icon {
        border-radius: 0.85rem;
    }

    .staff-dashboard .progress-wrap {
        background: #dbe7ff;
        height: 6px;
        border-radius: 999px;
    }

    .staff-dashboard .progress-fill {
        border-radius: 999px;
    }

    .staff-dashboard .btn-norsu,
    .staff-dashboard .btn-outline-norsu,
    .staff-dashboard .btn-warning {
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.01em;
        padding-left: 0.9rem;
        padding-right: 0.9rem;
    }

    .staff-dashboard .btn-outline-norsu:hover,
    .staff-dashboard .btn-warning:hover,
    .staff-dashboard .btn-norsu:hover {
        transform: translateY(-1px);
    }

    .staff-dashboard .btn-outline-norsu.btn-xs,
    .staff-dashboard .btn-warning.btn-xs {
        border-radius: 0.72rem;
        padding-left: 0.55rem;
        padding-right: 0.55rem;
    }

    .staff-dashboard .card table thead {
        background: #f3f8ff;
    }

    .staff-dashboard .card table thead th {
        color: #64748b;
        border-bottom: 1px solid #dbe7fb;
    }

    .staff-dashboard .card table tbody tr:hover {
        background: #f1f7ff;
    }

    .staff-dashboard .card .divide-y > * {
        border-color: #e6eefc;
    }

    .staff-dashboard .dashboard-footer {
        border: 1px solid #1e3a8a;
        border-radius: 1.12rem;
        background: linear-gradient(135deg, #0f2f88 0%, #1d4ed8 52%, #0f766e 100%);
    }

    @media (max-width: 767.98px) {
        .staff-dashboard .staff-shell {
            padding: 0.72rem;
            border-radius: 1.2rem;
        }

        .staff-dashboard .banner-main {
            padding: 1rem 0.95rem;
        }

        .staff-dashboard .banner-bottom {
            padding: 0.62rem 0.95rem;
            gap: 0.45rem 0.9rem;
        }

        .staff-dashboard .hero-link {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<section class="staff-dashboard">
<div class="staff-shell">
{# ══════════════════════════════════════════════
   WELCOME BANNER
   ══════════════════════════════════════════════ #}
<div class="welcome-banner mb-4" style="background-color:#1E3A8A;background-image:linear-gradient(118deg,rgba(6,24,63,0.84) 0%,rgba(13,65,120,0.66) 48%,rgba(5,150,105,0.54) 100%),url('{{ asset('images/home-hero-graduation.png') }}');background-size:cover;background-position:center;background-repeat:no-repeat;">
    <div class="banner-main py-5">
        <div class="flex justify-between items-center flex-wrap gap-3">
            <div class="flex items-center gap-3">
                <div class="user-avatar">{{ app.user.firstName|first }}{{ app.user.lastName|first }}</div>
                <div>
                    <h2 class="font-extrabold text-2xl mb-0"><i class="bi bi-speedometer2 mr-2"></i>Staff Dashboard</h2>
                    <p class="opacity-90 text-sm mt-1 mb-0">Welcome back, <strong>{{ app.user.firstName }} {{ app.user.lastName }}</strong>! Here's your overview.</p>
                </div>
            </div>
            <div class="flex gap-2 mt-3 md:mt-0">
                <a href="{{ path('alumni_index') }}#addAlumniSection" class="hero-link hero-link-soft inline-flex items-center gap-1" onclick="setTimeout(function(){var s=document.getElementById('addAlumniSection');if(s)s.classList.remove('hidden')},100)"><i class="bi bi-person-plus-fill"></i>Add Alumni</a>
                <a href="{{ path('report_index') }}" class="hero-link hero-link-ghost inline-flex items-center gap-1"><i class="bi bi-bar-chart-line"></i>Reports</a>
            </div>
        </div>
    </div>
    <div class="banner-bottom">
        <span class="opacity-85"><i class="bi bi-calendar3 mr-1"></i>{{ 'now'|date('F d, Y') }}</span>
        <span class="opacity-85"><i class="bi bi-clock mr-1"></i>{{ 'now'|date('h:i A') }}</span>
        <span class="badge bg-white text-cyan-600" style="font-size:0.7rem"><i class="bi bi-person-badge-fill mr-1"></i>Staff</span>
        <span class="ml-auto opacity-85"><i class="bi bi-people mr-1"></i>{{ totalAlumni }} alumni &middot; {{ totalUsers }} users</span>
    </div>
</div>

{# ══════════════════════════════════════════════
   STAT CARDS
   ══════════════════════════════════════════════ #}
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    {% set stats = [
        {bg: '#E0F2FE', fg: '#0284C7', icon: 'bi-people-fill', value: totalAlumni, label: 'Total Registered Alumni'},
        {bg: pendingUsers > 0 ? '#FEF3C7' : '#D1FAE5', fg: pendingUsers > 0 ? '#D97706' : '#059669', icon: 'bi-hourglass-split', value: pendingUsers, label: 'Pending Approvals (New Graduates)'},
        {bg: '#EDE9FE', fg: '#7C3AED', icon: 'bi-clipboard2-check', value: recentSurveySubmissions, label: 'Recent Survey Submissions'},
        {bg: '#D1FAE5', fg: '#059669', icon: 'bi-briefcase-fill', value: activeJobs, label: 'Active Jobs'}
    ] %}
    {% for s in stats %}
    <div class="stat-card">
        <div class="p-4 flex items-center gap-3">
            <div class="stat-icon" style="background:{{ s.bg }}">
                <i class="bi {{ s.icon }} text-xl" style="color:{{ s.fg }}"></i>
            </div>
            <div>
                <div class="stat-value">{{ s.value }}</div>
                <div class="stat-label">{{ s.label }}</div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{# ══════════════════════════════════════════════
   EMPLOYMENT RATE · USER OVERVIEW · QUICK ACTIONS
   ══════════════════════════════════════════════ #}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-3 mb-4">

    {# ── Employment Rate Donut ── #}
    <div class="card h-full">
        <div class="card-body text-center py-6">
            <h6 class="uppercase text-gray-500 font-bold text-xs mb-3 tracking-wide">Employment Rate</h6>
            <div class="relative w-[130px] h-[130px] mx-auto">
                <svg viewBox="0 0 36 36" class="w-[130px] h-[130px]">
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                          fill="none" stroke="#E5E7EB" stroke-width="2.8"/>
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                          fill="none" stroke="#0891B2" stroke-width="2.8"
                          stroke-dasharray="{{ employmentRate }}, 100"
                          stroke-linecap="round"/>
                </svg>
                <div class="absolute inset-0 flex items-center justify-center">
                    <span class="text-2xl font-extrabold text-cyan-700">{{ employmentRate }}%</span>
                </div>
            </div>
            <p class="text-gray-500 text-sm mt-3 mb-3">of alumni are employed or self-employed</p>
            <div class="flex justify-center gap-6">
                <div class="text-center">
                    <div class="font-bold text-base text-green-600">{{ employed }}</div>
                    <div class="text-gray-500 text-[0.7rem]">Employed</div>
                </div>
                <div class="text-center">
                    <div class="font-bold text-base text-amber-500">{{ selfEmployed }}</div>
                    <div class="text-gray-500 text-[0.7rem]">Self-Emp.</div>
                </div>
                <div class="text-center">
                    <div class="font-bold text-base text-red-600">{{ unemployed }}</div>
                    <div class="text-gray-500 text-[0.7rem]">Unemployed</div>
                </div>
            </div>
        </div>
    </div>

    {# ── User Overview ── #}
    <div class="card h-full">
        <div class="px-4 pt-4 pb-0">
            <h6 class="font-bold mb-0"><i class="bi bi-person-lines-fill mr-1 text-cyan-700"></i> User Overview</h6>
        </div>
        <div class="card-body pt-3">
            {% set roles = [
                {icon: 'bi-shield-fill', iconCls: 'text-red-600', badgeCls: 'bg-red-100 text-red-800', barCls: 'bg-red-600', label: 'Admins', count: adminCount},
                {icon: 'bi-person-badge-fill', iconCls: 'text-cyan-600', badgeCls: 'bg-cyan-100 text-cyan-800', barCls: 'bg-cyan-600', label: 'Staff', count: staffCount},
                {icon: 'bi-mortarboard-fill', iconCls: 'text-green-600', badgeCls: 'bg-green-100 text-green-800', barCls: 'bg-green-600', label: 'Alumni', count: alumniCount}
            ] %}
            {% for r in roles %}
            <div class="{% if not loop.last %}mb-3{% endif %}">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-semibold"><i class="bi {{ r.icon }} {{ r.iconCls }} mr-1"></i>{{ r.label }}</span>
                    <span class="badge {{ r.badgeCls }}" style="font-size:.7rem">{{ r.count }}</span>
                </div>
                <div class="progress-wrap h-[5px]">
                    <div class="progress-fill {{ r.barCls }}" style="width:{{ totalUsers > 0 ? (r.count / totalUsers * 100)|round : 0 }}%"></div>
                </div>
            </div>
            {% endfor %}

            <hr class="my-3 border-gray-200">

            <div class="flex justify-between text-sm mb-1">
                <span class="text-gray-500">Total Users</span>
                <span class="font-bold">{{ totalUsers }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-gray-500">Online Now</span>
                <span class="font-bold text-green-600">{{ activeUsers }}</span>
            </div>
        </div>
    </div>

    {# ── Quick Actions ── #}
    <div class="card h-full">
        <div class="px-4 pt-4 pb-0">
            <h6 class="font-bold mb-0"><i class="bi bi-lightning-fill text-amber-500 mr-1"></i> Quick Actions</h6>
        </div>
        <div class="card-body pt-3">
            <div class="grid grid-cols-2 gap-2">
                {% set actions = [
                    {path: 'alumni_index',       icon: 'bi-person-plus-fill', bg: '#D1FAE5', fg: '#059669', label: 'Add Alumni'},
                    {path: 'alumni_index',       icon: 'bi-search',           bg: '#E0F2FE', fg: '#0284C7', label: 'Manage Alumni'},
                    {path: 'report_index',       icon: 'bi-bar-chart-line',   bg: '#EDE9FE', fg: '#7C3AED', label: 'Reports'},
                    {path: 'report_import',      icon: 'bi-upload',           bg: '#FCE7F3', fg: '#DB2777', label: 'Import Data'},
                    {path: 'job_board_create',   icon: 'bi-briefcase-fill',   bg: '#FEE2E2', fg: '#DC2626', label: 'Post Job'},
                    {path: 'announcement_index', icon: 'bi-megaphone-fill',   bg: '#DBEAFE', fg: '#2563EB', label: 'Announcements'}
                ] %}
                {% for a in actions %}
                <a href="{{ path(a.path) }}" class="quick-action-card">
                    <div class="action-icon" style="background:{{ a.bg }}"><i class="bi {{ a.icon }} text-lg" style="color:{{ a.fg }}"></i></div>
                    <div class="font-semibold text-[0.78rem]">{{ a.label }}</div>
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   QUICK REPORT SUMMARY
   ══════════════════════════════════════════════ #}
<div class="card mb-4">
    <div class="card-header-norsu px-4 py-3 flex items-center gap-2">
        <i class="bi bi-card-checklist text-lg"></i>
        <span class="font-bold">Quick Report</span>
    </div>
    <div class="card-body">
        <p class="text-sm text-gray-700 mb-3">{{ quickReport }}</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
            <div class="rounded-lg bg-green-50 border border-green-200 px-3 py-2">
                <span class="text-gray-600">Fully Traced Alumni:</span>
                <strong class="text-green-700 ml-1">{{ fullyTracedCount }}</strong>
            </div>
            <div class="rounded-lg bg-blue-50 border border-blue-200 px-3 py-2">
                <span class="text-gray-600">Fresh Submissions (30 days):</span>
                <strong class="text-blue-700 ml-1">{{ freshSubmissionCount }}</strong>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   STAFF MANAGEMENT PANEL
   ══════════════════════════════════════════════ #}
<div class="card mb-4">
    <div class="card-header-norsu px-4 py-3 flex items-center gap-2">
        <i class="bi bi-kanban text-lg"></i>
        <span class="font-bold">Staff Management Panel</span>
    </div>
    <div class="card-body">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            {# Verification Queue #}
            <div class="staff-panel-card border-l-4 border-amber-400 rounded-lg bg-amber-50/50 p-3">
                <div class="flex items-center gap-2 mb-2">
                    <i class="bi bi-shield-check text-amber-600 text-lg"></i>
                    <span class="font-semibold text-sm">Verification Queue</span>
                </div>
                <p class="text-2xl font-extrabold text-amber-600 mb-1">{{ pendingUsers }}</p>
                <p class="text-xs text-gray-500 mb-2">accounts awaiting verification</p>
                <a href="{{ path('admin_verification') }}" class="btn-warning btn-sm w-full font-semibold"><i class="bi bi-arrow-right mr-1"></i>Review Now</a>
            </div>
            {# Tracer Analytics #}
            <div class="staff-panel-card border-l-4 border-green-500 rounded-lg bg-green-50/50 p-3">
                <div class="flex items-center gap-2 mb-2">
                    <i class="bi bi-clipboard-data text-green-600 text-lg"></i>
                    <span class="font-semibold text-sm">Tracer Analytics</span>
                </div>
                <p class="text-2xl font-extrabold text-green-600 mb-1">{{ alignmentRate }}%</p>
                <p class="text-xs text-gray-500 mb-2">job-to-degree alignment rate</p>
                <a href="{{ path('tracer_index') }}" class="bg-green-600 hover:bg-green-700 text-white text-center py-1.5 px-3 rounded-lg text-xs font-semibold block no-underline transition-colors"><i class="bi bi-arrow-right mr-1"></i>View Analytics</a>
            </div>
            {# Job Board #}
            <div class="staff-panel-card border-l-4 border-cyan-600 rounded-lg bg-cyan-50/50 p-3">
                <div class="flex items-center gap-2 mb-2">
                    <i class="bi bi-briefcase-fill text-cyan-600 text-lg"></i>
                    <span class="font-semibold text-sm">Job Board</span>
                </div>
                <p class="text-2xl font-extrabold text-cyan-600 mb-1">{{ activeJobs }}<span class="text-xs text-gray-400 font-normal ml-1">/ {{ totalJobs }}</span></p>
                <p class="text-xs text-gray-500 mb-2">active job postings</p>
                <a href="{{ path('job_board_index') }}" class="bg-cyan-600 hover:bg-cyan-700 text-white text-center py-1.5 px-3 rounded-lg text-xs font-semibold block no-underline transition-colors"><i class="bi bi-arrow-right mr-1"></i>Manage Jobs</a>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   RECENT SURVEYS · RECENT ACTIVITY
   ══════════════════════════════════════════════ #}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-4">

    {# ── Recent Survey Submissions ── #}
    <div class="card h-full">
        <div class="flex justify-between items-center py-3 px-4">
            <h6 class="font-bold mb-0"><i class="bi bi-clipboard2-check text-amber-500 mr-1"></i> Recent Survey Submissions</h6>
            {% if recentSurveySubmissions > 0 %}
                <span class="badge badge-warning rounded-full">{{ recentSurveySubmissions }}</span>
            {% else %}
                <span class="badge badge-success rounded-full">All clear</span>
            {% endif %}
        </div>
        <div class="p-0">
            {% if recentSurveySubmissions > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                        <tr>
                            <th class="pl-4 py-2.5 font-semibold text-left">Metric</th>
                            <th class="py-2.5 font-semibold text-left">Value</th>
                            <th class="py-2.5 font-semibold text-left">Window</th>
                            <th class="text-right pr-4 py-2.5 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="pl-4 py-2.5 font-semibold text-sm">Survey Submissions</td>
                            <td class="py-2.5 text-sm text-gray-500">{{ recentSurveySubmissions }}</td>
                            <td class="py-2.5 text-sm text-gray-500">Last 30 days</td>
                            <td class="text-right pr-4 py-2.5">
                                <a href="{{ path('gts_index') }}" class="icon-action icon-action-view" title="View responses" aria-label="View survey responses"><i class="bi bi-eye"></i></a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center text-gray-500 py-10">
                <i class="bi bi-check-circle text-green-600 text-4xl block mb-2"></i>
                <p class="mb-0 text-sm font-medium">No recent survey submissions</p>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Recent Activity ── #}
    <div class="card h-full">
        <div class="flex justify-between items-center py-3 px-4">
            <h6 class="font-bold mb-0"><i class="bi bi-activity mr-1 text-cyan-700"></i> Recent Activity</h6>
        </div>
        <div class="p-0">
            {% if recentAuditLogs|length > 0 %}
            <div class="divide-y divide-gray-100">
                {% for log in recentAuditLogs %}
                <div class="py-3 px-4">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="badge bg-gray-100 text-gray-700 text-[0.72rem]">{{ log.action }}</span>
                            <div class="text-gray-500 text-sm mt-1">{{ log.details|default('—') }}</div>
                        </div>
                        <span class="text-gray-500 shrink-0 ml-2 text-[0.68rem] whitespace-nowrap">{{ log.createdAt|date('M d, H:i') }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-center text-gray-500 py-10">
                <i class="bi bi-journal text-gray-400 text-4xl block mb-2"></i>
                <p class="mb-0 text-sm font-medium">No recent activity</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   LATEST ANNOUNCEMENTS
   ══════════════════════════════════════════════ #}
{% if recentAnnouncements|length > 0 %}
<div class="mb-4">
    <div class="card">
        <div class="flex justify-between items-center py-3 px-4">
            <h6 class="font-bold mb-0"><i class="bi bi-megaphone-fill text-cyan-700 mr-1"></i> Latest Announcements</h6>
            <a href="{{ path('announcement_index') }}" class="btn-outline-norsu btn-sm">View All</a>
        </div>
        <div class="divide-y divide-gray-100">
            {% for ann in recentAnnouncements %}
            <div class="px-4 py-3">
                <div class="flex justify-between items-start">
                    <div>
                        <h6 class="mb-1 font-bold text-sm">{{ ann.title }}</h6>
                        <p class="mb-0 text-sm text-gray-500 leading-relaxed">{{ ann.description|length > 150 ? ann.description|slice(0, 150) ~ '...' : ann.description }}</p>
                    </div>
                    <span class="badge bg-gray-100 text-gray-500 ml-3 shrink-0 whitespace-nowrap text-[0.68rem]">{{ ann.datePosted|date('M d') }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════
   RECENTLY ADDED ALUMNI · TOP COURSES
   ══════════════════════════════════════════════ #}
<div class="grid grid-cols-1 lg:grid-cols-12 gap-3 mb-4">

    {# ── Recently Added Alumni ── #}
    <div class="lg:col-span-8">
        <div class="card h-full">
            <div class="flex justify-between items-center py-3 px-4">
                <h6 class="font-bold mb-0"><i class="bi bi-clock-history mr-1 text-cyan-700"></i> Recently Added Alumni</h6>
                <a href="{{ path('alumni_index') }}" class="btn-outline-norsu btn-sm">View All</a>
            </div>
            <div class="p-0 overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                        <tr>
                            <th class="pl-4 py-2.5 font-semibold text-left">Name</th>
                            <th class="py-2.5 font-semibold text-left">Course</th>
                            <th class="py-2.5 font-semibold text-left">Year</th>
                            <th class="py-2.5 font-semibold text-left">Status</th>
                            <th class="text-right pr-4 py-2.5 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for alumni in recentAlumni %}
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="pl-4 py-2.5">
                                <div class="flex items-center gap-2">
                                    <div class="mate-avatar-sm bg-cyan-100 text-cyan-600">{{ alumni.firstName|first }}</div>
                                    <div>
                                        <div class="font-semibold text-sm">{{ alumni.lastName }}, {{ alumni.firstName }}</div>
                                        <span class="text-gray-500 text-[0.72rem]">{{ alumni.studentNumber }}</span>
                                    </div>
                                </div>
                            </td>
                            <td class="py-2.5 text-sm text-gray-500">{{ alumni.course|default('—') }}</td>
                            <td class="py-2.5 text-sm text-gray-500">{{ alumni.yearGraduated|default('—') }}</td>
                            <td class="py-2.5">
                                {% set empStatus = alumni.employmentStatus|default('Unknown') %}
                                <span class="badge {% if empStatus == 'Employed' %}badge-employed{% elseif empStatus == 'Self-Employed' %}badge-self-employed{% elseif empStatus == 'Unemployed' %}badge-unemployed{% else %}badge-secondary{% endif %}">
                                    {{ empStatus }}
                                </span>
                            </td>
                            <td class="text-right pr-4 py-2.5">
                                <div class="flex justify-end gap-1">
                                    <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="icon-action icon-action-view" title="View" aria-label="View alumni"><i class="bi bi-eye"></i></a>
                                    <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit alumni"><i class="bi bi-pencil"></i></a>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-gray-500 py-8">
                                <i class="bi bi-people text-4xl block mb-2 text-gray-300"></i>
                                <p class="mb-0 text-sm">No alumni records yet. <a href="{{ path('alumni_index') }}#addAlumniSection" onclick="setTimeout(function(){var s=document.getElementById('addAlumniSection');if(s)s.classList.remove('hidden')},100)">Add the first one</a>.</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ── Top Courses ── #}
    <div class="lg:col-span-4">
        <div class="card h-full">
            <div class="px-4 pt-4 pb-0">
                <h6 class="font-bold mb-0"><i class="bi bi-mortarboard-fill text-cyan-700 mr-1"></i> Top Courses</h6>
            </div>
            <div class="card-body pt-3">
                {% if courseStats|length > 0 %}
                    {% set maxTotal = courseStats[0].total %}
                    {% for stat in courseStats %}
                    <div class="{% if not loop.last %}mb-3{% endif %}">
                        <div class="flex justify-between items-center mb-1">
                            <span class="font-semibold text-sm truncate mr-2">{{ stat.course }}</span>
                            <span class="text-sm text-gray-500 shrink-0">{{ stat.total }}</span>
                        </div>
                        <div class="progress-wrap h-[5px]">
                            <div class="progress-fill bg-cyan-600" style="width:{{ (stat.total / maxTotal * 100)|round }}%"></div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center text-gray-500 py-6">
                        <i class="bi bi-mortarboard text-4xl block mb-2 text-gray-300"></i>
                        <p class="mb-0 text-sm">No course data yet</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   SYSTEM OVERVIEW · EMPLOYMENT BREAKDOWN
   ══════════════════════════════════════════════ #}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-4">
    {# ── System Overview ── #}
    <div class="card h-full">
        <div class="px-4 pt-4 pb-0">
            <h6 class="font-bold mb-0"><i class="bi bi-hdd-stack mr-1 text-cyan-700"></i> System Overview</h6>
        </div>
        <div class="card-body">
            <div class="grid grid-cols-2 gap-3">
                {% set overview = [
                    {icon: 'bi-people-fill', fg: '#0284C7', value: totalAlumni, label: 'Total Alumni'},
                    {icon: 'bi-person-check', fg: '#059669', value: totalUsers, label: 'Registered Users'},
                    {icon: 'bi-briefcase-fill', fg: '#7C3AED', value: totalJobs, label: 'Total Jobs'},
                    {icon: 'bi-bullseye', fg: '#DB2777', value: alignmentRate ~ '%', label: 'Alignment Rate'}
                ] %}
                {% for o in overview %}
                <div class="bg-gray-50 rounded-lg p-3 text-center">
                    <i class="bi {{ o.icon }} text-lg mb-1 block" style="color:{{ o.fg }}"></i>
                    <div class="text-xl font-extrabold">{{ o.value }}</div>
                    <div class="text-xs text-gray-500">{{ o.label }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ── Employment Breakdown ── #}
    <div class="card h-full">
        <div class="px-4 pt-4 pb-0">
            <h6 class="font-bold mb-0"><i class="bi bi-pie-chart-fill mr-1 text-cyan-700"></i> Employment Breakdown</h6>
        </div>
        <div class="card-body">
            {% set empData = [
                {label: 'Employed', count: employed, color: 'bg-green-600', text: 'text-green-600'},
                {label: 'Self-Employed', count: selfEmployed, color: 'bg-amber-500', text: 'text-amber-500'},
                {label: 'Unemployed', count: unemployed, color: 'bg-red-600', text: 'text-red-600'}
            ] %}

            {# Multi-segment progress bar #}
            <div class="w-full bg-gray-200 rounded-full h-3 flex overflow-hidden mb-4">
                {% if totalAlumni > 0 %}
                    <div class="bg-green-600 h-3" style="width:{{ (employed / totalAlumni * 100)|round }}%"></div>
                    <div class="bg-amber-500 h-3" style="width:{{ (selfEmployed / totalAlumni * 100)|round }}%"></div>
                    <div class="bg-red-600 h-3" style="width:{{ (unemployed / totalAlumni * 100)|round }}%"></div>
                {% endif %}
            </div>

            {% for e in empData %}
            <div class="flex justify-between items-center {% if not loop.last %}mb-2{% endif %}">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full {{ e.color }} inline-block"></span>
                    <span class="text-sm font-medium">{{ e.label }}</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="font-bold text-sm {{ e.text }}">{{ e.count }}</span>
                    <span class="text-xs text-gray-400">
                        ({{ totalAlumni > 0 ? (e.count / totalAlumni * 100)|round(1) : 0 }}%)
                    </span>
                </div>
            </div>
            {% endfor %}

            <div class="mt-3 pt-3 border-t border-gray-200 flex justify-between text-sm">
                <span class="text-gray-500">Total Alumni Tracked</span>
                <span class="font-bold">{{ totalAlumni }}</span>
            </div>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   DPA COMPLIANCE
   ══════════════════════════════════════════════ #}
<div class="card mb-4">
    <div class="bg-gradient-dpa px-4 py-3 flex items-center gap-2 text-white rounded-t-xl">
        <i class="bi bi-shield-lock-fill text-lg"></i>
        <span class="font-bold">DPA Compliance</span>
        <span class="ml-auto badge bg-white/20 text-white text-[0.65rem]">RA 10173</span>
    </div>
    <div class="p-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="bg-green-50 rounded-lg p-3 text-center">
                <i class="bi bi-check-circle-fill text-green-600 text-xl mb-1 block"></i>
                <div class="font-bold text-sm text-green-700">Compliant</div>
                <div class="text-xs text-gray-500">Data Collection</div>
            </div>
            <div class="bg-blue-50 rounded-lg p-3 text-center">
                <i class="bi bi-lock-fill text-blue-600 text-xl mb-1 block"></i>
                <div class="font-bold text-sm text-blue-700">Encrypted</div>
                <div class="text-xs text-gray-500">Data Storage</div>
            </div>
            <div class="bg-purple-50 rounded-lg p-3 text-center">
                <i class="bi bi-person-check-fill text-purple-600 text-xl mb-1 block"></i>
                <div class="font-bold text-sm text-purple-700">Role-Based</div>
                <div class="text-xs text-gray-500">Access Control</div>
            </div>
        </div>
        <div class="mt-3 p-3 bg-gray-50 rounded-lg text-xs text-gray-500 leading-relaxed">
            <i class="bi bi-info-circle text-blue-600 mr-1"></i>
            All alumni data is processed in compliance with the <strong>Data Privacy Act of 2012 (RA 10173)</strong>.
            Personal information is collected with consent and used solely for alumni tracking purposes.
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════
   FOOTER
   ══════════════════════════════════════════════ #}
