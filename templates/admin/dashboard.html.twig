{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - NORSU Alumni Tracker{% endblock %}

{% block body_class %}admin-material-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
<style>
    .admin-material-page {
        --dash-bg: hsl(60 9% 98%);
        --dash-card: #ffffff;
        --dash-border: hsl(20 6% 90%);
        --dash-text: hsl(24 10% 10%);
        --dash-muted: hsl(24 5% 45%);
        --dash-primary: hsl(142 76% 36%);
        --dash-primary-soft: hsl(142 60% 94%);
        --dash-primary-foreground: #ffffff;
        background: var(--dash-bg);
    }

    .admin-material-page #mainNavbar.norsu-topbar {
        background: #ffffff;
        border-bottom: 1px solid var(--dash-border);
        box-shadow: none;
    }

    .admin-material-page #mainNavbar .norsu-brand,
    .admin-material-page #mainNavbar .norsu-brand:hover,
    .admin-material-page #mainNavbar #sidebarToggle,
    .admin-material-page #mainNavbar #guestNavToggle,
    .admin-material-page #mainNavbar #guestNavDesktop a {
        color: var(--dash-text);
    }

    .admin-material-page #mainNavbar #userDropdownBtn {
        background: var(--dash-primary);
        color: var(--dash-primary-foreground);
        border-color: transparent;
        box-shadow: none;
    }

    .admin-material-page #sidebar.norsu-sidebar {
        background: #ffffff;
        border-right: 1px solid var(--dash-border);
        box-shadow: none;
    }

    .admin-material-page #sidebar .sidebar-section-title {
        border-left: 0;
        margin-left: 0.55rem;
        margin-right: 0.55rem;
        padding-left: 0.45rem;
        letter-spacing: 0.09em;
        font-size: 0.64rem;
        color: var(--dash-muted);
    }

    .admin-material-page #sidebar .sidebar-link {
        margin-left: 0.55rem;
        margin-right: 0.55rem;
        border-radius: 0.5rem;
        color: var(--dash-text);
        font-weight: 500;
    }

    .admin-material-page #sidebar .sidebar-link:hover {
        background: hsl(60 5% 96%);
        color: var(--dash-text);
        transform: none;
    }

    .admin-material-page #sidebar .sidebar-link.active {
        background: var(--dash-primary);
        color: var(--dash-primary-foreground);
        box-shadow: none;
    }

    .admin-material-page #sidebar .sidebar-helper-note {
        color: var(--dash-muted);
        margin-left: 0.55rem;
        margin-right: 0.55rem;
    }

    .admin-material-page .norsu-main-content {
        background: var(--dash-bg);
    }

    @media (min-width: 1024px) {
        .admin-material-page.sidebar-compact #sidebar.norsu-sidebar {
            width: 4.5rem !important;
            overflow-x: visible;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-section-title,
        .admin-material-page.sidebar-compact #sidebar .sidebar-helper-note {
            display: none;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link {
            position: relative;
            overflow: visible;
            justify-content: center;
            font-size: 0;
            gap: 0;
            padding-left: 0.5rem;
            padding-right: 0.5rem;
            min-height: 2.35rem;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link::before {
            content: "";
            position: absolute;
            left: calc(100% + 0.28rem);
            top: 50%;
            transform: translateY(-50%);
            border-width: 6px;
            border-style: solid;
            border-color: transparent hsl(24 10% 10%) transparent transparent;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.12s ease;
            z-index: 1085;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link::after {
            content: attr(data-sidebar-label);
            position: absolute;
            left: calc(100% + 0.62rem);
            top: 50%;
            transform: translateY(-50%) scale(0.98);
            background: hsl(24 10% 10%);
            color: #ffffff;
            border-radius: 0.35rem;
            padding: 0.28rem 0.45rem;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0;
            white-space: nowrap;
            box-shadow: 0 6px 14px rgba(15, 23, 42, 0.25);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.12s ease, transform 0.12s ease;
            z-index: 1090;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link:hover::before,
        .admin-material-page.sidebar-compact #sidebar .sidebar-link:focus-visible::before,
        .admin-material-page.sidebar-compact #sidebar .sidebar-link:hover::after,
        .admin-material-page.sidebar-compact #sidebar .sidebar-link:focus-visible::after {
            opacity: 1;
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link:hover::after,
        .admin-material-page.sidebar-compact #sidebar .sidebar-link:focus-visible::after {
            transform: translateY(-50%) scale(1);
        }

        .admin-material-page.sidebar-compact #sidebar .sidebar-link .sidebar-icon {
            font-size: 1rem;
            width: auto;
            height: auto;
            margin: 0;
        }

        .admin-material-page.sidebar-compact .norsu-main-content {
            margin-left: 4.5rem !important;
        }
    }

    .admin-dashboard {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        font-size: 0.95rem;
        line-height: 1.45;
        color: var(--dash-text);
    }
 
    .admin-dashboard .dashboard-shell {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        background: transparent;
    }

    .admin-dashboard .dashboard-order-hero { order: 1; }
    .admin-dashboard .dashboard-order-stats { order: 2; }
    .admin-dashboard .dashboard-order-trend { order: 3; }
    .admin-dashboard .dashboard-order-operational { order: 4; }
    .admin-dashboard .dashboard-order-snapshot { order: 5; }
    .admin-dashboard .dashboard-order-segments { order: 6; }
    .admin-dashboard .dashboard-order-kpi { order: 7; }
    .admin-dashboard .dashboard-order-engagement { order: 8; }
    .admin-dashboard .dashboard-order-directory { order: 9; }

    .admin-dashboard .card-enter {
        animation: dashboard-enter 0.28s ease-out both;
    }

    .admin-dashboard .hero-panel {
        border: 1px solid var(--dash-border);
        border-radius: 0.65rem;
        background: var(--dash-card);
        color: var(--dash-text);
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
    }

    .admin-dashboard .hero-panel::before {
        content: none;
    }

    .admin-dashboard .workspace-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.85rem;
        padding: 0.72rem 1rem;
        border-bottom: 1px solid var(--dash-border);
    }

    .admin-dashboard .workspace-toolbar-top {
        border: 1px solid var(--dash-border);
        border-radius: 0.65rem;
        border-bottom: 0;
        background: var(--dash-card);
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
    }

    .admin-dashboard .workspace-search {
        width: min(32rem, 100%);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid var(--dash-border);
        border-radius: 0.45rem;
        padding: 0.42rem 0.62rem;
        background: #fff;
        color: var(--dash-muted);
    }

    .admin-dashboard .workspace-search i {
        font-size: 0.82rem;
    }

    .admin-dashboard .workspace-search input {
        width: 100%;
        border: 0;
        outline: none;
        background: transparent;
        font-size: 0.8rem;
        color: var(--dash-text);
    }

    .admin-dashboard .workspace-search input::placeholder {
        color: var(--dash-muted);
    }

    .admin-dashboard .workspace-account {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 0;
    }

    .admin-dashboard .workspace-account-avatar {
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        background: var(--dash-primary-soft);
        color: var(--dash-primary);
        flex-shrink: 0;
    }

    .admin-dashboard .workspace-account-meta {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .admin-dashboard .workspace-account-name {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--dash-text);
        line-height: 1.1;
    }

    .admin-dashboard .workspace-account-email {
        font-size: 0.68rem;
        color: var(--dash-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 11rem;
        line-height: 1.2;
    }

    .admin-dashboard .workspace-account-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--dash-border);
        border-radius: 0.4rem;
        padding: 0.34rem 0.56rem;
        font-size: 0.72rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--dash-text);
        background: #fff;
    }

    .admin-dashboard .workspace-account-link:hover {
        background: hsl(60 5% 96%);
        color: var(--dash-text);
    }

    .admin-dashboard .workspace-compact-toggle {
        min-width: 2rem;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
    }

    .admin-dashboard .workspace-compact-toggle i {
        font-size: 0.82rem;
    }

    .admin-dashboard .hero-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 0.95rem 1rem 0.85rem;
    }

    .admin-dashboard .hero-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-width: 0;
    }

    .admin-dashboard .hero-avatar {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 0;
        background: var(--dash-primary-soft);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        font-weight: 700;
        flex-shrink: 0;
        color: var(--dash-primary);
    }

    .admin-dashboard .hero-title {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .admin-dashboard .hero-subtitle {
        margin: 0.2rem 0 0;
        font-size: 0.82rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .hero-actions {
        display: flex;
        gap: 0.58rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .admin-dashboard .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.34rem;
        border-radius: 0.45rem;
        padding: 0.45rem 0.78rem;
        font-size: 0.76rem;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid transparent;
        transition: background-color 0.16s ease, border-color 0.16s ease;
    }

    .admin-dashboard .hero-btn:hover {
        transform: none;
    }

    .admin-dashboard .hero-btn-soft {
        color: var(--dash-text);
        background: #ffffff;
        border-color: var(--dash-border);
    }

    .admin-dashboard .hero-btn-soft:hover {
        background: hsl(60 5% 96%);
    }

    .admin-dashboard .hero-btn-solid {
        color: var(--dash-primary-foreground);
        background: var(--dash-primary);
    }

    .admin-dashboard .hero-btn-solid:hover {
        background: hsl(142 76% 32%);
    }

    .admin-dashboard .hero-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.55rem 1rem;
        padding: 0.55rem 1rem 0.65rem;
        border-top: 1px solid var(--dash-border);
        background: hsl(60 5% 97%);
        font-size: 0.75rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .hero-meta i {
        margin-right: 0.22rem;
    }

    .admin-dashboard .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.16rem 0.46rem;
        border-radius: 999px;
        border: 1px solid hsl(142 50% 84%);
        background: var(--dash-primary-soft);
        font-size: 0.69rem;
        font-weight: 600;
        color: hsl(142 76% 24%);
    }

    .admin-dashboard .metric-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    .admin-dashboard .metric-card {
        border: 1px solid var(--dash-border);
        border-radius: 0.65rem;
        background: var(--dash-card);
        padding: 0.8rem 0.9rem;
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
        transition: border-color 0.16s ease, box-shadow 0.16s ease;
    }

    .admin-dashboard .metric-card:hover {
        transform: none;
        border-color: hsl(20 6% 85%);
        box-shadow: 0 2px 6px rgba(17, 24, 39, 0.07);
    }

    .admin-dashboard .metric-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.56rem;
        margin-bottom: 0.42rem;
    }

    .admin-dashboard .metric-icon {
        width: 34px;
        height: 34px;
        border-radius: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .admin-dashboard .metric-icon.primary {
        background: hsl(142 58% 94%);
        color: hsl(142 76% 30%);
    }

    .admin-dashboard .metric-icon.accent {
        background: hsl(160 52% 93%);
        color: hsl(160 74% 28%);
    }

    .admin-dashboard .metric-icon.warning {
        background: hsl(45 100% 94%);
        color: hsl(32 95% 34%);
    }

    .admin-dashboard .metric-icon.neutral {
        background: hsl(60 5% 95%);
        color: hsl(24 10% 30%);
    }

    .admin-dashboard .metric-label {
        font-size: 0.73rem;
        font-weight: 600;
        color: var(--dash-muted);
    }

    .admin-dashboard .metric-value {
        font-size: 1.42rem;
        font-weight: 700;
        line-height: 1;
        color: var(--dash-text);
        margin-bottom: 0.18rem;
    }

    .admin-dashboard .metric-value.metric-warning {
        color: hsl(32 95% 34%);
    }

    .admin-dashboard .metric-value.metric-success {
        color: hsl(142 76% 30%);
    }

    .admin-dashboard .metric-note {
        margin: 0;
        font-size: 0.8rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .kpi-band {
        border: 1px solid var(--dash-border);
        border-radius: 0.65rem;
        background: var(--dash-card);
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        overflow: hidden;
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
    }

    .admin-dashboard .kpi-item {
        padding: 0.8rem 0.95rem;
        border-bottom: 1px solid var(--dash-border);
    }

    .admin-dashboard .kpi-item:last-child {
        border-bottom: 0;
    }

    .admin-dashboard .kpi-label {
        margin: 0;
        font-size: 0.74rem;
        font-weight: 500;
        color: var(--dash-muted);
    }

    .admin-dashboard .kpi-main {
        margin-top: 0.28rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
    }

    .admin-dashboard .kpi-value {
        font-size: 1.45rem;
        font-weight: 800;
        line-height: 1;
    }

    .admin-dashboard .kpi-value.primary {
        color: hsl(142 76% 30%);
    }

    .admin-dashboard .kpi-value.success {
        color: hsl(142 76% 30%);
    }

    .admin-dashboard .kpi-value.warning {
        color: hsl(32 95% 34%);
    }

    .admin-dashboard .kpi-value.neutral {
        color: var(--dash-text);
    }

    .admin-dashboard .kpi-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.16rem 0.52rem;
        font-size: 0.73rem;
        font-weight: 700;
    }

    .admin-dashboard .kpi-badge.primary {
        background: var(--dash-primary-soft);
        color: hsl(142 76% 24%);
    }

    .admin-dashboard .kpi-badge.success {
        background: hsl(142 58% 94%);
        color: hsl(142 76% 24%);
    }

    .admin-dashboard .kpi-badge.warning {
        background: hsl(45 100% 94%);
        color: hsl(32 95% 34%);
    }

    .admin-dashboard .panel-card {
        border: 1px solid var(--dash-border);
        border-radius: 0.65rem;
        background: var(--dash-card);
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
        overflow: hidden;
        transition: border-color 0.16s ease;
    }

    .admin-dashboard .panel-card:hover {
        transform: none;
        box-shadow: 0 1px 2px rgba(17, 24, 39, 0.05);
        border-color: hsl(20 6% 85%);
    }

    .admin-dashboard .panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        padding: 0.85rem 0.95rem;
        border-bottom: 1px solid var(--dash-border);
        background: #ffffff;
    }

    .admin-dashboard .panel-title {
        margin: 0;
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .admin-dashboard .panel-subtitle {
        font-size: 0.78rem;
        color: var(--dash-muted);
        white-space: nowrap;
    }

    .admin-dashboard .panel-body {
        padding: 0.9rem;
    }

    .admin-dashboard .panel-body-tight {
        padding: 0;
    }

    .admin-dashboard .employment-ring {
        position: relative;
        width: 132px;
        height: 132px;
        margin: 0 auto;
    }

    .admin-dashboard .employment-score {
        position: absolute;
        inset: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--dash-primary);
    }

    .admin-dashboard .employment-caption {
        margin: 0.75rem 0 0.92rem;
        text-align: center;
        font-size: 0.85rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .employment-breakdown {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.5rem;
        text-align: center;
    }

    .admin-dashboard .employment-number {
        font-size: 1.02rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .admin-dashboard .employment-number.employed {
        color: #15803d;
    }

    .admin-dashboard .employment-number.self-employed {
        color: #b45309;
    }

    .admin-dashboard .employment-number.unemployed {
        color: #b91c1c;
    }

    .admin-dashboard .employment-label {
        margin-top: 0.2rem;
        font-size: 0.74rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .role-row + .role-row {
        margin-top: 0.72rem;
    }

    .admin-dashboard .role-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.32rem;
        gap: 0.4rem;
    }

    .admin-dashboard .role-name {
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--dash-text);
        display: inline-flex;
        align-items: center;
        gap: 0.36rem;
    }

    .admin-dashboard .role-count {
        border-radius: 999px;
        padding: 0.14rem 0.45rem;
        font-size: 0.74rem;
        font-weight: 700;
    }

    .admin-dashboard .role-count.admin {
        background: hsl(0 85% 95%);
        color: hsl(0 72% 36%);
    }

    .admin-dashboard .role-count.staff {
        background: hsl(199 89% 94%);
        color: hsl(198 74% 28%);
    }

    .admin-dashboard .role-count.alumni {
        background: hsl(142 60% 94%);
        color: hsl(142 76% 24%);
    }

    .admin-dashboard .progress-track {
        width: 100%;
        height: 6px;
        border-radius: 999px;
        background: hsl(20 6% 93%);
        overflow: hidden;
    }

    .admin-dashboard .progress-fill {
        height: 100%;
        border-radius: 999px;
    }

    .admin-dashboard .progress-fill.admin {
        background: hsl(0 72% 46%);
    }

    .admin-dashboard .progress-fill.staff {
        background: hsl(198 74% 44%);
    }

    .admin-dashboard .progress-fill.alumni {
        background: var(--dash-primary);
    }

    .admin-dashboard .user-summary {
        margin-top: 0.85rem;
        padding-top: 0.72rem;
        border-top: 1px solid var(--dash-border);
        display: grid;
        gap: 0.42rem;
    }

    .admin-dashboard .user-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.86rem;
    }

    .admin-dashboard .quick-action-grid {
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        gap: 0.5rem;
    }

    .admin-dashboard .quick-action-link {
        border: 1px solid var(--dash-border);
        border-radius: 0.6rem;
        padding: 0.62rem 0.7rem;
        display: flex;
        align-items: center;
        gap: 0.58rem;
        color: inherit;
        text-decoration: none;
        background: #ffffff;
        transition: border-color 0.16s ease, background-color 0.16s ease;
    }

    .admin-dashboard .quick-action-link:hover {
        border-color: hsl(20 6% 85%);
        transform: none;
        box-shadow: none;
        background: hsl(60 5% 96%);
    }

    .admin-dashboard .quick-action-icon {
        width: 34px;
        height: 34px;
        border-radius: 0.45rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--dash-primary);
        background: var(--dash-primary-soft);
        flex-shrink: 0;
    }

    .admin-dashboard .quick-action-text {
        min-width: 0;
        flex: 1;
        line-height: 1.2;
    }

    .admin-dashboard .quick-action-title {
        display: block;
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .admin-dashboard .quick-action-meta {
        display: block;
        margin-top: 0.08rem;
        font-size: 0.76rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .quick-action-arrow {
        color: var(--dash-muted);
        font-size: 0.82rem;
        flex-shrink: 0;
    }

    .admin-dashboard .chart-compact {
        height: 240px;
    }

    .admin-dashboard .viewport-list {
        max-height: none;
        overflow-y: visible;
        scrollbar-width: auto;
    }

    .admin-dashboard .viewport-list::-webkit-scrollbar {
        width: 6px;
    }

    .admin-dashboard .viewport-list::-webkit-scrollbar-thumb {
        background: hsl(20 6% 85%);
        border-radius: 999px;
    }

    .admin-dashboard .table-minimal {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .admin-dashboard .table-minimal thead th {
        position: static;
        background: hsl(60 5% 96%);
        border-bottom: 1px solid var(--dash-border);
        color: var(--dash-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-weight: 600;
        text-align: left;
        padding: 0.72rem 0.88rem;
        white-space: nowrap;
    }

    .admin-dashboard .table-minimal tbody td {
        padding: 0.76rem 0.88rem;
        font-size: 0.86rem;
        border-bottom: 1px solid var(--dash-border);
        vertical-align: middle;
    }

    .admin-dashboard .table-minimal tbody tr:hover {
        background: hsl(60 5% 97%);
    }

    .admin-dashboard .table-minimal .cell-tight {
        width: 1%;
        white-space: nowrap;
    }

    .admin-dashboard .inline-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        border-radius: 0.45rem;
        border: 1px solid var(--dash-primary);
        background: var(--dash-primary);
        color: var(--dash-primary-foreground);
        font-size: 0.73rem;
        font-weight: 600;
        padding: 0.34rem 0.6rem;
        line-height: 1;
        text-decoration: none;
    }

    .admin-dashboard .inline-action-btn:hover {
        background: hsl(142 76% 32%);
        border-color: hsl(142 76% 32%);
        color: #fff;
    }

    .admin-dashboard .inline-action-btn.icon-only {
        gap: 0;
        min-width: 1.9rem;
        justify-content: center;
        padding: 0.38rem;
    }

    .admin-dashboard .list-block {
        display: flex;
        flex-direction: column;
    }

    .admin-dashboard .list-row {
        padding: 0.82rem 0.92rem;
        border-bottom: 1px solid var(--dash-border);
        transition: background-color 0.16s ease;
    }

    .admin-dashboard .list-row:hover {
        background: hsl(60 5% 97%);
    }

    .admin-dashboard .list-row:last-child {
        border-bottom: 0;
    }

    .admin-dashboard .list-row-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .admin-dashboard .list-tag {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.14rem 0.48rem;
        font-size: 0.68rem;
        font-weight: 600;
        background: hsl(60 5% 95%);
        color: var(--dash-text);
    }

    .admin-dashboard .list-time {
        font-size: 0.73rem;
        color: var(--dash-muted);
        white-space: nowrap;
    }

    .admin-dashboard .list-text {
        margin-top: 0.26rem;
        font-size: 0.82rem;
        color: var(--dash-muted);
        line-height: 1.4;
    }

    .admin-dashboard .announcement-title {
        margin: 0;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .admin-dashboard .announcement-text {
        margin: 0.24rem 0 0;
        font-size: 0.82rem;
        color: var(--dash-muted);
        line-height: 1.45;
    }

    .admin-dashboard .course-row + .course-row {
        margin-top: 0.78rem;
    }

    .admin-dashboard .course-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.3rem;
    }

    .admin-dashboard .course-name {
        font-size: 0.86rem;
        font-weight: 600;
        color: var(--dash-text);
    }

    .admin-dashboard .course-count {
        font-size: 0.8rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .empty-block {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--dash-muted);
    }

    .admin-dashboard .dashboard-footnote {
        order: 99;
        text-align: center;
        font-size: 0.75rem;
        color: var(--dash-muted);
        margin-top: 0.3rem;
        margin-bottom: 0.18rem;
    }

    .admin-dashboard .btn-outline-norsu,
    .admin-dashboard .btn-warning {
        border-radius: 0.45rem;
        font-weight: 600;
        letter-spacing: 0;
        padding-left: 0.75rem;
        padding-right: 0.75rem;
    }

    .admin-dashboard .btn-outline-norsu:hover {
        transform: none;
        box-shadow: none;
    }

    .admin-dashboard .btn-warning:hover {
        transform: none;
    }

    .admin-dashboard .btn-outline-norsu.btn-xs,
    .admin-dashboard .btn-warning.btn-xs {
        border-radius: 0.35rem;
        padding-left: 0.55rem;
        padding-right: 0.55rem;
    }

    @keyframes dashboard-enter {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (min-width: 768px) {
        .admin-dashboard .metric-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .admin-dashboard .kpi-band {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .admin-dashboard .kpi-item {
            border-bottom: 0;
            border-right: 1px solid var(--dash-border);
        }

        .admin-dashboard .kpi-item:last-child {
            border-right: 0;
        }

        .admin-dashboard .quick-action-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (min-width: 1280px) {
        .admin-dashboard .metric-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @media (max-width: 991.98px) {
        .admin-dashboard .panel-subtitle {
            white-space: normal;
            text-align: right;
        }

        .admin-dashboard .viewport-list {
            overflow-y: visible;
        }

        .admin-dashboard .chart-compact {
            height: 270px;
        }
    }

    @media (max-width: 767.98px) {
        .admin-dashboard .dashboard-shell {
            gap: 0.8rem;
        }

        .admin-dashboard .workspace-compact-toggle {
            display: none;
        }

        .admin-dashboard .workspace-toolbar {
            flex-direction: column;
            align-items: stretch;
            padding: 0.62rem 0.72rem;
        }

        .admin-dashboard .workspace-search {
            width: 100%;
        }

        .admin-dashboard .workspace-account {
            width: 100%;
            justify-content: space-between;
        }

        .admin-dashboard .workspace-account-meta {
            flex: 1;
        }

        .admin-dashboard .hero-main {
            padding: 0.95rem 0.9rem 0.75rem;
        }

        .admin-dashboard .hero-meta {
            padding: 0.52rem 0.9rem 0.62rem;
        }

        .admin-dashboard .hero-title {
            font-size: 1.35rem;
        }

        .admin-dashboard .hero-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .admin-dashboard .employment-breakdown {
            gap: 0.35rem;
        }

        .admin-dashboard .quick-action-grid {
            grid-template-columns: repeat(1, minmax(0, 1fr));
        }
    }
</style>

<section class="admin-dashboard">
    <div class="dashboard-shell">

        <div class="workspace-toolbar workspace-toolbar-top card-enter">
            <label class="workspace-search" for="adminDashboardSearch">
                <i class="bi bi-search"></i>
                <input id="adminDashboardSearch" type="search" placeholder="Search dashboard..." aria-label="Search dashboard">
            </label>
            <div class="workspace-account">
                <span class="workspace-account-avatar">{{ app.user.firstName|first }}{{ app.user.lastName|first }}</span>
                <div class="workspace-account-meta">
                    <span class="workspace-account-name">Account</span>
                    <span class="workspace-account-email">{{ app.user.email }}</span>
                </div>
                <button type="button" id="adminSidebarCompactToggle" class="workspace-account-link workspace-compact-toggle" aria-label="Toggle sidebar compact mode" aria-pressed="false" title="Collapse sidebar">
                    <i class="bi bi-layout-sidebar"></i>
                </button>
                <a href="{{ path('app_profile') }}" class="workspace-account-link">Profile</a>
            </div>
        </div>

        <div class="hero-panel card-enter dashboard-order-hero">
            <div class="hero-main">
                <div class="hero-user">
                    <div class="hero-avatar">{{ app.user.firstName|first }}{{ app.user.lastName|first }}</div>
                    <div class="min-w-0">
                        <h2 class="hero-title">Admin Dashboard</h2>
                        <p class="hero-subtitle">Welcome back, <strong>{{ app.user.firstName }}</strong>. Here is your system overview.</p>
                    </div>
                </div>
                <div class="hero-actions">
                    <a href="{{ path('announcement_create') }}" class="hero-btn hero-btn-solid"><i class="bi bi-megaphone-fill"></i>New Announcement</a>
                    <a href="{{ path('admin_gts_surveys_index') }}" class="hero-btn hero-btn-soft"><i class="bi bi-ui-checks-grid"></i>Survey Builder</a>
                    <a href="{{ path('admin_verification') }}" class="hero-btn hero-btn-soft"><i class="bi bi-patch-check-fill"></i>Verify Profiles</a>
                </div>
            </div>
            <div class="hero-meta">
                <span><i class="bi bi-calendar3"></i>{{ 'now'|date('F d, Y') }}</span>
                <span><i class="bi bi-clock"></i>{{ 'now'|date('h:i A') }}</span>
                <span class="hero-pill"><i class="bi bi-shield-check"></i>Administrator</span>
                <span class="ml-auto"><i class="bi bi-people"></i>{{ totalAlumni }} alumni | {{ totalUsers }} users | {{ totalSurveyResponses }} GTS responses</span>
            </div>
        </div>

        {% set headlineMetrics = [
            {label: 'Total Alumni', value: totalAlumni, icon: 'bi-people-fill', tone: 'primary', note: 'Profiles tracked'},
            {label: 'Registered Users', value: totalUsers, icon: 'bi-person-check-fill', tone: 'accent', note: 'Accounts in platform'},
            {label: 'Pending Approval', value: pendingUsers, icon: 'bi-hourglass-split', tone: pendingUsers > 0 ? 'warning' : 'accent', valueClass: pendingUsers > 0 ? 'metric-warning' : 'metric-success', note: pendingUsers > 0 ? 'Needs review' : 'All clear'},
            {label: 'Survey Responses', value: totalSurveyResponses, icon: 'bi-clipboard-data-fill', tone: 'neutral', note: 'Tracer data collected'}
        ] %}
        <div class="metric-grid dashboard-order-stats">
            {% for metric in headlineMetrics %}
            <article class="metric-card card-enter">
                <div class="metric-top">
                    <div class="metric-icon {{ metric.tone }}"><i class="bi {{ metric.icon }}"></i></div>
                    <span class="metric-label">{{ metric.label }}</span>
                </div>
                <div class="metric-value {{ metric.valueClass|default('') }}">{{ metric.value }}</div>
                <p class="metric-note">{{ metric.note }}</p>
            </article>
            {% endfor %}
        </div>

        <div class="kpi-band card-enter dashboard-order-kpi">
            <div class="kpi-item">
                <p class="kpi-label">Alignment Rate</p>
                <div class="kpi-main">
                    <span class="kpi-value primary">{{ alignmentRate }}%</span>
                    <span class="kpi-badge primary">Job vs Degree</span>
                </div>
            </div>
            <div class="kpi-item">
                <p class="kpi-label">Queue Health</p>
                <div class="kpi-main">
                    <span class="kpi-value {{ pendingUsers > 0 ? 'warning' : 'success' }}">{{ pendingUsers }}</span>
                    <span class="kpi-badge {{ pendingUsers > 0 ? 'warning' : 'success' }}">{{ pendingUsers > 0 ? 'Needs Review' : 'Stable' }}</span>
                </div>
            </div>
            <div class="kpi-item">
                <p class="kpi-label">Active Users</p>
                <div class="kpi-main">
                    <span class="kpi-value neutral">{{ activeUsers }}</span>
                    <span class="kpi-badge primary">Online now</span>
                </div>
            </div>
        </div>

        {% set registrationCards = [
            {key: 'unregistered', label: 'Unregistered Alumni', count: registrationStates.unregistered, note: 'Known alumni without an account yet', accent: 'border-slate-200 bg-slate-50 text-slate-800', link: path('alumni_index', {registration_state: 'unregistered'})},
            {key: 'pending', label: 'Pending Approval', count: registrationStates.pending, note: 'Accounts waiting for verification', accent: 'border-amber-200 bg-amber-50 text-amber-900', link: path('alumni_index', {registration_state: 'pending'})},
            {key: 'active', label: 'Active Accounts', count: registrationStates.active, note: 'Linked alumni already approved', accent: 'border-emerald-200 bg-emerald-50 text-emerald-900', link: path('alumni_index', {registration_state: 'active'})},
            {key: 'inactive', label: 'Inactive Accounts', count: registrationStates.inactive, note: 'Denied or restricted alumni accounts', accent: 'border-rose-200 bg-rose-50 text-rose-900', link: path('alumni_index', {registration_state: 'inactive'})}
        ] %}
        <div class="panel-card card-enter dashboard-order-operational">
            <div class="panel-head">
                <h6 class="panel-title"><i class="bi bi-diagram-3-fill"></i>Registration Snapshot</h6>
                <span class="panel-subtitle">Unified alumni account states</span>
            </div>
            <div class="panel-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3">
                    {% for card in registrationCards %}
                        <a href="{{ card.link }}" data-registration-state-card="{{ card.key }}" class="block rounded-xl border px-4 py-4 no-underline shadow-sm transition hover:-translate-y-0.5 hover:shadow-md {{ card.accent }}">
                            <div class="text-xs font-semibold uppercase tracking-[0.18em] opacity-70">{{ card.label }}</div>
                            <div class="mt-2 text-3xl font-bold">{{ card.count }}</div>
                            <div class="mt-1 text-sm opacity-80">{{ card.note }}</div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 dashboard-order-segments">
            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-building"></i>Alumni by College</h6>
                    <span class="panel-subtitle">Top segments</span>
                </div>
                <div class="panel-body">
                    {% if collegeStats|length > 0 %}
                        {% set maxCollege = collegeStats[0].total %}
                        {% for stat in collegeStats %}
                        <div class="course-row">
                            <div class="course-head">
                                <span class="course-name">{{ stat.label }}</span>
                                <span class="course-count">{{ stat.total }}</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" style="width:{{ maxCollege > 0 ? (stat.total / maxCollege * 100)|round : 0 }}%; background:var(--dash-primary);"></div>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty-block">
                            <i class="bi bi-building text-gray-400 text-3xl block mb-2"></i>
                            <p class="mb-0 text-sm">No college data yet</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-diagram-3"></i>Alumni by Department</h6>
                    <span class="panel-subtitle">Major or degree program</span>
                </div>
                <div class="panel-body">
                    {% if departmentStats|length > 0 %}
                        {% set maxDepartment = departmentStats[0].total %}
                        {% for stat in departmentStats %}
                        <div class="course-row">
                            <div class="course-head">
                                <span class="course-name">{{ stat.label }}</span>
                                <span class="course-count">{{ stat.total }}</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" style="width:{{ maxDepartment > 0 ? (stat.total / maxDepartment * 100)|round : 0 }}%; background:hsl(165 75% 32%);"></div>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty-block">
                            <i class="bi bi-diagram-3 text-gray-400 text-3xl block mb-2"></i>
                            <p class="mb-0 text-sm">No department data yet</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-calendar-range"></i>Alumni by Batch Year</h6>
                    <span class="panel-subtitle">Recent graduation cohorts</span>
                </div>
                <div class="panel-body">
                    {% if batchYearStats|length > 0 %}
                        {% set maxBatchYear = batchYearStats[0].total %}
                        {% for stat in batchYearStats %}
                        <div class="course-row">
                            <div class="course-head">
                                <span class="course-name">{{ stat.label }}</span>
                                <span class="course-count">{{ stat.total }}</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" style="width:{{ maxBatchYear > 0 ? (stat.total / maxBatchYear * 100)|round : 0 }}%; background:hsl(35 88% 38%);"></div>
                            </div>
                        </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty-block">
                            <i class="bi bi-calendar-range text-gray-400 text-3xl block mb-2"></i>
                            <p class="mb-0 text-sm">No batch year data yet</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 dashboard-order-snapshot">
            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-speedometer2"></i>Employment Rate</h6>
                        <span class="panel-subtitle">Current snapshot</span>
                    </div>
                    <div class="panel-body">
                        <div class="employment-ring">
                            <svg viewBox="0 0 36 36" class="w-full h-full">
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="hsl(20 6% 90%)" stroke-width="2.8"></path>
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="hsl(142 76% 36%)" stroke-width="2.8" stroke-dasharray="{{ employmentRate }}, 100" stroke-linecap="round"></path>
                            </svg>
                            <div class="employment-score">{{ employmentRate }}%</div>
                        </div>

                        <p class="employment-caption">of alumni are employed or self-employed.</p>

                        <div class="employment-breakdown">
                            <div>
                                <div class="employment-number employed">{{ employed }}</div>
                                <div class="employment-label">Employed</div>
                            </div>
                            <div>
                                <div class="employment-number self-employed">{{ selfEmployed }}</div>
                                <div class="employment-label">Self-Emp.</div>
                            </div>
                            <div>
                                <div class="employment-number unemployed">{{ unemployed }}</div>
                                <div class="employment-label">Unemployed</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-person-lines-fill"></i>User Overview</h6>
                        <span class="panel-subtitle">Role distribution</span>
                    </div>
                    <div class="panel-body">
                        {% set roles = [
                            {icon: 'bi-shield-fill', iconCls: 'text-red-600', countCls: 'admin', fillCls: 'admin', label: 'Admins', count: adminCount},
                            {icon: 'bi-person-badge-fill', iconCls: 'text-cyan-600', countCls: 'staff', fillCls: 'staff', label: 'Staff', count: staffCount},
                            {icon: 'bi-mortarboard-fill', iconCls: 'text-green-600', countCls: 'alumni', fillCls: 'alumni', label: 'Alumni', count: studentCount}
                        ] %}
                        {% for role in roles %}
                        <div class="role-row">
                            <div class="role-top">
                                <span class="role-name"><i class="bi {{ role.icon }} {{ role.iconCls }}"></i>{{ role.label }}</span>
                                <span class="role-count {{ role.countCls }}">{{ role.count }}</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill {{ role.fillCls }}" style="width:{{ totalUsers > 0 ? (role.count / totalUsers * 100)|round : 0 }}%"></div>
                            </div>
                        </div>
                        {% endfor %}

                        <div class="user-summary">
                            <div class="user-summary-row">
                                <span class="text-gray-500">Total Users</span>
                                <span class="font-bold">{{ totalUsers }}</span>
                            </div>
                            <div class="user-summary-row">
                                <span class="text-gray-500">Active</span>
                                <span class="font-bold text-green-700">{{ activeUsers }}</span>
                            </div>
                        </div>

                        <a href="{{ path('admin_users') }}" class="btn-outline-norsu btn-sm w-full mt-3 font-semibold">
                            <i class="bi bi-arrow-right mr-1"></i>Manage Users
                        </a>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-lightning-fill"></i>Quick Actions</h6>
                        <span class="panel-subtitle">Common shortcuts</span>
                    </div>
                    <div class="panel-body">
                        {% set actions = [
                            {path: 'announcement_create', icon: 'bi-megaphone-fill', label: 'New Announcement', note: 'Post updates for all alumni'},
                            {path: 'admin_gts_surveys_index', icon: 'bi-ui-checks-grid', label: 'Survey Builder', note: 'Open and manage tracer survey forms'},
                            {path: 'admin_verification', icon: 'bi-patch-check-fill', label: 'Profile Verification', note: 'Review and approve registrants'},
                            {path: 'alumni_index', icon: 'bi-people-fill', label: 'Alumni Directory', note: 'Search and maintain alumni records'},
                            {path: 'gts_index', icon: 'bi-clipboard2-data-fill', label: 'GTS Responses', note: 'Inspect submitted tracer forms'},
                            {path: 'admin_analytics_hub', icon: 'bi-grid-1x2-fill', label: 'Reports and Analytics', note: 'Open Analytics Hub for all reporting modules'}
                        ] %}
                        <div class="quick-action-grid">
                            {% for action in actions %}
                            <a href="{{ path(action.path, action.pathParams|default({})) }}" class="quick-action-link">
                                <span class="quick-action-icon"><i class="bi {{ action.icon }}"></i></span>
                                <span class="quick-action-text">
                                    <span class="quick-action-title">{{ action.label }}</span>
                                    <span class="quick-action-meta">{{ action.note }}</span>
                                </span>
                                <i class="bi bi-chevron-right quick-action-arrow"></i>
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-card card-enter dashboard-order-trend">
            <div class="panel-head">
                <h6 class="panel-title"><i class="bi bi-pie-chart-fill"></i>Employment Status Distribution</h6>
                <span class="panel-subtitle">Grouped by alumni employmentStatus</span>
            </div>
            <div class="panel-body">
                <div class="chart-compact">
                    <canvas id="employmentStatusPieChart"></canvas>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 dashboard-order-operational">
            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-hourglass-split"></i>Pending Approvals</h6>
                    {% if pendingUsers > 0 %}
                        <span class="badge badge-warning">{{ pendingUsers }}</span>
                    {% else %}
                        <span class="badge badge-success">All clear</span>
                    {% endif %}
                </div>
                <div class="panel-body panel-body-tight">
                    {% if pendingList|length > 0 %}
                    <div class="viewport-list">
                        <table class="table-minimal">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Registered</th>
                                    <th class="cell-tight text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pUser in pendingList %}
                                <tr>
                                    <td class="font-semibold">{{ pUser.fullName }}</td>
                                    <td class="text-gray-500">{{ pUser.email }}</td>
                                    <td class="text-gray-500">{{ pUser.dateRegistered|date('M d, Y') }}</td>
                                    <td class="cell-tight text-right">
                                        <form method="post" action="{{ path('admin_user_approve', {id: pUser.id}) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ pUser.id) }}">
                                            <button class="icon-action icon-action-approve icon-action-btn" type="submit" title="Approve" aria-label="Approve user"><i class="bi bi-check-lg"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% if pendingUsers > 5 %}
                    <div class="text-center py-2 border-t border-gray-100">
                        <a href="{{ path('admin_verification') }}" class="text-sm text-blue-700 font-semibold">View all {{ pendingUsers }} pending <i class="bi bi-arrow-right"></i></a>
                    </div>
                    {% endif %}
                    {% else %}
                    <div class="empty-block">
                        <i class="bi bi-check-circle text-green-600 text-3xl block mb-2"></i>
                        <p class="mb-0 text-sm font-medium">No pending approvals</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-activity"></i>Recent Activity</h6>
                    <a href="{{ path('admin_audit_log') }}" class="btn-outline-norsu btn-sm">View All</a>
                </div>
                <div class="panel-body panel-body-tight">
                    {% if recentAuditLogs|length > 0 %}
                    <div class="list-block viewport-list">
                        {% for log in recentAuditLogs %}
                        <div class="list-row">
                            <div class="list-row-top">
                                <span class="list-tag">{{ log.action }}</span>
                                <span class="list-time">{{ log.createdAt|date('M d, H:i') }}</span>
                            </div>
                            <p class="list-text">{{ log.details|default('-') }}</p>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="empty-block">
                        <i class="bi bi-journal text-gray-400 text-3xl block mb-2"></i>
                        <p class="mb-0 text-sm font-medium">No recent activity</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 dashboard-order-engagement">
            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-clipboard2-data-fill"></i>Recent GTS Responses</h6>
                    <a href="{{ path('gts_index') }}" class="btn-outline-norsu btn-sm">View All</a>
                </div>
                <div class="panel-body panel-body-tight">
                    {% if recentGtsResponses|length > 0 %}
                    <div class="list-block viewport-list">
                        {% for survey in recentGtsResponses %}
                        <div class="list-row">
                            <div class="list-row-top">
                                <h6 class="announcement-title">{{ survey.name ?: (survey.user ? survey.user.fullName : 'Unknown respondent') }}</h6>
                                <span class="list-tag">{{ survey.createdAt|date('M d') }}</span>
                            </div>
                            <p class="announcement-text">{{ survey.emailAddress ?: (survey.user ? survey.user.email : 'No email address') }}</p>
                            <div class="mt-2">
                                <a href="{{ path('gts_show', {id: survey.id}) }}" class="text-sm text-blue-700 font-semibold">Open response <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="empty-block">
                        <i class="bi bi-clipboard2 text-gray-400 text-3xl block mb-2"></i>
                        <p class="mb-0 text-sm font-medium">No tracer responses yet</p>
                    </div>
                    {% endif %}
                </div>
            </div>

            {% if recentAnnouncements|length > 0 %}
            <div class="panel-card card-enter">
                <div class="panel-head">
                    <h6 class="panel-title"><i class="bi bi-megaphone-fill"></i>Latest Announcements</h6>
                    <a href="{{ path('announcement_index') }}" class="btn-outline-norsu btn-sm">View All</a>
                </div>
                <div class="panel-body panel-body-tight">
                    <div class="list-block viewport-list">
                        {% for ann in recentAnnouncements %}
                        <div class="list-row">
                            <div class="list-row-top">
                                <h6 class="announcement-title">{{ ann.title }}</h6>
                                <span class="list-tag">{{ ann.datePosted|date('M d') }}</span>
                            </div>
                            <p class="announcement-text">{{ ann.description|length > 150 ? ann.description|slice(0, 150) ~ '...' : ann.description }}</p>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-3 dashboard-order-directory">
            <div class="lg:col-span-8">
                <div class="panel-card card-enter">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-clock-history"></i>Recently Added Alumni</h6>
                        <a href="{{ path('alumni_index') }}" class="btn-outline-norsu btn-sm">View All</a>
                    </div>
                    <div class="panel-body panel-body-tight">
                        <div class="viewport-list">
                            <table class="table-minimal">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Course</th>
                                        <th>Year</th>
                                        <th>Status</th>
                                        <th class="cell-tight text-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for alumni in recentAlumni %}
                                    <tr>
                                        <td>
                                            <div class="font-semibold">{{ alumni.lastName }}, {{ alumni.firstName }}</div>
                                            <span class="text-gray-500 text-[0.7rem]">{{ alumni.studentNumber }}</span>
                                        </td>
                                        <td>{{ alumni.course }}</td>
                                        <td>{{ alumni.yearGraduated ?? 'N/A' }}</td>
                                        <td>
                                            {% if alumni.employmentStatus == 'Employed' %}
                                                <span class="badge badge-employed">Employed</span>
                                            {% elseif alumni.employmentStatus == 'Unemployed' %}
                                                <span class="badge badge-unemployed">Unemployed</span>
                                            {% elseif alumni.employmentStatus == 'Self-Employed' %}
                                                <span class="badge badge-self-employed">Self-Employed</span>
                                            {% else %}
                                                <span class="badge badge-secondary">{{ alumni.employmentStatus ?? 'N/A' }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="cell-tight text-right">
                                            <div class="flex justify-end gap-1">
                                                <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="icon-action icon-action-view" title="View" aria-label="View alumni"><i class="bi bi-eye"></i></a>
                                                <a href="{{ path('alumni_edit', {id: alumni.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit alumni"><i class="bi bi-pencil"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-gray-500 py-8">
                                            No alumni records yet. <a href="{{ path('alumni_index') }}#addAlumniSection" onclick="setTimeout(function(){var s=document.getElementById('addAlumniSection');if(s)s.classList.remove('hidden')},100)">Add the first one</a>.
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-4">
                <div class="panel-card card-enter h-full">
                    <div class="panel-head">
                        <h6 class="panel-title"><i class="bi bi-mortarboard-fill"></i>Top Courses</h6>
                        <span class="panel-subtitle">Most represented programs</span>
                    </div>
                    <div class="panel-body">
                        {% if courseStats|length > 0 %}
                            {% set maxTotal = courseStats[0].total %}
                            {% for stat in courseStats %}
                            <div class="course-row">
                                <div class="course-head">
                                    <span class="course-name">{{ stat.course }}</span>
                                    <span class="course-count">{{ stat.total }}</span>
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width:{{ (stat.total / maxTotal * 100)|round }}%; background:var(--dash-primary);"></div>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-block">
                                <i class="bi bi-mortarboard text-gray-400 text-3xl block mb-2"></i>
                                <p class="mb-0 text-sm">No course data yet</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="dashboard-footnote">&copy; {{ 'now'|date('Y') }} NORSU Alumni Tracker</div>
    </div>
</section>

<script>
    document.addEventListener('turbo:load', function () {
        const canvas = document.getElementById('employmentStatusPieChart');
        if (!canvas || typeof Chart === 'undefined') {
            return;
        }

        const chartPayload = {{ employmentStatusChart|json_encode|raw }};
        const labels = chartPayload.labels || [];
        const values = chartPayload.values || [];

        if (!labels.length || !values.length) {
            return;
        }

        if (window.employmentStatusPieChartInstance) {
            window.employmentStatusPieChartInstance.destroy();
        }

        window.employmentStatusPieChartInstance = new Chart(canvas, {
            type: 'pie',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: [
                        '#16A34A',
                        '#22C55E',
                        '#10B981',
                        '#14B8A6',
                        '#F59E0B',
                        '#78716C',
                        '#EF4444'
                    ],
                    borderColor: '#FFFFFF',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                const label = context.label || '';
                                const value = context.parsed || 0;
                                return label + ': ' + value;
                            }
                        }
                    }
                }
            }
        });
    });
</script>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
{% endblock %}
