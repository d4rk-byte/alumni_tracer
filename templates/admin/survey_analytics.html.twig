{% extends 'base.html.twig' %}

{% block title %}Survey Analytics - NORSU Alumni Tracker{% endblock %}

{% block body %}
<div class="card mb-4">
    <div class="card-body py-4 px-4 md:px-5 flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-bold mb-1"><i class="bi bi-clipboard-data mr-1 text-blue-700"></i> Survey Analytics</h2>
            <p class="text-sm text-gray-500 mb-0">All submitted Graduate Tracer Survey responses.</p>
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ path('admin_analytics_hub') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-grid-1x2-fill mr-1"></i>Analytics Hub</a>
            <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 px-3 py-2 rounded-lg text-sm font-semibold">
                <i class="bi bi-collection"></i>
                <span>Total Responses: {{ totalResponses }}</span>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        {% if surveys|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                        <tr>
                            <th class="text-left px-4 py-3 font-semibold">Alumni Name</th>
                            <th class="text-left px-4 py-3 font-semibold">Date Submitted</th>
                            <th class="text-right px-4 py-3 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for survey in surveys %}
                            {% set surveyOwnerName = survey.user ? survey.user.fullName : survey.name %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-4 py-3 font-semibold">{{ surveyOwnerName ?: 'Unknown Alumni' }}</td>
                                <td class="px-4 py-3 text-gray-600">{{ survey.createdAt ? survey.createdAt|date('M d, Y h:i A') : 'N/A' }}</td>
                                <td class="px-4 py-3 text-right">
                                    <a href="{{ path('gts_show', {id: survey.id}) }}" class="icon-action icon-action-view" title="View response" aria-label="View survey response">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-12 text-gray-500">
                <i class="bi bi-inbox text-4xl block mb-2"></i>
                <p class="mb-0 text-sm font-medium">No survey responses found yet.</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
