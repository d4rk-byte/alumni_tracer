{% extends 'base.html.twig' %}

{% block title %}Survey Builder{% endblock %}

{% block body %}
{% set surveysIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_index' : 'staff_gts_surveys_index' %}
{% set surveysNewRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_new' : 'staff_gts_surveys_new' %}
{% set surveysEditRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_edit' : 'staff_gts_surveys_edit' %}
{% set surveysDeleteRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_delete' : 'staff_gts_surveys_delete' %}
{% set questionsIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_index' : 'staff_gts_questions_index' %}
{% set campaignNewRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_campaign_new' : 'staff_gts_campaign_new' %}
{% set campaignIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_campaign_index' : 'staff_gts_campaign_index' %}
<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center justify-between">
        <div class="max-w-3xl space-y-1.5">
            <h1 class="flex items-center gap-2 text-2xl font-bold text-gray-800">
                <i class="bi bi-ui-checks-grid text-norsu"></i>
                <span>Survey Builder</span>
            </h1>
            <p class="text-sm text-gray-500">Create and manage Graduate Tracer Survey forms. Open a survey to add or edit its questions.</p>
        </div>
        <a href="{{ path(surveysNewRoute) }}" class="btn-norsu inline-flex items-center justify-center">
            <i class="bi bi-plus-lg mr-1"></i>New Survey
        </a>
    </div>

    {% if templates is empty %}
        <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center shadow-sm">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 text-gray-500">
                <i class="bi bi-ui-checks-grid text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-800">No surveys yet</h3>
            <p class="mt-2 text-sm text-gray-500">Create your first survey to start building the Graduate Tracer Survey questionnaire.</p>
            <div class="mt-5">
                <a href="{{ path(surveysNewRoute) }}" class="btn-norsu inline-flex items-center justify-center">
                    <i class="bi bi-plus-lg mr-1"></i>Create First Survey
                </a>
            </div>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for template in templates %}
                <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-shadow hover:shadow-md">
                    <div class="flex flex-col gap-4 p-6 md:flex-row md:items-center justify-between">
                        <div class="min-w-0 flex-1 space-y-2">
                            <div class="flex flex-wrap items-center gap-2">
                                {% if template.isActive %}
                                    <span class="inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-700">Active</span>
                                {% else %}
                                    <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-500">Inactive</span>
                                {% endif %}
                                <span class="text-xs text-gray-400">Created {{ template.createdAt|date('M d, Y') }}</span>
                            </div>
                            <h2 class="text-lg font-bold text-gray-800">{{ template.title }}</h2>
                            {% if template.description %}
                                <p class="text-sm text-gray-500">{{ template.description }}</p>
                            {% endif %}
                            <p class="text-xs text-gray-400">{{ template.questions|length }} question{{ template.questions|length == 1 ? '' : 's' }}</p>
                        </div>

                        <div class="flex flex-wrap items-center gap-2 shrink-0">
                            <a href="{{ path(questionsIndexRoute, {templateId: template.id}) }}"
                               class="btn-norsu btn-sm inline-flex items-center justify-center">
                                <i class="bi bi-ui-checks-grid mr-1"></i>Manage Questions
                            </a>
                            <a href="{{ path(campaignIndexRoute, {id: template.id}) }}"
                               class="btn-outline-norsu btn-sm inline-flex items-center justify-center">
                                <i class="bi bi-envelope-paper mr-1"></i>Campaigns
                            </a>
                            <a href="{{ path(surveysEditRoute, {id: template.id}) }}"
                               class="btn-outline-norsu btn-sm inline-flex items-center justify-center">
                                <i class="bi bi-pencil mr-1"></i>Edit
                            </a>
                            <form method="post" action="{{ path(surveysDeleteRoute, {id: template.id}) }}"
                                  class="inline-flex"
                                  onsubmit="return confirm('Delete this survey and ALL its questions? This cannot be undone.')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_gts_survey_' ~ template.id) }}">
                                <button type="submit" class="btn-secondary btn-sm inline-flex items-center justify-center">
                                    <i class="bi bi-trash mr-1"></i>Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
