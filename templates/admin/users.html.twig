{% extends 'base.html.twig' %}

{% block title %}Manage Users{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css">
    <style>
        .manage-users-toolbar {
            position: relative;
            z-index: 30;
            overflow: visible;
        }

        .manage-users-toolbar-layout {
            display: grid;
            gap: 0.75rem;
            align-items: end;
        }

        .manage-users-toolbar-field {
            min-width: 0;
        }

        .manage-users-toolbar-actions {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.5rem;
        }

        .manage-users-search-wrap {
            position: relative;
        }

        .manage-users-search-icon {
            position: absolute;
            top: 50%;
            left: 1rem;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.9rem;
            pointer-events: none;
            z-index: 1;
        }

        .manage-users-search-input {
            padding-left: 2.9rem !important;
            padding-right: 1rem !important;
        }

        .manage-users-search-input::placeholder {
            color: #94a3b8;
        }

        @media (min-width: 1280px) {
            .manage-users-toolbar-layout {
                grid-template-columns: minmax(240px, 1.7fr) minmax(165px, 0.75fr) minmax(190px, 0.9fr) minmax(135px, 0.6fr) auto;
            }

            .manage-users-toolbar-actions {
                justify-content: flex-end;
                flex-wrap: nowrap;
                white-space: nowrap;
            }
        }

        .manage-users-table.dataTable {
            margin-top: 0 !important;
            border-bottom: none !important;
        }

        .manage-users-table.dataTable.no-footer {
            border-bottom: none !important;
        }

        .manage-users-table.dataTable thead th {
            border-bottom: 1px solid #e5e7eb !important;
        }

        .manage-users-table.dataTable tbody td {
            border-top: 1px solid #f3f4f6;
        }

        .manage-users-table.dataTable tbody tr:first-child td {
            border-top: none;
        }

        .manage-users-table.dataTable tbody tr:hover {
            background-color: #f8fafc;
        }

        .manage-users-table .academic-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            border-radius: 9999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 0.7rem;
            font-weight: 600;
            line-height: 1;
            padding: 0.3rem 0.55rem;
        }

        .dataTables_wrapper .dataTables_info {
            padding-top: 0 !important;
            color: #64748b;
            font-size: 0.78rem;
        }

        .dataTables_wrapper .dataTables_paginate {
            padding-top: 0 !important;
            display: flex;
            align-items: center;
            gap: 0.35rem;
            flex-wrap: wrap;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button {
            min-width: 2.4rem;
            margin-left: 0 !important;
            border-radius: 0.85rem !important;
            border: 1px solid #cbd5e1 !important;
            background: #ffffff !important;
            color: #334155 !important;
            padding: 0.45rem 0.8rem !important;
            line-height: 1 !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.current,
        .dataTables_wrapper .dataTables_paginate .paginate_button.current:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8) !important;
            border-color: #1d4ed8 !important;
            color: #ffffff !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
            background: #eff6ff !important;
            border-color: #93c5fd !important;
            color: #1d4ed8 !important;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled,
        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled:hover {
            opacity: 0.45;
            color: #94a3b8 !important;
            border-color: #e2e8f0 !important;
            background: #ffffff !important;
            cursor: default !important;
        }

        @media (max-width: 767px) {
            .dataTables_wrapper .dataTables_paginate {
                justify-content: center;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableElement = document.getElementById('usersTable');
            if (!tableElement || typeof window.jQuery === 'undefined' || !window.jQuery.fn.DataTable) {
                return;
            }

            const $ = window.jQuery;
            const searchInput = document.getElementById('usersTableSearch');
            const collegeSelect = document.getElementById('usersTableCollegeFilter');
            const departmentSelect = document.getElementById('usersTableDepartmentFilter');
            const batchSelect = document.getElementById('usersTableBatchFilter');
            const clearButton = document.getElementById('usersTableClearFilters');
            const printButton = document.getElementById('usersTablePrintButton');

            const normalize = (value) => String(value || '').trim().toLowerCase();
            const dataTable = $(tableElement).DataTable({
                autoWidth: false,
                info: true,
                lengthChange: false,
                pageLength: 10,
                order: [[3, 'desc']],
                columnDefs: [
                    { targets: 5, orderable: false, searchable: false },
                ],
                dom: 'rt<"flex flex-col gap-3 border-t border-gray-100 px-4 py-3 text-xs text-gray-500 md:flex-row md:items-center md:justify-between"ip>',
                language: {
                    emptyTable: 'No users found.',
                    info: 'Showing _START_ to _END_ of _TOTAL_ users',
                    infoEmpty: 'Showing 0 users',
                    paginate: {
                        previous: 'Prev',
                        next: 'Next',
                    },
                    zeroRecords: 'No users match the current filters.',
                },
            });

            const filterCallback = (settings, data, dataIndex) => {
                if (settings.nTable !== tableElement) {
                    return true;
                }

                const rowNode = settings.aoData[dataIndex] ? settings.aoData[dataIndex].nTr : null;
                if (!rowNode) {
                    return true;
                }

                const selectedCollege = normalize(collegeSelect ? collegeSelect.value : '');
                const selectedDepartment = normalize(departmentSelect ? departmentSelect.value : '');
                const selectedBatch = normalize(batchSelect ? batchSelect.value : '');

                const rowCollege = normalize(rowNode.dataset.college);
                const rowDepartment = normalize(rowNode.dataset.department);
                const rowBatch = normalize(rowNode.dataset.batch);

                if (selectedCollege !== '' && rowCollege !== selectedCollege) {
                    return false;
                }

                if (selectedDepartment !== '' && rowDepartment !== selectedDepartment) {
                    return false;
                }

                if (selectedBatch !== '' && rowBatch !== selectedBatch) {
                    return false;
                }

                return true;
            };

            $.fn.dataTable.ext.search.push(filterCallback);

            function syncDepartmentOptions() {
                if (!departmentSelect || !collegeSelect) {
                    return;
                }

                const selectedCollege = normalize(collegeSelect.value);
                Array.from(departmentSelect.options).forEach((option, index) => {
                    if (index === 0) {
                        option.hidden = false;
                        option.disabled = false;

                        return;
                    }

                    const optionCollege = normalize(option.dataset.college);
                    const matchesCollege = selectedCollege === '' || optionCollege === '' || optionCollege === selectedCollege;
                    option.hidden = !matchesCollege;
                    option.disabled = !matchesCollege;
                });

                const selectedOption = departmentSelect.selectedOptions[0];
                if (selectedOption && selectedOption.disabled) {
                    departmentSelect.value = '';
                }
            }

            function syncUrlState() {
                const url = new URL(window.location.href);
                const values = {
                    q: searchInput ? searchInput.value.trim() : '',
                    college: collegeSelect ? collegeSelect.value : '',
                    department: departmentSelect ? departmentSelect.value : '',
                    batch: batchSelect ? batchSelect.value : '',
                };

                Object.entries(values).forEach(([key, value]) => {
                    if (value) {
                        url.searchParams.set(key, value);
                    } else {
                        url.searchParams.delete(key);
                    }
                });

                window.history.replaceState({}, '', url);
            }

            function applyFilters() {
                syncDepartmentOptions();
                dataTable.search(searchInput ? searchInput.value.trim() : '').draw();
                syncUrlState();
            }

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            if (collegeSelect) {
                collegeSelect.addEventListener('change', applyFilters);
            }

            if (departmentSelect) {
                departmentSelect.addEventListener('change', applyFilters);
            }

            if (batchSelect) {
                batchSelect.addEventListener('change', applyFilters);
            }

            if (clearButton) {
                clearButton.addEventListener('click', () => {
                    if (searchInput) {
                        searchInput.value = '';
                    }

                    if (collegeSelect) {
                        collegeSelect.value = '';
                    }

                    if (departmentSelect) {
                        departmentSelect.value = '';
                    }

                    if (batchSelect) {
                        batchSelect.value = '';
                    }

                    applyFilters();
                    dataTable.page('first').draw('page');
                });
            }

            let restorePrintState = null;
            if (printButton) {
                printButton.addEventListener('click', () => {
                    restorePrintState = {
                        pageLength: dataTable.page.len(),
                        pageIndex: dataTable.page(),
                    };

                    dataTable.page.len(-1).draw();
                    window.requestAnimationFrame(() => window.print());
                });

                window.addEventListener('afterprint', () => {
                    if (!restorePrintState) {
                        return;
                    }

                    const { pageLength, pageIndex } = restorePrintState;
                    restorePrintState = null;

                    dataTable.page.len(pageLength).draw(false);
                    dataTable.page(pageIndex).draw('page');
                });
            }

            syncDepartmentOptions();
            applyFilters();
        });
    </script>
{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="font-bold text-xl mb-0"><i class="bi bi-people-fill mr-2"></i>Manage Users</h4>
        <p class="text-gray-500 text-sm mb-0">View and manage all registered accounts</p>
    </div>
    {% if pendingCount > 0 %}
        <span class="bg-amber-100 text-amber-800 text-sm font-semibold px-3 py-1 rounded-full no-print"><i class="bi bi-hourglass-split mr-1"></i>{{ pendingCount }} pending</span>
    {% endif %}
</div>

{# ── Print-only header ── #}
<div class="hidden print-header" style="display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <h2 style="margin:0; font-size:18pt; font-weight:bold;">Negros Oriental State University</h2>
        <h3 style="margin:4px 0; font-size:14pt;">User Directory</h3>
        <p style="margin:4px 0; font-size:10pt; color:#555;">
            Printed on: {{ 'now'|date('F d, Y') }}
            {% if search %} | Search: "{{ search }}"{% endif %}
            {% if selectedCollege %} | College: {{ selectedCollege }}{% endif %}
            {% if selectedDepartment %} | Department: {{ selectedDepartment }}{% endif %}
            {% if selectedBatch %} | Batch: {{ selectedBatch }}{% endif %}
        </p>
        <hr style="margin-top:10px;">
    </div>
</div>

{# ── Search, Filters, Actions ── #}
<div class="bg-white rounded-2xl shadow-sm mb-4 manage-users-toolbar no-print border border-slate-100">
    <div class="p-4 manage-users-toolbar-layout">
            <label class="block manage-users-toolbar-field">
                <span class="block text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 mb-2">Search</span>
                <span class="manage-users-search-wrap block">
                    <i class="bi bi-search manage-users-search-icon"></i>
                    <input
                        id="usersTableSearch"
                        type="text"
                        value="{{ search }}"
                        class="manage-users-search-input w-full rounded-xl border border-slate-200 bg-slate-50/70 py-3 text-sm text-slate-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200"
                        placeholder="Search name, email, role, or academic details..."
                    >
                </span>
            </label>

            <label class="block manage-users-toolbar-field">
                <span class="block text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 mb-2">College</span>
                <select id="usersTableCollegeFilter" class="w-full rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3 text-sm text-slate-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200">
                    <option value="">All Colleges</option>
                    {% for college in collegeOptions %}
                        <option value="{{ college }}" {{ selectedCollege == college ? 'selected' }}>{{ college }}</option>
                    {% endfor %}
                </select>
            </label>

            <label class="block manage-users-toolbar-field">
                <span class="block text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 mb-2">Department</span>
                <select id="usersTableDepartmentFilter" class="w-full rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3 text-sm text-slate-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200">
                    <option value="">All Departments</option>
                    {% for department in departmentOptions %}
                        <option
                            value="{{ department }}"
                            data-college="{{ departmentCollegeMap[department]|default('') }}"
                            {{ selectedDepartment == department ? 'selected' }}
                        >
                            {{ department }}
                        </option>
                    {% endfor %}
                </select>
            </label>

            <label class="block manage-users-toolbar-field">
                <span class="block text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500 mb-2">Batch</span>
                <select id="usersTableBatchFilter" class="w-full rounded-xl border border-slate-200 bg-slate-50/70 px-3 py-3 text-sm text-slate-700 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200">
                    <option value="">All Batches</option>
                    {% for batch in batchOptions %}
                        <option value="{{ batch }}" {{ selectedBatch == (batch ~ '') ? 'selected' }}>{{ batch }}</option>
                    {% endfor %}
                </select>
            </label>

        <div class="manage-users-toolbar-actions">
            <button type="button" id="usersTableClearFilters" class="inline-flex min-h-[48px] items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-600 transition hover:border-slate-300 hover:bg-slate-50">
                <i class="bi bi-arrow-counterclockwise"></i>
                Clear
            </button>

            <div class="relative z-[60]" data-controller="dropdown-menu">
                <button type="button"
                        class="inline-flex min-h-[48px] items-center gap-2 rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-700"
                        data-action="click->dropdown-menu#toggle"
                        data-dropdown-menu-target="button"
                        aria-haspopup="true"
                        aria-expanded="false">
                    <i class="bi bi-person-plus-fill"></i>
                    Create User
                    <i class="bi bi-chevron-down text-xs transition-transform" data-dropdown-menu-target="icon"></i>
                </button>

                <div class="hidden absolute right-0 top-full mt-2 w-48 overflow-hidden rounded-xl border border-slate-200 bg-white shadow-xl z-[80]"
                     data-dropdown-menu-target="menu">
                    <a href="{{ path('app_staff_create') }}" class="block px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-blue-50 hover:text-blue-700">
                        <i class="bi bi-person-badge mr-2"></i>Create Staff
                    </a>
                    <a href="{{ path('app_alumni_create') }}" class="block border-t border-slate-100 px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-blue-50 hover:text-blue-700">
                        <i class="bi bi-mortarboard mr-2"></i>Create Alumni
                    </a>
                </div>
            </div>

            <a href="{{ path('admin_users_export') }}" class="inline-flex min-h-[48px] items-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                Export CSV
            </a>

            <button id="usersTablePrintButton" type="button" class="inline-flex min-h-[48px] items-center gap-2 rounded-xl bg-slate-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
                <i class="bi bi-printer"></i>
                Print
            </button>
        </div>
    </div>
</div>

{# ── Users Table ── #}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table id="usersTable" class="w-full text-sm manage-users-table">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-200 text-gray-600 text-xs uppercase tracking-wider">
                    <th class="px-4 py-3 text-left font-semibold">User</th>
                    <th class="px-4 py-3 text-left font-semibold">Role</th>
                    <th class="px-4 py-3 text-left font-semibold">Status</th>
                    <th class="px-4 py-3 text-left font-semibold">Registered</th>
                    <th class="px-4 py-3 text-left font-semibold">Last Login</th>
                    <th class="px-4 py-3 text-right font-semibold no-print">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for user in users %}
                {% set alumni = user.alumni %}
                {% set college = alumni ? alumni.college|default('') : '' %}
                {% set department = alumni ? (alumni.degreeProgram ?: alumni.course)|default('') : '' %}
                {% set batch = alumni and alumni.yearGraduated ? alumni.yearGraduated : '' %}
                <tr
                    class="hover:bg-gray-50 transition {{ user.accountStatus == 'pending' ? 'bg-amber-50' : '' }}"
                    data-college="{{ college|e('html_attr') }}"
                    data-department="{{ department|e('html_attr') }}"
                    data-batch="{{ batch|e('html_attr') }}"
                >
                    {# ── User info (name + email combined) ── #}
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0
                                {% if 'ROLE_ADMIN' in user.roles %} bg-gradient-to-br from-red-500 to-red-700
                                {% elseif 'ROLE_STAFF' in user.roles %} bg-gradient-to-br from-blue-500 to-blue-700
                                {% else %} bg-gradient-to-br from-emerald-500 to-teal-700{% endif %}">
                                {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                            </div>
                            <div>
                                <p class="font-semibold text-gray-800 mb-0 leading-tight">{{ user.fullName }}</p>
                                <p class="text-gray-500 text-xs mb-0">{{ user.email }}</p>
                                {% if college or department or batch %}
                                    <div class="mt-1 flex flex-wrap gap-1.5">
                                        {% if college %}
                                            <span class="academic-chip"><i class="bi bi-building text-[10px]"></i>{{ college }}</span>
                                        {% endif %}
                                        {% if department %}
                                            <span class="academic-chip"><i class="bi bi-diagram-3 text-[10px]"></i>{{ department }}</span>
                                        {% endif %}
                                        {% if batch %}
                                            <span class="academic-chip"><i class="bi bi-calendar4-week text-[10px]"></i>Batch {{ batch }}</span>
                                        {% endif %}
                                    </div>
                                {% else %}
                                    <p class="mt-1 mb-0 text-[11px] font-medium text-slate-400">No alumni academic profile linked.</p>
                                {% endif %}
                            </div>
                        </div>
                    </td>
                    {# ── Role ── #}
                    <td class="px-4 py-3">
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span class="inline-flex items-center gap-1 bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full"><i class="bi bi-shield-fill text-[10px]"></i>Admin</span>
                        {% elseif 'ROLE_STAFF' in user.roles %}
                            <span class="inline-flex items-center gap-1 bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-0.5 rounded-full"><i class="bi bi-person-badge text-[10px]"></i>Staff</span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 text-xs font-semibold px-2 py-0.5 rounded-full"><i class="bi bi-mortarboard text-[10px]"></i>Alumni</span>
                        {% endif %}
                    </td>
                    {# ── Status ── #}
                    <td class="px-4 py-3">
                        {% if user.accountStatus == 'active' %}
                            <span class="inline-flex items-center gap-1 text-xs font-semibold text-green-700"><span class="w-2 h-2 bg-green-500 rounded-full"></span>Active</span>
                        {% elseif user.accountStatus == 'pending' %}
                            <span class="inline-flex items-center gap-1 text-xs font-semibold text-amber-700"><span class="w-2 h-2 bg-amber-500 rounded-full"></span>Pending</span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 text-xs font-semibold text-gray-500"><span class="w-2 h-2 bg-gray-400 rounded-full"></span>Inactive</span>
                        {% endif %}
                    </td>
                    {# ── Dates ── #}
                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap" data-order="{{ user.dateRegistered|date('Y-m-d H:i:s') }}">{{ user.dateRegistered|date('M d, Y') }}</td>
                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap" data-order="{{ user.lastLogin ? user.lastLogin|date('Y-m-d H:i:s') : '' }}">{{ user.lastLogin ? user.lastLogin|date('M d, Y H:i') : '—' }}</td>
                    {# ── Actions ── #}
                    <td class="px-4 py-3 text-right no-print">
                        <div class="flex items-center justify-end gap-1">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="w-8 h-8 rounded-lg bg-blue-100 text-blue-700 hover:bg-blue-200 transition flex items-center justify-center" title="Edit User">
                                <i class="bi bi-pencil text-sm"></i>
                            </a>
                            {% if user.accountStatus == 'pending' %}
                            <form method="post" action="{{ path('admin_user_approve', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ user.id) }}">
                                <button class="w-8 h-8 rounded-lg bg-green-100 text-green-700 hover:bg-green-200 transition flex items-center justify-center" title="Approve">
                                    <i class="bi bi-check-lg text-sm"></i>
                                </button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('admin_user_toggle_status', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                <button class="w-8 h-8 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition flex items-center justify-center" title="{{ user.accountStatus == 'active' ? 'Deactivate' : 'Activate' }}">
                                    <i class="bi {{ user.accountStatus == 'active' ? 'bi-pause-circle' : 'bi-play-circle' }} text-sm"></i>
                                </button>
                            </form>
                            {% if is_granted('ROLE_SUPER_ADMIN') %}
                            <form method="post" action="{{ path('admin_user_toggle_admin', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin' ~ user.id) }}">
                                <button class="w-8 h-8 rounded-lg bg-amber-100 text-amber-700 hover:bg-amber-200 transition flex items-center justify-center" title="Toggle Admin Role">
                                    <i class="bi bi-shield-lock text-sm"></i>
                                </button>
                            </form>
                            {% endif %}
                            {% if user != app.user %}
                            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}"
                                  onsubmit="return confirm('Are you sure you want to delete this user?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="w-8 h-8 rounded-lg bg-red-100 text-red-600 hover:bg-red-200 transition flex items-center justify-center" title="Delete User">
                                    <i class="bi bi-trash text-sm"></i>
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="6" class="px-4 py-8 text-center text-gray-400"><i class="bi bi-people text-2xl block mb-2"></i>No users found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
