{% extends 'base.html.twig' %}

{% block title %}Verification — NORSU Alumni Tracker{% endblock %}

{% block body %}
{# ── Header ── #}
<div class="flex justify-between items-center mb-4 flex-wrap gap-2">
    <div>
        <h4 class="font-bold mb-0 text-xl"><i class="bi bi-shield-check mr-2"></i>Alumni Verification System</h4>
        <p class="text-gray-500 mb-0 text-sm">Approve or deny new alumni registrants before they are added to the system.</p>
    </div>
    {% if pendingCount > 0 and is_granted('ROLE_ADMIN') %}
    <form method="post" action="{{ path('admin_verification_bulk_approve') }}"
          onsubmit="return confirm('Approve all {{ pendingCount }} pending registrations?')">
        <input type="hidden" name="_token" value="{{ csrf_token('bulk_approve') }}">
        <button class="btn-norsu btn-sm font-semibold">
            <i class="bi bi-check-all mr-1"></i>Approve All ({{ pendingCount }})
        </button>
    </form>
    {% endif %}
</div>

{# ── Print / Export Actions ── #}
<div class="flex justify-end gap-2 mb-4 no-print">
    <a href="{{ path('admin_verification_export') }}" class="inline-flex items-center gap-1 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
        <i class="bi bi-file-earmark-spreadsheet"></i>Export CSV
    </a>
    <button onclick="window.print()" class="inline-flex items-center gap-1 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
        <i class="bi bi-printer"></i>Print
    </button>
</div>

{# ── Print-only header ── #}
<div class="hidden print-header" style="display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <h2 style="margin:0; font-size:18pt; font-weight:bold;">Negros Oriental State University</h2>
        <h3 style="margin:4px 0; font-size:14pt;">Alumni Verification Report</h3>
        <p style="margin:4px 0; font-size:10pt; color:#555;">Pending: {{ pendingCount }} | Approved: {{ approvedCount }} | Denied: {{ deniedCount }} | Printed on: {{ 'now'|date('F d, Y') }}</p>
        <hr style="margin-top:10px;">
    </div>
</div>

{# ── Search Bar ── #}
<div class="bg-white rounded-xl shadow-sm mb-4">
    <div class="p-3">
        <form method="get" action="{{ path('admin_verification') }}" class="flex gap-2">
            <input type="text" name="q" value="{{ search|default('') }}" class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm" placeholder="Search by name or email...">
            <button type="submit" class="btn-norsu btn-sm"><i class="bi bi-search"></i></button>
            {% if search|default('') %}
                <a href="{{ path('admin_verification') }}" class="bg-gray-200 text-gray-700 rounded-lg px-3 py-2 text-sm hover:bg-gray-300">Clear</a>
            {% endif %}
        </form>
    </div>
</div>

{# ── Stats ── #}
<div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4 no-print">
    <div class="stat-card border-l-4 border-amber-400">
        <div class="p-4 flex items-center gap-3">
            <div class="stat-icon" style="background:#FEF3C7">
                <i class="bi bi-hourglass-split text-xl" style="color:#D97706"></i>
            </div>
            <div>
                <div class="stat-value">{{ pendingCount }}</div>
                <div class="stat-label">Pending Verification</div>
            </div>
        </div>
    </div>
    <div class="stat-card border-l-4 border-green-500">
        <div class="p-4 flex items-center gap-3">
            <div class="stat-icon" style="background:#D1FAE5">
                <i class="bi bi-check-circle-fill text-xl" style="color:#059669"></i>
            </div>
            <div>
                <div class="stat-value">{{ approvedCount }}</div>
                <div class="stat-label">Approved</div>
            </div>
        </div>
    </div>
    <div class="stat-card border-l-4 border-red-500">
        <div class="p-4 flex items-center gap-3">
            <div class="stat-icon" style="background:#FEE2E2">
                <i class="bi bi-x-circle-fill text-xl" style="color:#DC2626"></i>
            </div>
            <div>
                <div class="stat-value">{{ deniedCount }}</div>
                <div class="stat-label">Denied / Inactive</div>
            </div>
        </div>
    </div>
</div>

{# ── Pending Registrants Table ── #}
<div class="card mb-4">
    <div class="card-header bg-white flex items-center gap-2">
        <i class="bi bi-hourglass-split text-amber-500"></i> Pending Registrants
        {% if pendingCount > 0 %}
            <span class="badge badge-warning ml-1">{{ pendingCount }}</span>
        {% endif %}
    </div>
    <div class="p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="pl-4 py-3 font-semibold text-left">Name</th>
                    <th class="py-3 font-semibold text-left">Email</th>
                    <th class="py-3 font-semibold text-left">Date Registered</th>
                    <th class="py-3 font-semibold text-left">Alumni Record</th>
                    <th class="text-right pr-4 py-3 font-semibold no-print">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for user in pending %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-4 py-3">
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center text-[0.7rem] font-bold shrink-0">
                                {{ user.firstName|first }}{{ user.lastName|first }}
                            </div>
                            <div class="font-semibold">{{ user.fullName }}</div>
                        </div>
                    </td>
                    <td class="py-3">{{ user.email }}</td>
                    <td class="py-3 text-sm">{{ user.dateRegistered|date('M d, Y h:i A') }}</td>
                    <td class="py-3">
                        {% if user.alumni %}
                            <span class="badge badge-info"><i class="bi bi-check mr-1"></i>Submitted</span>
                        {% else %}
                            <span class="badge badge-secondary">Not yet</span>
                        {% endif %}
                    </td>
                    <td class="text-right pr-4 py-3 no-print">
                        <div class="flex justify-end gap-1">
                            <form method="post" action="{{ path('admin_verification_approve', {id: user.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ user.id) }}">
                                <button class="icon-action icon-action-approve icon-action-btn" title="Approve" aria-label="Approve registration">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_verification_deny', {id: user.id}) }}" class="inline"
                                  onsubmit="return confirm('Deny registration for {{ user.fullName }}?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('verify' ~ user.id) }}">
                                <button class="icon-action icon-action-delete icon-action-btn" title="Deny" aria-label="Deny registration">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center text-gray-500 py-8">
                        <i class="bi bi-check-circle text-green-600 text-3xl block mb-2"></i>
                        No pending registrations. All caught up!
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Recently Approved / Denied ── #}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
    <div class="card">
        <div class="card-header bg-white font-semibold">
            <i class="bi bi-check-circle text-green-600 mr-1"></i> Recently Approved
        </div>
        <div class="p-0 overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                    <tr>
                        <th class="pl-4 py-2.5 font-semibold text-left">Name</th>
                        <th class="py-2.5 font-semibold text-left">Email</th>
                        <th class="py-2.5 font-semibold text-left">Registered</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for user in approved %}
                    <tr class="hover:bg-gray-50">
                        <td class="pl-4 py-2.5 font-semibold text-sm">{{ user.fullName }}</td>
                        <td class="py-2.5 text-sm">{{ user.email }}</td>
                        <td class="py-2.5 text-sm">{{ user.dateRegistered|date('M d, Y') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="text-center text-gray-500 py-4 text-sm">None yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="card">
        <div class="card-header bg-white font-semibold">
            <i class="bi bi-x-circle text-red-600 mr-1"></i> Recently Denied
        </div>
        <div class="p-0 overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                    <tr>
                        <th class="pl-4 py-2.5 font-semibold text-left">Name</th>
                        <th class="py-2.5 font-semibold text-left">Email</th>
                        <th class="py-2.5 font-semibold text-left">Registered</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for user in denied %}
                    <tr class="hover:bg-gray-50">
                        <td class="pl-4 py-2.5 font-semibold text-sm">{{ user.fullName }}</td>
                        <td class="py-2.5 text-sm">{{ user.email }}</td>
                        <td class="py-2.5 text-sm">{{ user.dateRegistered|date('M d, Y') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="3" class="text-center text-gray-500 py-4 text-sm">None yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
