{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Edit Question' : 'Add Question' }}{% endblock %}

{% block body %}
{% set surveysIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_index' : 'staff_gts_surveys_index' %}
{% set questionIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_index' : 'staff_gts_questions_index' %}
<div class="mx-auto max-w-4xl space-y-6">
    <div class="flex flex-col gap-3 sm:flex-row items-start justify-between">
        <div class="space-y-1.5">
            <h1 class="text-2xl font-bold text-gray-800">{{ isEdit ? 'Edit Question' : 'Add Question' }}</h1>
            <p class="max-w-2xl text-sm text-gray-500">Update the question text, input type, and choices for the Graduate Tracer Survey form. Keep sections and sort order consistent so the whole form stays clean.</p>
        </div>
        <a href="{{ surveyTemplate ? path(questionIndexRoute, {templateId: surveyTemplate.id}) : path(surveysIndexRoute) }}" class="btn-secondary btn-sm inline-flex items-center justify-center"><i class="bi bi-arrow-left mr-1"></i>Back</a>
    </div>

    <div class="grid gap-6 md:grid-cols-12">
        <div class="md:col-span-8 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
            {{ form_start(form, { attr: { class: 'space-y-6' } }) }}
                <div class="grid gap-4 md:grid-cols-2">
                    <div class="space-y-1.5 md:col-span-2">
                        {{ form_label(form.section, null, { label_attr: { class: 'block text-sm font-semibold text-gray-700' } }) }}
                        {{ form_widget(form.section) }}
                        <div class="text-sm text-red-600">{{ form_errors(form.section) }}</div>
                    </div>

                    <div class="space-y-1.5 md:col-span-2">
                        {{ form_label(form.questionText, null, { label_attr: { class: 'block text-sm font-semibold text-gray-700' } }) }}
                        {{ form_widget(form.questionText) }}
                        <div class="text-sm text-red-600">{{ form_errors(form.questionText) }}</div>
                    </div>

                    <div class="space-y-1.5">
                        {{ form_label(form.inputType, null, { label_attr: { class: 'block text-sm font-semibold text-gray-700' } }) }}
                        {{ form_widget(form.inputType) }}
                        <div class="text-sm text-red-600">{{ form_errors(form.inputType) }}</div>
                    </div>
                    <div class="space-y-1.5">
                        {{ form_label(form.sortOrder, null, { label_attr: { class: 'block text-sm font-semibold text-gray-700' } }) }}
                        {{ form_widget(form.sortOrder) }}
                        <div class="text-sm text-red-600">{{ form_errors(form.sortOrder) }}</div>
                    </div>
                </div>

                <div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
                    <div class="space-y-1.5">
                        {{ form_label(form.optionsCsv, null, { label_attr: { class: 'block text-sm font-semibold text-gray-700' } }) }}
                        {{ form_widget(form.optionsCsv) }}
                    </div>
                    <div class="mt-3 space-y-1 text-xs text-gray-500">
                        <p>For radio, checkbox, and select inputs, enter one choice per line.</p>
                        <p>For repeater rows, use one column per line in the format: <span class="font-mono">field_key|Field Label|type|Option A, Option B</span>.</p>
                    </div>
                    <div class="mt-2 text-sm text-red-600">{{ form_errors(form.optionsCsv) }}</div>
                </div>

                <div class="rounded-2xl border border-gray-100 bg-white px-4 py-4">
                    <label class="inline-flex items-center gap-3 text-sm text-gray-700">
                        {{ form_widget(form.isActive) }}
                        <span class="font-medium">Active question</span>
                    </label>
                </div>

                <div class="flex flex-col gap-2 border-t border-gray-100 pt-4 sm:flex-row justify-end">
                    <a href="{{ surveyTemplate ? path(questionIndexRoute, {templateId: surveyTemplate.id}) : path(surveysIndexRoute) }}" class="btn-secondary inline-flex items-center justify-center">Cancel</a>
                    <button type="submit" class="btn-norsu inline-flex items-center justify-center">{{ isEdit ? 'Update Question' : 'Save Question' }}</button>
                </div>
            {{ form_end(form) }}
        </div>

        <aside class="md:col-span-4 rounded-2xl border border-blue-200 bg-blue-50 p-5 shadow-sm">
            <div class="text-xs font-bold uppercase tracking-wide text-blue-700">Layout Guide</div>
            <div class="mt-3 space-y-4 text-sm text-gray-600">
                <p>Use short, clear section names so questions stay grouped well in the full form preview.</p>
                <p>Use sort order to control the vertical flow inside each section.</p>
                <p>Keep long option lists in the choices box only when the selected input type needs them.</p>
            </div>
        </aside>
    </div>
</div>
{% endblock %}
