{% extends 'base.html.twig' %}

{% block title %}{{ surveyTemplate.title }} – Questions{% endblock %}

{% block body %}
{% set surveysIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_surveys_index' : 'staff_gts_surveys_index' %}
{% set questionIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_index' : 'staff_gts_questions_index' %}
{% set questionNewRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_new' : 'staff_gts_questions_new' %}
{% set questionEditRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_edit' : 'staff_gts_questions_edit' %}
{% set questionDeleteRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_delete' : 'staff_gts_questions_delete' %}
{% set questionImportRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_questions_import_defaults' : 'staff_gts_questions_import_defaults' %}
{% set questionPreviewRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_survey_preview' : 'staff_gts_survey_preview' %}
{% set campaignIndexRoute = is_granted('ROLE_ADMIN') ? 'admin_gts_campaign_index' : 'staff_gts_campaign_index' %}
<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-center justify-between">
        <div class="max-w-3xl space-y-1.5">
            <a href="{{ path(surveysIndexRoute) }}" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-norsu">
                <i class="bi bi-arrow-left"></i> All Surveys
            </a>
            <h1 class="flex items-center gap-2 text-2xl font-bold text-gray-800">
                <i class="bi bi-ui-checks-grid text-norsu"></i>
                <span>{{ surveyTemplate.title }}</span>
            </h1>
            {% if surveyTemplate.description %}
                <p class="text-sm text-gray-500">{{ surveyTemplate.description }}</p>
            {% endif %}
        </div>
        <div class="flex flex-col gap-2 sm:flex-row items-center">
            <a href="{{ path(campaignIndexRoute, {id: surveyTemplate.id}) }}" class="btn-outline-norsu inline-flex items-center justify-center">
                <i class="bi bi-envelope-paper mr-1"></i>Campaigns
            </a>
            <a href="{{ path(questionPreviewRoute, {id: surveyTemplate.id}) }}" class="btn-outline-norsu inline-flex items-center justify-center" data-view-whole-form target="_blank" rel="noopener">
                <i class="bi bi-eye mr-1"></i>View Whole Form
            </a>
            <a href="{{ path(questionNewRoute, {templateId: surveyTemplate.id}) }}" class="btn-norsu inline-flex items-center justify-center"><i class="bi bi-plus-lg mr-1"></i>Add Question</a>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-blue-200 bg-blue-50 shadow-sm">
        <div class="grid gap-6 p-5 lg:grid-cols-2">
            <div class="space-y-4">
                <div class="mb-2 inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-bold uppercase tracking-wide text-norsu">Form Workspace</div>
                <h2 class="text-xl font-bold text-gray-800">{{ surveyTemplate.title }}</h2>
                <p class="max-w-2xl text-sm text-gray-600">
                    Add questions below, organize them by section, and use <strong>View Whole Form</strong> to inspect the entire form exactly as alumni will see it.
                </p>

                <div class="flex flex-col gap-2 sm:flex-row items-center">
                    <a href="{{ path(questionPreviewRoute, {id: surveyTemplate.id}) }}" class="btn-outline-norsu inline-flex items-center justify-center" data-view-whole-form-inline target="_blank" rel="noopener">
                        <i class="bi bi-layout-text-window-reverse mr-1"></i>Open Complete Form Preview
                    </a>
                    {% if questions is empty %}
                        <form method="post" action="{{ path(questionImportRoute, {templateId: surveyTemplate.id}) }}" class="inline-flex">
                            <input type="hidden" name="_token" value="{{ csrf_token('import_gts_defaults') }}">
                            <button type="submit" class="btn-norsu inline-flex items-center justify-center"><i class="bi bi-download mr-1"></i>Create Form From Default Template</button>
                        </form>
                    {% endif %}
                </div>
            </div>

            <div class="flex h-full flex-col justify-between rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
                <div>
                    <div class="text-xs font-bold uppercase tracking-wide text-gray-500">Form Snapshot</div>
                    <div class="mt-4 grid md:grid-cols-2 gap-3 text-center">
                        <div class="rounded-xl bg-gray-50 px-3 py-4">
                            <div class="text-2xl font-bold text-gray-800">{{ sectionCount }}</div>
                            <div class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500">Sections</div>
                        </div>
                        <div class="rounded-xl bg-gray-50 px-3 py-4">
                            <div class="text-2xl font-bold text-gray-800">{{ questions|length }}</div>
                            <div class="mt-1 text-xs font-semibold uppercase tracking-wide text-gray-500">Questions</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
                    <strong>{{ activeQuestionCount }}</strong> active question{{ activeQuestionCount == 1 ? '' : 's' }} currently appear in the live form.
                </div>
            </div>
        </div>
    </div>

    {% if questionSections is not empty %}
        <div class="space-y-5">
            {% for section in questionSections %}
                <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
                    <div class="flex flex-col gap-3 border-b border-gray-100 bg-gray-50 px-6 py-4 md:flex-row md:items-center justify-between">
                        <div class="min-w-0 space-y-1">
                            <h3 class="text-lg font-bold text-gray-800">{{ section.title }}</h3>
                            <p class="text-xs uppercase tracking-wide text-gray-500">{{ section.questions|length }} question{{ section.questions|length == 1 ? '' : 's' }} in this section</p>
                        </div>
                        <a href="{{ path(questionPreviewRoute, {id: surveyTemplate.id}) }}" class="btn-outline-norsu btn-sm inline-flex items-center self-start" target="_blank" rel="noopener">
                            <i class="bi bi-eye mr-1"></i>Preview in Whole Form
                        </a>
                    </div>

                    <div class="divide-y divide-gray-100">
                        {% for question in section.questions %}
                            <div class="px-6 py-4 transition-colors hover:bg-gray-50">
                                <div class="flex flex-col gap-3 md:flex-row md:items-center justify-between">
                                    <div class="min-w-0 flex-1 space-y-3">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="inline-flex rounded-full bg-blue-100 px-2.5 py-1 text-xs font-semibold text-blue-700">{{ question.inputType }}</span>
                                            {% if question.isActive %}
                                                <span class="inline-flex rounded-full bg-green-100 px-2.5 py-1 text-xs font-semibold text-green-700">Active</span>
                                            {% else %}
                                                <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-600">Inactive</span>
                                            {% endif %}
                                            <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-600">Order {{ question.sortOrder }}</span>
                                        </div>
                                        <div class="text-base font-semibold text-gray-800">{{ question.questionText }}</div>
                                    </div>

                                    <div class="flex flex-wrap items-center gap-2">
                                        <a href="{{ path(questionEditRoute, {id: question.id}) }}" class="btn-outline-norsu btn-sm inline-flex items-center justify-center"><i class="bi bi-pencil mr-1"></i>Edit</a>
                                        <form method="post" action="{{ path(questionDeleteRoute, {id: question.id}) }}" class="inline-flex" onsubmit="return confirm('Delete this question?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_gts_question_' ~ question.id) }}">
                                            <button type="submit" class="btn-secondary btn-sm inline-flex items-center justify-center"><i class="bi bi-trash mr-1"></i>Delete</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="rounded-2xl border border-dashed border-gray-300 bg-white px-6 py-12 text-center shadow-sm">
            <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-gray-100 text-gray-500">
                <i class="bi bi-ui-checks-grid text-2xl"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-800">No questions yet</h3>
            <p class="mt-2 text-sm text-gray-500">Import the default template or add the first question manually.</p>
            <div class="mt-5 flex flex-col items-center justify-center gap-2 sm:flex-row">
                <form method="post" action="{{ path(questionImportRoute, {templateId: surveyTemplate.id}) }}" class="inline-flex">
                    <input type="hidden" name="_token" value="{{ csrf_token('import_gts_defaults') }}">
                    <button type="submit" class="btn-outline-norsu inline-flex items-center justify-center"><i class="bi bi-download mr-1"></i>Create Form From Default Template</button>
                </form>
                <a href="{{ path(questionNewRoute, {templateId: surveyTemplate.id}) }}" class="btn-norsu inline-flex items-center justify-center"><i class="bi bi-plus-lg mr-1"></i>Add First Question</a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
