{% extends 'base.html.twig' %}

{% block title %}Manage Departments - Admin{% endblock %}

{% block body %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 mb-4">
    <div>
        <h4 class="font-bold mb-0"><i class="bi bi-diagram-3 mr-2"></i>Departments</h4>
        <p class="text-gray-500 text-sm mb-0">Manage academic departments</p>
    </div>
    <a href="{{ path('admin_department_create') }}" class="btn-norsu">
        <i class="bi bi-plus-lg mr-1"></i>Add Department
    </a>
</div>

{# Filters #}
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
            <div class="md:col-span-6">
                <label class="form-label text-xs uppercase text-gray-500">Search</label>
                <input type="text" name="q" value="{{ search }}" class="form-input" placeholder="Department name or code…">
            </div>
            <div class="md:col-span-4">
                <label class="form-label text-xs uppercase text-gray-500">College</label>
                <select name="college" class="form-select">
                    <option value="">All Colleges</option>
                    {% for c in colleges %}
                        <option value="{{ c.id }}" {% if collegeFilter == c.id %}selected{% endif %}>{{ c.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="md:col-span-2">
                <button type="submit" class="btn-norsu w-full"><i class="bi bi-search mr-1"></i>Filter</button>
            </div>
        </form>
    </div>
</div>

{# Results Table #}
<div class="card">
    <div class="p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="pl-4 py-2.5 font-semibold text-left">Code</th>
                    <th class="py-2.5 font-semibold text-left">Department</th>
                    <th class="py-2.5 font-semibold text-left">College</th>
                    <th class="py-2.5 font-semibold text-left">Description</th>
                    <th class="py-2.5 font-semibold text-center">Status</th>
                    <th class="text-right pr-4 py-2.5 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for dept in departments %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-4 py-2.5 font-mono text-xs font-bold text-blue-700">{{ dept.code }}</td>
                    <td class="py-2.5 font-semibold">{{ dept.name }}</td>
                    <td class="py-2.5">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800">
                            {{ dept.college.code }}
                        </span>
                    </td>
                    <td class="py-2.5 text-gray-600">{{ dept.description ?? '—' }}</td>
                    <td class="py-2.5 text-center">
                        {% if dept.isIsActive %}
                            <span class="badge badge-success">Active</span>
                        {% else %}
                            <span class="badge badge-secondary">Inactive</span>
                        {% endif %}
                    </td>
                    <td class="text-right pr-4 py-2.5">
                        <div class="flex gap-1 justify-end">
                            <a href="{{ path('admin_department_edit', {id: dept.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit department">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_department_delete', {id: dept.id}) }}" class="inline"
                                  onsubmit="return confirm('Delete this department?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dept.id) }}">
                                <button type="submit" class="icon-action icon-action-delete icon-action-btn" title="Delete" aria-label="Delete department"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center text-gray-500 py-10">
                        <i class="bi bi-search text-2xl block mb-2 opacity-25"></i>
                        No departments found.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-sm text-gray-500">
    Showing {{ total }} department(s)
</div>
{% endblock %}
