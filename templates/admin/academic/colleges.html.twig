{% extends 'base.html.twig' %}

{% block title %}Manage Colleges - Admin{% endblock %}

{% block body %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 mb-4">
    <div>
        <h4 class="font-bold mb-0"><i class="bi bi-building mr-2"></i>Colleges</h4>
        <p class="text-gray-500 text-sm mb-0">Manage academic colleges</p>
    </div>
    <a href="{{ path('admin_college_create') }}" class="btn-norsu">
        <i class="bi bi-plus-lg mr-1"></i>Add College
    </a>
</div>

{# Search #}
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="flex gap-2">
            <input type="text" name="q" value="{{ search }}" class="form-input flex-1" placeholder="Search by name or code…">
            <button type="submit" class="btn-norsu"><i class="bi bi-search mr-1"></i>Search</button>
        </form>
    </div>
</div>

{# Results Table #}
<div class="card">
    <div class="p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="pl-4 py-2.5 font-semibold text-left">Code</th>
                    <th class="py-2.5 font-semibold text-left">Name</th>
                    <th class="py-2.5 font-semibold text-left">Description</th>
                    <th class="py-2.5 font-semibold text-center">Status</th>
                    <th class="text-right pr-4 py-2.5 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for college in colleges %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-4 py-2.5 font-mono text-xs font-bold text-blue-700">{{ college.code }}</td>
                    <td class="py-2.5 font-semibold">{{ college.name }}</td>
                    <td class="py-2.5 text-gray-600">{{ college.description ?? '—' }}</td>
                    <td class="py-2.5 text-center">
                        {% if college.isIsActive %}
                            <span class="badge badge-success">Active</span>
                        {% else %}
                            <span class="badge badge-secondary">Inactive</span>
                        {% endif %}
                    </td>
                    <td class="text-right pr-4 py-2.5">
                        <div class="flex gap-1 justify-end">
                            <a href="{{ path('admin_college_edit', {id: college.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit college">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_college_delete', {id: college.id}) }}" class="inline"
                                  onsubmit="return confirm('Delete this college?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ college.id) }}">
                                <button type="submit" class="icon-action icon-action-delete icon-action-btn" title="Delete" aria-label="Delete college"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="text-center text-gray-500 py-10">
                        <i class="bi bi-search text-2xl block mb-2 opacity-25"></i>
                        No colleges found.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-sm text-gray-500">
    Showing {{ total }} college(s)
</div>
{% endblock %}
