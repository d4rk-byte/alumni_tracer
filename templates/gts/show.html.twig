{% extends 'base.html.twig' %}

{% block title %}GTS Response — {{ survey.name }}{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">
    <div class="flex items-center gap-3 mb-5">
        <a href="{{ path('gts_index') }}" class="btn-secondary btn-sm no-print"><i class="bi bi-arrow-left mr-1"></i>Back</a>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_analytics_hub') }}" class="btn-outline-norsu btn-sm no-print"><i class="bi bi-grid-1x2-fill mr-1"></i>Analytics Hub</a>
        {% endif %}
        <h4 class="font-bold mb-0"><i class="bi bi-clipboard2-check mr-2"></i>GTS Response #{{ survey.id }}</h4>
        <span class="text-sm text-gray-400 ml-auto">{{ survey.createdAt|date('F d, Y g:ia') }}</span>
        <button onclick="window.print()" class="inline-flex items-center gap-1 bg-gray-600 hover:bg-gray-700 text-white text-sm font-semibold px-3 py-2 rounded-lg transition no-print">
            <i class="bi bi-printer"></i>Print
        </button>
    </div>

    {# ── Print-only header ── #}
    <div class="hidden print-header" style="display:none">
        <div style="text-align:center; margin-bottom:20px;">
            <h2 style="margin:0; font-size:18pt; font-weight:bold;">Negros Oriental State University</h2>
            <h3 style="margin:4px 0; font-size:14pt;">CHED Graduate Tracer Study</h3>
            <p style="margin:4px 0; font-size:10pt; color:#555;">Respondent: {{ survey.name }} | Printed on: {{ 'now'|date('F d, Y') }}</p>
            <hr style="margin-top:10px;">
        </div>
    </div>

    {# ── A. General Information ── #}
    <div class="card mb-5">
        <div class="card-header-norsu flex items-center gap-2"><i class="bi bi-person-vcard"></i> A. General Information</div>
        <div class="card-body">
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                <div><dt class="text-gray-500">Name</dt><dd class="font-semibold">{{ survey.name }}</dd></div>
                <div><dt class="text-gray-500">Email</dt><dd>{{ survey.emailAddress ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Permanent Address</dt><dd>{{ survey.permanentAddress ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Telephone / Contact</dt><dd>{{ survey.telephoneNumber ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Mobile</dt><dd>{{ survey.mobileNumber ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Civil Status</dt><dd>{{ survey.civilStatus ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Sex</dt><dd>{{ survey.sex ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Birthday</dt><dd>{{ survey.birthday ? survey.birthday|date('M d, Y') : '—' }}</dd></div>
                <div><dt class="text-gray-500">Region of Origin</dt><dd>{{ survey.regionOfOrigin ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Province</dt><dd>{{ survey.province ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Residence</dt><dd>{{ survey.locationOfResidence ?? '—' }}</dd></div>
            </dl>
        </div>
    </div>

    {# ── B. Educational Background ── #}
    <div class="card mb-5">
        <div class="card-header-norsu flex items-center gap-2"><i class="bi bi-mortarboard"></i> B. Educational Background</div>
        <div class="card-body space-y-4">
            {% if survey.educationalAttainment %}
            <div>
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-2">12. Educational Attainment</h6>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 text-xs uppercase text-gray-600"><tr>
                            <th class="px-3 py-2 text-left">Degree</th><th class="px-3 py-2 text-left">College</th>
                            <th class="px-3 py-2 text-left">Year</th><th class="px-3 py-2 text-left">Honors</th>
                        </tr></thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for row in survey.educationalAttainment %}
                            <tr><td class="px-3 py-2">{{ row.degree ?? '' }}</td><td class="px-3 py-2">{{ row.college ?? '' }}</td>
                            <td class="px-3 py-2">{{ row.yearGraduated ?? '' }}</td><td class="px-3 py-2">{{ row.honors ?? '' }}</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}

            {% if survey.professionalExams %}
            <div>
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-2">13. Professional Examinations</h6>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead class="bg-gray-50 text-xs uppercase text-gray-600"><tr>
                            <th class="px-3 py-2 text-left">Examination</th><th class="px-3 py-2 text-left">Date Taken</th>
                            <th class="px-3 py-2 text-left">Rating</th>
                        </tr></thead>
                        <tbody class="divide-y divide-gray-100">
                        {% for row in survey.professionalExams %}
                            <tr><td class="px-3 py-2">{{ row.name ?? '' }}</td><td class="px-3 py-2">{{ row.dateTaken ?? '' }}</td>
                            <td class="px-3 py-2">{{ row.rating ?? '' }}</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
            {% endif %}

            {% if survey.reasonsForCourseUndergrad %}
            <div>
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">14. Reasons (Undergraduate)</h6>
                <div class="flex flex-wrap gap-1.5">
                    {% for r in survey.reasonsForCourseUndergrad %}<span class="badge badge-info">{{ r }}</span>{% endfor %}
                </div>
            </div>
            {% endif %}
            {% if survey.reasonsForCourseGrad %}
            <div>
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">14. Reasons (Graduate)</h6>
                <div class="flex flex-wrap gap-1.5">
                    {% for r in survey.reasonsForCourseGrad %}<span class="badge badge-info">{{ r }}</span>{% endfor %}
                </div>
            </div>
            {% endif %}
            {% if survey.reasonsForCourseOther %}
            <p class="text-sm text-gray-600"><strong>Other:</strong> {{ survey.reasonsForCourseOther }}</p>
            {% endif %}
        </div>
    </div>

    {# ── C. Training ── #}
    <div class="card mb-5">
        <div class="card-header-norsu flex items-center gap-2"><i class="bi bi-journal-bookmark"></i> C. Training / Advance Studies</div>
        <div class="card-body space-y-4">
            {% if survey.trainings %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-xs uppercase text-gray-600"><tr>
                        <th class="px-3 py-2 text-left">Title</th><th class="px-3 py-2 text-left">Duration</th>
                        <th class="px-3 py-2 text-left">Institution</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-100">
                    {% for row in survey.trainings %}
                        <tr><td class="px-3 py-2">{{ row.title ?? '' }}</td><td class="px-3 py-2">{{ row.duration ?? '' }}</td>
                        <td class="px-3 py-2">{{ row.institution ?? '' }}</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="text-gray-500 text-sm">No trainings recorded.</p>
            {% endif %}

            {% if survey.reasonsAdvanceStudy %}
            <div>
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">15b. Reasons for Advance Studies</h6>
                <div class="flex flex-wrap gap-1.5">
                    {% for r in survey.reasonsAdvanceStudy %}<span class="badge badge-info">{{ r }}</span>{% endfor %}
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── D. Employment Data ── #}
    <div class="card mb-5">
        <div class="card-header-norsu flex items-center gap-2"><i class="bi bi-briefcase"></i> D. Employment Data</div>
        <div class="card-body">
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                <div><dt class="text-gray-500">Q16. Presently Employed</dt><dd class="font-semibold">{{ survey.presentlyEmployed ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q18. Employment Status</dt><dd>{{ survey.presentEmploymentStatus ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q19. Occupation</dt><dd>{{ survey.presentOccupation ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q20a. Company</dt><dd>{{ survey.companyNameAddress ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q20b. Line of Business</dt><dd>{{ survey.lineOfBusiness ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q21. Place of Work</dt><dd>{{ survey.placeOfWork ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q22. First Job After College</dt><dd>{{ survey.isFirstJobAfterCollege is not null ? (survey.isFirstJobAfterCollege ? 'Yes' : 'No') : '—' }}</dd></div>
                <div><dt class="text-gray-500">Q24. First Job Related to Course</dt><dd>{{ survey.firstJobRelatedToCourse is not null ? (survey.firstJobRelatedToCourse ? 'Yes' : 'No') : '—' }}</dd></div>
                <div><dt class="text-gray-500">Q27. Duration First Job</dt><dd>{{ survey.durationFirstJob ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q29. Time to Land First Job</dt><dd>{{ survey.timeToLandFirstJob ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q30.1 Job Level (First)</dt><dd>{{ survey.jobLevelFirstJob ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q30.2 Job Level (Current)</dt><dd>{{ survey.jobLevelCurrentJob ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q31. Initial Earning</dt><dd>{{ survey.initialMonthlyEarning ?? '—' }}</dd></div>
                <div><dt class="text-gray-500">Q32. Curriculum Relevant</dt><dd>{{ survey.curriculumRelevant is not null ? (survey.curriculumRelevant ? 'Yes' : 'No') : '—' }}</dd></div>
            </dl>

            {% if survey.reasonsNotEmployed %}
            <div class="mt-4">
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">Q17. Reasons Not Employed</h6>
                <div class="flex flex-wrap gap-1.5">{% for r in survey.reasonsNotEmployed %}<span class="badge badge-warning">{{ r }}</span>{% endfor %}</div>
            </div>
            {% endif %}

            {% if survey.reasonsForStaying %}
            <div class="mt-4">
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">Q23. Reasons for Staying</h6>
                <div class="flex flex-wrap gap-1.5">{% for r in survey.reasonsForStaying %}<span class="badge badge-info">{{ r }}</span>{% endfor %}</div>
            </div>
            {% endif %}

            {% if survey.howFoundFirstJob %}
            <div class="mt-4">
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">Q28. How Found First Job</h6>
                <div class="flex flex-wrap gap-1.5">{% for r in survey.howFoundFirstJob %}<span class="badge badge-info">{{ r }}</span>{% endfor %}</div>
            </div>
            {% endif %}

            {% if survey.competenciesUseful %}
            <div class="mt-4">
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">Q33. Competencies Useful</h6>
                <div class="flex flex-wrap gap-1.5">{% for r in survey.competenciesUseful %}<span class="badge badge-info">{{ r }}</span>{% endfor %}</div>
            </div>
            {% endif %}

            {% if survey.suggestions %}
            <div class="mt-4">
                <h6 class="text-xs font-bold uppercase text-gray-500 mb-1">Q34. Suggestions</h6>
                <p class="text-sm text-gray-700 bg-gray-50 rounded-lg p-3">{{ survey.suggestions }}</p>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
