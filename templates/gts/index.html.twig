{% extends 'base.html.twig' %}

{% block title %}GTS Responses{% endblock %}

{% block body %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 mb-4">
    <div>
        <h4 class="font-bold mb-0"><i class="bi bi-clipboard2-data mr-2"></i>Graduate Tracer Survey — Responses</h4>
        <p class="text-gray-500 text-sm mb-0">{{ totalItems }} total response(s)</p>
    </div>
    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_analytics_hub') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-grid-1x2-fill mr-1"></i>Analytics Hub</a>
    {% endif %}
</div>

<div class="card">
    <div class="p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="pl-4 py-2.5 font-semibold text-left">#</th>
                    <th class="py-2.5 font-semibold text-left">Name</th>
                    <th class="py-2.5 font-semibold text-left">Email</th>
                    <th class="py-2.5 font-semibold text-left">Contact Number</th>
                    <th class="py-2.5 font-semibold text-left">Occupation</th>
                    <th class="py-2.5 font-semibold text-left">Company Name</th>
                    <th class="py-2.5 font-semibold text-left">Company Address</th>
                    <th class="py-2.5 font-semibold text-left">Submitted</th>
                    <th class="text-right pr-4 py-2.5 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for row in surveyRows %}
                {% set s = row.survey %}
                {% set summary = row.summary %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-4 py-2.5 font-mono text-xs">{{ s.id }}</td>
                    <td class="py-2.5 font-semibold">{{ s.name }}</td>
                    <td class="py-2.5 text-gray-500">{{ s.emailAddress ?? '—' }}</td>
                    <td class="py-2.5">{{ summary.contactNumber ?: '—' }}</td>
                    <td class="py-2.5">{{ summary.occupation ?: '—' }}</td>
                    <td class="py-2.5">{{ summary.companyName ?: '—' }}</td>
                    <td class="py-2.5 text-gray-500">{{ summary.companyAddress ?: '—' }}</td>
                    <td class="py-2.5 text-gray-500 text-xs">{{ s.createdAt|date('M d, Y g:ia') }}</td>
                    <td class="text-right pr-4 py-2.5">
                        <a href="{{ path('gts_show', {id: s.id}) }}" class="icon-action icon-action-view" title="View" aria-label="View survey"><i class="bi bi-eye"></i></a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="9" class="text-center text-gray-500 py-10">
                        <i class="bi bi-clipboard2-x text-2xl block mb-2 opacity-25"></i>
                        No survey responses yet.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% include '_pagination.html.twig' with {currentPage: currentPage, totalPages: totalPages, route: 'gts_index'} %}
{% endblock %}
