{% extends 'base.html.twig' %}

{% block title %}Graduate Tracer Survey{% endblock %}

{% block body %}
{% set isPreviewMode = isPreviewMode|default(false) %}
<div class="max-w-5xl mx-auto">
    <div class="text-center mb-6">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-norsu-50 text-norsu mb-3">
            <i class="bi bi-clipboard2-check text-3xl"></i>
        </div>
        <h2 class="text-2xl font-bold text-gray-800">Graduate Tracer Survey (GTS)</h2>
    </div>

    {% if isPreviewMode %}
        <div class="mb-6 rounded-xl border-2 border-red-300 bg-red-50 px-4 py-3 text-sm font-semibold text-red-900">
            <i class="bi bi-shield-exclamation mr-2"></i>
            ADMIN PREVIEW MODE - This survey is not submittable.
        </div>
    {% endif %}

    <div class="mb-6 rounded-2xl border border-blue-200 bg-blue-50 px-8 py-6 md:px-10 text-sm leading-6 text-gray-700 shadow-sm">
        <p class="font-semibold text-gray-900">Dear Graduate:</p>
        <p class="mt-2">
            Good day! Please complete this GTS questionnaire as accurately and frankly as possible by checking (/)
            the box corresponding to your response.
        </p>
        <p class="mt-2">
            Your answer will be used for research purposes in order to assess graduate employability and eventually,
            improve course offerings to your alma mater and other universities/colleges in the Philippines.
        </p>
        <p class="mt-2">
            Your answers to this survey will be treated with strictest confidentiality.
        </p>
    </div>

    {{ form_start(form, {'attr': {'id': 'gtsForm', 'novalidate': 'novalidate'}}) }}

    <div class="grid gap-4 mb-5 md:grid-cols-2">
        <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3">
            <div class="flex flex-wrap items-center gap-2 text-sm">
                <span class="font-semibold text-blue-800">Institution Code:</span>
                <span class="inline-flex items-center rounded-full bg-blue-700 px-3 py-1 text-xs font-bold tracking-wide text-white">{{ institutionCode|default('NORSU-GTS') }}</span>
                <span class="text-blue-700">Control Code: <strong>{{ controlCode|default('Auto-generated') }}</strong></span>
            </div>
        </div>

        <div class="rounded-xl border border-gray-200 bg-white px-4 py-3 shadow-sm">
            <div class="text-xs font-bold uppercase tracking-wide text-gray-500">Respondent</div>
            <div class="mt-2 text-base font-semibold text-gray-900">{{ survey.name }}</div>
            <div class="text-sm text-gray-500">{{ survey.emailAddress ?: 'No email on file' }}</div>
            <p class="mt-3 text-xs text-gray-500">The questionnaire below is loaded from the Survey Builder. Edit the builder to change the live alumni form.</p>
        </div>
    </div>

    <fieldset {% if isPreviewMode %}disabled{% endif %} class="space-y-5">
        {% for section in questionSections|default([]) %}
            <div class="card mb-5">
                <div class="card-header-norsu flex items-center gap-2">
                    <i class="bi bi-ui-checks-grid text-lg"></i>
                    <span>{{ section.title }}</span>
                </div>
                <div class="card-body space-y-6">
                    {% for question in section.items %}
                        {% set answer = dynamicAnswers[question.key]|default(question.inputType in ['checkbox', 'repeater'] ? [] : '') %}
                        <div>
                            <label class="mb-2 block text-sm font-semibold text-gray-800">{{ question.questionText }}</label>
                            {% include 'gts/_question_input.html.twig' with {
                                question: question,
                                answer: answer,
                                isPreviewMode: isPreviewMode
                            } only %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% else %}
            <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
                No active survey questions are configured yet. Open the Survey Builder to import or create the questionnaire.
            </div>
        {% endfor %}
    </fieldset>

    <div class="flex justify-end gap-3 mb-8">
        <a href="{{ path('app_home') }}" class="btn-secondary"><i class="bi bi-x-lg mr-1"></i>Cancel</a>
        {% if isPreviewMode %}
            <a href="{{ path('app_dashboard') }}" class="btn-norsu text-base px-8 py-3">
                <i class="bi bi-box-arrow-left mr-1"></i>Exit Preview
            </a>
        {% elseif hasAlreadyResponded|default(false) %}
            <span class="inline-flex items-center rounded-lg bg-amber-50 text-amber-800 px-4 py-2 text-sm">
                <i class="bi bi-info-circle mr-2"></i>
                You have already completed this survey.
            </span>
        {% else %}
            <button type="submit" class="btn-norsu text-base px-8 py-3"><i class="bi bi-send mr-1"></i>Submit Survey</button>
        {% endif %}
    </div>

    {{ form_end(form) }}
</div>

<script>
const isPreviewMode = {{ isPreviewMode ? 'true' : 'false' }};

document.addEventListener('click', function (e) {
    if (isPreviewMode) {
        return;
    }

    const addButton = e.target.closest('[data-add-repeater-row]');
    if (addButton) {
        const key = addButton.getAttribute('data-add-repeater-row');
        if (!key) {
            return;
        }

        const container = document.querySelector(`[data-repeater-container="${key}"]`);
        const template = document.querySelector(`[data-repeater-template="${key}"]`);
        if (!container || !template) {
            return;
        }

        const nextIndex = Number(container.getAttribute('data-next-index') || '0');
        container.insertAdjacentHTML('beforeend', template.innerHTML.replace(/__name__/g, String(nextIndex)));
        container.setAttribute('data-next-index', String(nextIndex + 1));
        return;
    }

    const removeButton = e.target.closest('[data-remove-repeater-row]');
    if (removeButton) {
        const row = removeButton.closest('[data-repeater-row]');
        const container = removeButton.closest('[data-repeater-container]');
        if (!row) {
            return;
        }

        if (container && container.querySelectorAll('[data-repeater-row]').length > 1) {
            row.remove();
            return;
        }

        row.querySelectorAll('input, textarea, select').forEach((field) => {
            if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
                field.value = '';
                return;
            }

            if (field instanceof HTMLSelectElement) {
                field.selectedIndex = 0;
            }
        });
    }
});
</script>
{% endblock %}
