<div style="font-family: Arial, sans-serif; line-height: 1.5; color: #1f2937;">
    <p>Good day, {{ invitation.user.firstName }}.</p>

    <p>{{ campaign.emailBody|nl2br }}</p>

    <p>
        <a href="{{ invitationUrl }}" style="display: inline-block; background: #1d4ed8; color: #ffffff; text-decoration: none; padding: 10px 16px; border-radius: 6px; font-weight: 600;">
            Open Survey Invitation
        </a>
    </p>

    {% if invitation.expiresAt %}
        <p style="font-size: 13px; color: #6b7280;">
            This invitation expires on {{ invitation.expiresAt|date('M d, Y h:i A') }}.
        </p>
    {% endif %}

    <p style="font-size: 13px; color: #6b7280;">
        You need to sign in with your alumni account to answer the survey.
    </p>
</div>
