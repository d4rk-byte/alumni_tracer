{% extends 'home/landing_layout.html.twig' %}

{% block title %}Login — NORSU Alumni Tracker{% endblock %}

{% block page_content %}
<div class="bg-cream pb-12">
    <div class="max-w-screen-xl px-8 mx-auto pt-14">
        <div data-aos="fade-up" class="max-w-2xl mx-auto text-center mb-10">
            <h1 class="font-bold text-darken my-3 text-3xl">Welcome back to <span class="text-yellow-500">NORSU Alumni Tracker</span></h1>
            <p class="leading-relaxed text-gray-500">Sign in to access your alumni profile, announcements, tracer forms, and career opportunities.</p>
        </div>

        <section data-aos="fade-up" data-aos-delay="100" class="max-w-xl mx-auto bg-white shadow-xl rounded-xl p-8" aria-label="Login form">
            <div class="grid grid-cols-2 gap-2 bg-slate-100 rounded-xl p-1 mb-6" role="tablist" aria-label="Authentication options">
                <span class="text-center font-semibold text-gray-900 bg-white rounded-lg py-2" role="tab" aria-selected="true">Login</span>
                <a href="{{ path('app_register') }}" class="text-center font-semibold text-gray-600 rounded-lg py-2 no-underline hover:text-gray-900" role="tab" aria-selected="false">Sign Up</a>
            </div>

            {% if error %}
                <div class="rounded-lg border border-red-200 bg-red-50 text-red-700 px-4 py-3 text-sm mb-4">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% for message in app.flashes('success') %}
                <div class="rounded-lg border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-3 text-sm mb-4">
                    {{ message }}
                </div>
            {% endfor %}

            <form method="post" class="space-y-4">
                <div>
                    <label for="inputEmail" class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="inputEmail"
                           class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-300"
                           autocomplete="email"
                           placeholder="you@example.com"
                           required
                           autofocus>
                </div>

                <div>
                    <label for="inputPassword" class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
                    <input type="password"
                           name="_password"
                           id="inputPassword"
                           class="w-full rounded-xl border border-slate-300 bg-slate-50 px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-300"
                           autocomplete="current-password"
                           placeholder="Enter your password"
                           required>
                </div>

                <div class="flex items-center gap-2 text-sm text-gray-600">
                    <input type="checkbox" id="remember_me" name="_remember_me" value="on" class="h-4 w-4 rounded border-slate-300">
                    <label for="remember_me">Remember me</label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="w-full rounded-xl bg-gradient-to-r from-indigo-700 to-indigo-900 text-white font-semibold py-3" type="submit">Sign In</button>
            </form>

            <div class="flex items-center gap-3 text-slate-400 text-sm uppercase tracking-wide my-5">
                <span class="h-px bg-slate-200 flex-1"></span>
                <span>or</span>
                <span class="h-px bg-slate-200 flex-1"></span>
            </div>

            <a href="{{ path('app_google_start') }}" class="w-full inline-flex justify-center items-center rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-800 font-medium no-underline hover:bg-slate-50" title="Continue with Google">
                Continue with Google
            </a>

            <a href="{{ path('app_forgot_password') }}" class="block text-center mt-5 text-sm text-slate-600 no-underline hover:underline">Forgot your password?</a>
        </section>
    </div>
</div>
{% endblock %}
