{% extends 'home/landing_layout.html.twig' %}

{% block title %}Tracer Survey Insights — NORSU Alumni Tracker{% endblock %}

{% block page_content %}
<div class="bg-blue-50 pb-10">
    <div class="max-w-screen-xl px-8 mx-auto pt-14">
        <div data-aos="fade-up" class="max-w-3xl mx-auto text-center mb-10">
            <h1 class="font-bold text-darken my-3 text-3xl">Tracer Survey <span class="text-blue-600">Insights</span></h1>
            <p class="leading-relaxed text-gray-500">The Graduate Tracer Survey helps NORSU measure employment outcomes and improve programs based on real alumni data.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            <div data-aos="fade-up" class="bg-white shadow-xl p-8 rounded-xl">
                <h2 class="font-semibold text-darken text-2xl mb-4">Why It Matters</h2>
                <ul class="space-y-3 text-gray-500 list-disc pl-5">
                    <li>Tracks career outcomes of graduates over time</li>
                    <li>Identifies skills and curriculum alignment gaps</li>
                    <li>Supports accreditation and planning requirements</li>
                    <li>Guides student and alumni support initiatives</li>
                </ul>
            </div>
            <div data-aos="fade-up" data-aos-delay="140" class="bg-white shadow-xl p-8 rounded-xl">
                <h2 class="font-semibold text-darken text-2xl mb-4">How to Participate</h2>
                <p class="text-gray-500">Register your alumni account, complete your profile, and submit your tracer responses through the guided form when prompted.</p>
                <div class="mt-8 flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('app_register') }}" class="px-6 py-3 text-sm text-center bg-blue-600 text-white rounded-full no-underline">Register Now</a>
                    <a href="{{ path('app_faq') }}" class="px-6 py-3 text-sm text-center bg-white text-gray-800 border border-gray-300 rounded-full no-underline">Read FAQ</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
