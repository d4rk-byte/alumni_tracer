{% set eventStartAt = announcement.eventStartAt|default(null) %}
{% set eventDate = eventStartAt ? eventStartAt|date('M d, Y') : 'Date TBA' %}
{% set eventTime = eventStartAt ? eventStartAt|date('h:i A') : 'Time TBA' %}
{% set eventLocation = announcement.location|default(null) %}
{% set eventLocation = eventLocation ?: 'Location TBA' %}
{% set accent = accent|default('#2563eb') %}
{% set modalId = modal_id|default('announcement-modal-' ~ announcement.id) %}

<button type="button" onclick="document.getElementById('{{ modalId }}').showModal()" class="inline-flex items-center gap-1.5 text-sm font-semibold mt-auto bg-transparent border-0 p-0 cursor-pointer" style="color: {{ accent }};">
    View details
    <svg width="16" height="16" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" /></svg>
</button>

<dialog id="{{ modalId }}" class="w-[min(92vw,42rem)] rounded-xl border-0 p-0 shadow-[0_24px_70px_rgba(15,23,42,0.28)] backdrop:bg-slate-950/55">
    <div class="bg-white rounded-xl overflow-hidden">
        <div class="px-5 sm:px-6 py-5 border-b border-slate-100">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <span class="inline-flex items-center rounded-full text-[0.65rem] font-bold uppercase tracking-[0.12em] px-2.5 py-1 mb-3" style="background: {{ accent }}14; color: {{ accent }};">{{ announcement.category ?: 'Event' }}</span>
                    <h3 class="text-xl sm:text-2xl font-bold text-darken mb-0">{{ announcement.title }}</h3>
                </div>
                <form method="dialog">
                    <button class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 hover:bg-slate-50" aria-label="Close announcement details">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" /></svg>
                    </button>
                </form>
            </div>
        </div>

        <div class="px-5 sm:px-6 py-5 max-h-[68vh] overflow-y-auto">
            <div class="grid sm:grid-cols-3 gap-3 mb-5">
                <div class="rounded-lg bg-blue-50 border border-blue-100 px-3 py-3">
                    <p class="text-[0.68rem] uppercase tracking-[0.14em] text-blue-700 font-bold mb-1">Date</p>
                    <p class="text-sm font-semibold text-slate-800 mb-0">{{ eventDate }}</p>
                </div>
                <div class="rounded-lg bg-blue-50 border border-blue-100 px-3 py-3">
                    <p class="text-[0.68rem] uppercase tracking-[0.14em] text-blue-700 font-bold mb-1">Time</p>
                    <p class="text-sm font-semibold text-slate-800 mb-0">{{ eventTime }}</p>
                </div>
                <div class="rounded-lg bg-blue-50 border border-blue-100 px-3 py-3">
                    <p class="text-[0.68rem] uppercase tracking-[0.14em] text-blue-700 font-bold mb-1">Location</p>
                    <p class="text-sm font-semibold text-slate-800 mb-0">{{ eventLocation }}</p>
                </div>
            </div>

            <div class="text-sm sm:text-base leading-relaxed text-slate-600 whitespace-pre-line">{{ announcement.description }}</div>

            {% if announcement.postedBy %}
                <div class="mt-5 rounded-lg bg-slate-50 border border-slate-200 px-4 py-3">
                    <p class="text-[0.68rem] uppercase tracking-[0.14em] text-slate-500 font-bold mb-1">Posted By</p>
                    <p class="text-sm font-semibold text-slate-800 mb-0">{{ announcement.postedBy.fullName }}</p>
                </div>
            {% endif %}

            {% if announcement.joinUrl %}
                <div class="mt-5">
                    <a href="{{ announcement.joinUrl }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full px-5 py-2.5 text-sm font-semibold text-white no-underline" style="background: {{ accent }};">
                        Open link
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</dialog>
