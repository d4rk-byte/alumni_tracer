{% extends 'home/landing_layout.html.twig' %}

{% block title %}Contact Us — NORSU Alumni Tracker{% endblock %}

{% block page_content %}
<div class="bg-blue-50 pb-10">
    <div class="max-w-screen-xl px-8 mx-auto pt-14">
        <div data-aos="fade-up" class="max-w-3xl mx-auto text-center mb-10">
            <h1 class="font-bold text-darken my-3 text-3xl">Contact <span class="text-blue-600">NORSU Alumni Tracker</span></h1>
            <p class="leading-relaxed text-gray-500">Reach the support team for account concerns, verification, tracer survey help, and platform-related inquiries.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 mt-8">
            <div data-aos="fade-up" class="bg-white shadow-xl p-8 rounded-xl">
                <h2 class="font-semibold text-darken text-2xl mb-4">Office Information</h2>
                <div class="space-y-3 text-gray-500">
                    <p><span class="font-semibold text-gray-700">Office:</span> Alumni Affairs and Linkages Office</p>
                    <p><span class="font-semibold text-gray-700">University:</span> Negros Oriental State University</p>
                    <p><span class="font-semibold text-gray-700">Address:</span> Dumaguete City, Negros Oriental, Philippines</p>
                    <p><span class="font-semibold text-gray-700">Email:</span> alumni@norsu.edu.ph</p>
                    <p><span class="font-semibold text-gray-700">Phone:</span> +63 (35) 000-0000</p>
                </div>
            </div>

            <div data-aos="fade-up" data-aos-delay="150" class="bg-white shadow-xl p-8 rounded-xl">
                <h2 class="font-semibold text-darken text-2xl mb-4">Support Hours</h2>
                <div class="space-y-3 text-gray-500">
                    <p><span class="font-semibold text-gray-700">Monday to Friday:</span> 8:00 AM - 5:00 PM</p>
                    <p><span class="font-semibold text-gray-700">Saturday:</span> 8:00 AM - 12:00 PM</p>
                    <p><span class="font-semibold text-gray-700">Sunday / Holidays:</span> Closed</p>
                </div>
                <p class="mt-6 text-gray-500">For urgent account concerns, include your full name and registered email when contacting support.</p>
                <div class="mt-8 flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('app_register') }}" class="px-6 py-3 text-sm text-center bg-blue-600 text-white rounded-full no-underline">Create Account</a>
                    <a href="{{ path('app_faq') }}" class="px-6 py-3 text-sm text-center bg-white text-gray-800 border border-gray-300 rounded-full no-underline">Read FAQ</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
