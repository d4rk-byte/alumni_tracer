{% extends 'home/landing_layout.html.twig' %}

{% set featureKey = featureKey|default('generic') %}
{% set featurePills = pagePills|default([]) %}
{% set featureCards = pageCards|default([]) %}
{% set announcementFeed = announcementFeed|default([]) %}
{% set jobFeed = jobFeed|default([]) %}
{% set jobPreviewImages = [
    asset('skilline/img/laptop-news.png'),
    asset('skilline/img/children-laptop.png'),
    asset('skilline/img/girl-laptop.png')
] %}
{% set latestSurvey = latestSurvey|default(null) %}
{% set linkedAlumni = alumni|default(null) %}
{% set tracerCampaign = tracerCampaignSnapshot|default({
    hasInvitation: false,
    hasCampaign: false,
    campaignName: hasGtsSurvey ? 'Direct tracer response' : 'No tracer campaign yet',
    campaignStatusLabel: 'No campaign',
    invitationStatusLabel: hasGtsSurvey ? 'Completed' : 'No invitation',
    statusSummary: hasGtsSurvey ? 'Your latest tracer response is on file.' : 'No tracer invitation campaign is currently assigned to this account.',
    timelineLabel: profileSnapshot.lastTracerSubmissionAt ? 'Latest Response' : 'Tracer Timeline',
    timelineValue: profileSnapshot.lastTracerSubmissionAt ? profileSnapshot.lastTracerSubmissionAt|date('M d, Y') : (hasGtsSurvey ? 'Response on file' : 'No activity yet'),
    windowValue: hasGtsSurvey ? 'Completed' : 'Not scheduled',
    audienceSummary: hasGtsSurvey ? 'Direct tracer submission' : 'No audience configured'
}) %}
{% set featureAccent = '#2563eb' %}
{% set featureAccentStrong = '#1d4ed8' %}
{% set featureAccentSoft = 'rgba(37, 99, 235, 0.12)' %}
{% set featureAccentBorder = 'rgba(147, 197, 253, 0.48)' %}
{% set featureHeroBackground = 'linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(239,246,255,0.95) 55%, rgba(219,234,254,0.88) 100%)' %}
{% set featurePageBackground = 'linear-gradient(180deg, #e8f0fb 0%, #eef4ff 100%)' %}
{% set featureSpotlightEyebrow = 'Landing Focus' %}
{% set featureSpotlightTitle = 'Feature page overview' %}
{% set featureSpotlightBody = 'This page keeps alumni content inside the landing experience with a clearer feature-specific layout.' %}
{% set featureSpotlightTags = ['Landing-only view', 'Alumni self-service'] %}

{% if featureKey == 'announcements' %}
    {% set featureAccent = '#2563eb' %}
    {% set featureAccentStrong = '#1e40af' %}
    {% set featureAccentSoft = 'rgba(37, 99, 235, 0.12)' %}
    {% set featureAccentBorder = 'rgba(147, 197, 253, 0.52)' %}
    {% set featureHeroBackground = 'linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(239,246,255,0.95) 52%, rgba(219,234,254,0.9) 100%)' %}
    {% set featurePageBackground = 'linear-gradient(180deg, #edf4ff 0%, #e8f0fb 100%)' %}
    {% set featureSpotlightEyebrow = 'Notice Focus' %}
    {% set featureSpotlightTitle = announcementFeed|length > 0 ? 'Published alumni notices are ready' : 'Waiting for the next office notice' %}
    {% set featureSpotlightBody = announcementFeed|length > 0 ? 'This page emphasizes updates, categories, and posting context so announcements feel like a real notice desk.' : 'The layout is ready for advisories, reminders, and event posts as soon as active announcements are published.' %}
    {% set featureSpotlightTags = ['Office updates', 'Event reminders'] %}
{% elseif featureKey == 'jobs' %}
    {% set featureAccent = '#d97706' %}
    {% set featureAccentStrong = '#b45309' %}
    {% set featureAccentSoft = 'rgba(245, 158, 11, 0.14)' %}
    {% set featureAccentBorder = 'rgba(251, 191, 36, 0.5)' %}
    {% set featureHeroBackground = 'linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(255,251,235,0.96) 56%, rgba(254,243,199,0.88) 100%)' %}
    {% set featurePageBackground = 'linear-gradient(180deg, #fff8eb 0%, #fdf2d9 100%)' %}
    {% set featureSpotlightEyebrow = 'Career Focus' %}
    {% set featureSpotlightTitle = jobFeed|length > 0 ? 'Opportunity details lead this page' : 'Waiting for the next hiring cycle' %}
    {% set featureSpotlightBody = jobFeed|length > 0 ? 'Jobs get a warmer, action-oriented layout that highlights role fit, salary, deadlines, and employer context.' : 'When jobs are available, this page will focus on openings, deadlines, and alumni-ready role details.' %}
    {% set featureSpotlightTags = ['Career board', 'Hiring windows'] %}
{% elseif featureKey == 'tracer' %}
    {% set featureAccent = '#0f766e' %}
    {% set featureAccentStrong = '#115e59' %}
    {% set featureAccentSoft = 'rgba(20, 184, 166, 0.14)' %}
    {% set featureAccentBorder = 'rgba(94, 234, 212, 0.45)' %}
    {% set featureHeroBackground = 'linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(240,253,250,0.96) 54%, rgba(204,251,241,0.88) 100%)' %}
    {% set featurePageBackground = 'linear-gradient(180deg, #ecfffb 0%, #e1f7f2 100%)' %}
    {% set featureSpotlightEyebrow = 'Response Focus' %}
    {% set featureSpotlightTitle = hasGtsSurvey ? 'Your latest tracer status is on file' : 'Your tracer status still needs action' %}
    {% set featureSpotlightBody = hasGtsSurvey ? 'Tracer uses a monitoring-style layout so response status and employment summary read differently from announcements or jobs.' : 'This page is designed like a readiness checkpoint, keeping survey status and next steps more explicit than the other features.' %}
    {% set featureSpotlightTags = ['Survey state', 'Employment summary'] %}
{% elseif featureKey == 'profile' %}
    {% set featureAccent = '#4f46e5' %}
    {% set featureAccentStrong = '#3730a3' %}
    {% set featureAccentSoft = 'rgba(99, 102, 241, 0.14)' %}
    {% set featureAccentBorder = 'rgba(165, 180, 252, 0.48)' %}
    {% set featureHeroBackground = 'linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(238,242,255,0.96) 54%, rgba(224,231,255,0.9) 100%)' %}
    {% set featurePageBackground = 'linear-gradient(180deg, #eef2ff 0%, #e6ebfb 100%)' %}
    {% set featureSpotlightEyebrow = 'Record Focus' %}
    {% set featureSpotlightTitle = linkedAlumni ? 'Your account and alumni record are paired' : 'Your account is waiting for a linked alumni record' %}
    {% set featureSpotlightBody = linkedAlumni ? 'Profile uses a more identity-driven layout so academic, account, and employment details feel different from the operational pages.' : 'This page emphasizes identity and record completeness, which should feel more personal than the jobs or tracer views.' %}
    {% set featureSpotlightTags = ['Account details', 'Alumni record'] %}
{% endif %}

{% block title %}{{ pageTitle }} | NORSU Alumni Tracker{% endblock %}

{% block page_content %}
<div class="pb-12 sm:pb-16" style="background: {{ featurePageBackground }};">
    <div class="max-w-screen-xl px-5 sm:px-8 mx-auto pt-10 sm:pt-14">
        <div class="max-w-7xl mx-auto">
            {% if featureKey == 'announcements' %}
                {% set latestAnnouncement = announcementFeed|first %}
                <section data-aos="fade-up" data-alumni-feature-hero="announcements" class="rounded-[2rem] px-5 sm:px-8 py-6 sm:py-8 shadow-[0_22px_48px_rgba(15,23,42,0.08)]" style="background: {{ featureHeroBackground }}; border: 1px solid {{ featureAccentBorder }};">
                    <div class="grid lg:grid-cols-2 gap-5 sm:gap-6 items-start">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.24em] uppercase mb-3" style="color: {{ featureAccentStrong }};">{{ pageEyebrow }}</p>
                            <h1 class="text-3xl sm:text-4xl font-bold text-darken leading-tight">{{ pageTitle }}</h1>
                            <p class="mt-4 text-sm sm:text-base leading-relaxed text-gray-500 max-w-3xl">{{ pageDescription }}</p>

                            <div class="mt-6 grid sm:grid-cols-3 gap-3">
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Active Notices</p>
                                    <p class="text-xl font-bold text-darken mb-0">{{ announcementFeed|length }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Latest Category</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ latestAnnouncement ? (latestAnnouncement.category ?: 'General Notice') : 'Office updates' }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Latest Posted</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ latestAnnouncement ? latestAnnouncement.datePosted|date('M d, Y') : 'Waiting for next post' }}</p>
                                </div>
                            </div>

                            <div class="mt-6 flex flex-col sm:flex-row gap-3">
                                <a href="{{ primaryAction.href }}" class="inline-flex items-center justify-center rounded-full text-white font-semibold px-6 py-3 no-underline shadow-sm" style="background: {{ featureAccent }}; box-shadow: 0 14px 30px {{ featureAccentSoft }};">{{ primaryAction.label }}</a>
                                <a href="{{ secondaryAction.href }}" class="inline-flex items-center justify-center rounded-full font-semibold px-6 py-3 no-underline border" style="background: rgba(255, 255, 255, 0.82); color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ secondaryAction.label }}</a>
                            </div>

                            <p class="mt-4 text-sm text-gray-500">{{ pageModuleHint }}</p>
                        </div>

                        <article class="rounded-[1.6rem] px-5 py-5 shadow-sm" style="background: rgba(255, 255, 255, 0.82); border: 1px solid {{ featureAccentBorder }};">
                            <p class="text-[0.68rem] font-bold tracking-[0.22em] uppercase mb-2" style="color: {{ featureAccentStrong }};">Latest Notice Snapshot</p>
                            <h2 class="text-xl font-bold text-darken mb-2">{{ latestAnnouncement ? latestAnnouncement.title : 'No active notices published yet' }}</h2>
                            <p class="text-sm leading-relaxed text-gray-500 mb-4">{{ latestAnnouncement ? (latestAnnouncement.description|length > 150 ? latestAnnouncement.description|slice(0, 150) ~ '…' : latestAnnouncement.description) : 'This top section stays focused on notice activity, posting context, and what alumni should expect next.' }}</p>
                            <div class="grid gap-3 text-sm">
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Audience</p>
                                    <p class="font-semibold text-darken mb-0">Active alumni readers</p>
                                </div>
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Focus</p>
                                    <p class="font-semibold text-darken mb-0">Office advisories, reminders, and event posts</p>
                                </div>
                            </div>
                        </article>
                    </div>
                </section>
            {% elseif featureKey == 'jobs' %}
                {% set latestJob = jobFeed|first %}
                <section data-aos="fade-up" data-alumni-feature-hero="jobs" class="rounded-[2rem] px-5 sm:px-8 py-6 sm:py-8 shadow-[0_22px_48px_rgba(15,23,42,0.08)]" style="background: {{ featureHeroBackground }}; border: 1px solid {{ featureAccentBorder }};">
                    <div class="grid lg:grid-cols-2 gap-5 sm:gap-6 items-start">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.24em] uppercase mb-3" style="color: {{ featureAccentStrong }};">{{ pageEyebrow }}</p>
                            <h1 class="text-3xl sm:text-4xl font-bold text-darken leading-tight">{{ pageTitle }}</h1>
                            <p class="mt-4 text-sm sm:text-base leading-relaxed text-gray-500 max-w-3xl">{{ pageDescription }}</p>

                            <div class="mt-6 flex flex-wrap gap-2.5">
                                <span class="px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border" style="background: {{ featureAccentSoft }}; color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ jobFeed|length }} active opportunities</span>
                                <span class="px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border" style="background: {{ featureAccentSoft }}; color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ latestJob ? (latestJob.relatedCourse ?: 'Multiple programs') : 'Career-ready roles' }}</span>
                                <span class="px-3.5 py-2 rounded-full text-xs sm:text-sm font-semibold border" style="background: {{ featureAccentSoft }}; color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ hasGtsSurvey ? 'Tracer already on file' : 'Tracer still pending' }}</span>
                            </div>

                            <div class="mt-6 grid sm:grid-cols-2 gap-3">
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Latest Employer</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ latestJob ? latestJob.companyName : 'Waiting for new postings' }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Hiring Window</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ latestJob and latestJob.deadline ? latestJob.deadline|date('M d, Y') : 'Open until filled' }}</p>
                                </div>
                            </div>

                            <div class="mt-6 flex flex-col sm:flex-row gap-3">
                                <a href="{{ primaryAction.href }}" class="inline-flex items-center justify-center rounded-full text-white font-semibold px-6 py-3 no-underline shadow-sm" style="background: {{ featureAccent }}; box-shadow: 0 14px 30px {{ featureAccentSoft }};">{{ primaryAction.label }}</a>
                                <a href="{{ secondaryAction.href }}" class="inline-flex items-center justify-center rounded-full font-semibold px-6 py-3 no-underline border" style="background: rgba(255, 255, 255, 0.82); color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ secondaryAction.label }}</a>
                            </div>

                            <p class="mt-4 text-sm text-gray-500">{{ pageModuleHint }}</p>
                        </div>

                        <article class="rounded-[1.6rem] overflow-hidden px-4 sm:px-5 py-4 sm:py-5 shadow-sm" style="background: rgba(255, 255, 255, 0.82); border: 1px solid {{ featureAccentBorder }};">
                            <div class="rounded-[1.1rem] overflow-hidden border border-white/80 bg-white/80 mb-4">
                                <img
                                    src="{{ latestJob and latestJob.imageFilename ? asset('uploads/job_postings/' ~ latestJob.imageFilename) : jobPreviewImages[0] }}"
                                    alt="{{ latestJob and latestJob.imageFilename ? latestJob.title ~ ' image' : 'Job opportunity preview' }}"
                                    class="w-full h-36 sm:h-40 object-cover"
                                    loading="lazy"
                                >
                            </div>
                            <p class="text-[0.68rem] font-bold tracking-[0.22em] uppercase mb-2" style="color: {{ featureAccentStrong }};">Opportunity Snapshot</p>
                            <h2 class="text-lg sm:text-xl font-bold text-darken mb-2">{{ latestJob ? latestJob.title : 'No current opportunity highlight' }}</h2>
                            <p class="text-sm leading-relaxed text-gray-500 mb-3">{{ latestJob ? (latestJob.companyName ~ (latestJob.location ? ' • ' ~ latestJob.location : '')) : 'This top section is focused on role fit, employer context, and hiring windows instead of generic feature text.' }}</p>
                            <div class="grid gap-3 text-sm">
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-2.5">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Salary Range</p>
                                    <p class="font-semibold text-darken mb-0">{{ latestJob ? (latestJob.salaryRange ?: 'Discuss during hiring') : 'Will appear once jobs are posted' }}</p>
                                </div>
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-2.5">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Career Fit</p>
                                    <p class="font-semibold text-darken mb-0">{{ latestJob ? (latestJob.relatedCourse ?: 'Open to multiple programs') : 'Waiting for role alignment data' }}</p>
                                </div>
                            </div>
                        </article>
                    </div>
                </section>
            {% elseif featureKey == 'tracer' %}
                <section data-aos="fade-up" data-alumni-feature-hero="tracer" class="rounded-[2rem] px-5 sm:px-8 py-6 sm:py-8 shadow-[0_22px_48px_rgba(15,23,42,0.08)]" style="background: {{ featureHeroBackground }}; border: 1px solid {{ featureAccentBorder }};">
                    <div class="grid lg:grid-cols-2 gap-5 sm:gap-6 items-start">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.24em] uppercase mb-3" style="color: {{ featureAccentStrong }};">{{ pageEyebrow }}</p>
                            <h1 class="text-3xl sm:text-4xl font-bold text-darken leading-tight">{{ pageTitle }}</h1>
                            <p class="mt-4 text-sm sm:text-base leading-relaxed text-gray-500 max-w-3xl">{{ pageDescription }}</p>

                            <div class="mt-6 grid sm:grid-cols-3 gap-3">
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Invitation Status</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ tracerCampaign.invitationStatusLabel }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Campaign Status</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ tracerCampaign.campaignStatusLabel }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Profile Readiness</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ profileSnapshot.completionPercent|default(0) }}% complete</p>
                                </div>
                            </div>

                            <div class="mt-6 flex flex-col sm:flex-row gap-3">
                                <a href="{{ primaryAction.href }}" class="inline-flex items-center justify-center rounded-full text-white font-semibold px-6 py-3 no-underline shadow-sm" style="background: {{ featureAccent }}; box-shadow: 0 14px 30px {{ featureAccentSoft }};">{{ primaryAction.label }}</a>
                                <a href="{{ secondaryAction.href }}" class="inline-flex items-center justify-center rounded-full font-semibold px-6 py-3 no-underline border" style="background: rgba(255, 255, 255, 0.82); color: {{ featureAccentStrong }}; border-color: {{ featureAccentBorder }};">{{ secondaryAction.label }}</a>
                            </div>

                            <p class="mt-4 text-sm text-gray-500">{{ pageModuleHint }}</p>
                        </div>

                        <article class="rounded-[1.6rem] px-5 py-5 shadow-sm" style="background: rgba(255, 255, 255, 0.82); border: 1px solid {{ featureAccentBorder }};">
                            <p class="text-[0.68rem] font-bold tracking-[0.22em] uppercase mb-2" style="color: {{ featureAccentStrong }};">Tracer Snapshot</p>
                            <h2 class="text-xl font-bold text-darken mb-2">{{ tracerCampaign.campaignName }}</h2>
                            <p class="text-sm leading-relaxed text-gray-500 mb-4">{{ tracerCampaign.statusSummary }}</p>
                            <div class="grid gap-3 text-sm">
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Timeline</p>
                                    <p class="font-semibold text-darken mb-0">{{ tracerCampaign.timelineLabel }} • {{ tracerCampaign.timelineValue }}</p>
                                </div>
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Invitation Window</p>
                                    <p class="font-semibold text-darken mb-0">{{ tracerCampaign.windowValue }}</p>
                                </div>
                                <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Audience</p>
                                    <p class="font-semibold text-darken mb-0">{{ tracerCampaign.audienceSummary }}</p>
                                </div>
                            </div>
                        </article>
                    </div>
                </section>
            {% elseif featureKey == 'profile' %}
                <section data-aos="fade-up" data-alumni-feature-hero="profile" class="rounded-[2rem] px-5 sm:px-8 py-6 sm:py-8 shadow-[0_22px_48px_rgba(15,23,42,0.08)]" style="background: {{ featureHeroBackground }}; border: 1px solid {{ featureAccentBorder }};">
                    <div class="grid lg:grid-cols-2 gap-5 sm:gap-6 items-start">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.24em] uppercase mb-3" style="color: {{ featureAccentStrong }};">{{ pageEyebrow }}</p>
                            <h1 class="text-3xl sm:text-4xl font-bold text-darken leading-tight">{{ pageTitle }}</h1>
                            <p class="mt-4 text-sm sm:text-base leading-relaxed text-gray-500 max-w-3xl">{{ pageDescription }}</p>

                            <div class="mt-6 flex items-center gap-4 rounded-[1.6rem] px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                {% if app.user.profileImage %}
                                    <img src="{{ asset('uploads/profile/' ~ app.user.profileImage) }}" alt="{{ app.user.fullName }} profile photo" class="h-16 w-16 rounded-full object-cover border shadow-sm" style="border-color: {{ featureAccentBorder }};">
                                {% else %}
                                    <div class="inline-flex h-16 w-16 items-center justify-center rounded-full text-white text-xl font-bold shadow-sm" style="background: linear-gradient(135deg, {{ featureAccent }} 0%, {{ featureAccentStrong }} 100%);">
                                        {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                                    </div>
                                {% endif %}
                                <div>
                                    <h2 class="text-xl font-bold text-darken mb-1">{{ app.user.fullName }}</h2>
                                    <p class="text-sm text-gray-500 mb-0">{{ app.user.email }}</p>
                                </div>
                            </div>

                            <div class="mt-4 grid sm:grid-cols-3 gap-3">
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Completion</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ profileSnapshot.completionPercent|default(0) }}% complete</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Account</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ profileSnapshot.accountStatus }}</p>
                                </div>
                                <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid {{ featureAccentBorder }};">
                                    <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: {{ featureAccentStrong }};">Linked Record</p>
                                    <p class="text-sm font-semibold text-darken mb-0">{{ linkedAlumni ? 'Connected' : 'Needs attention' }}</p>
                                </div>
                            </div>

                            <div class="mt-6 flex flex-col sm:flex-row gap-3">
