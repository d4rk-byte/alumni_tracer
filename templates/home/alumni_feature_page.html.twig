                                </div>
                            {% else %}
                                <div class="rounded-2xl bg-slate-50 border border-dashed border-slate-300 px-5 py-8 text-center text-gray-500">
                                    <p class="text-base font-semibold text-darken mb-2">No linked alumni record yet</p>
                                    <p class="mb-0">Once your alumni record is linked, your academic and employment profile details will appear here.</p>
                                </div>
                            {% endif %}
                        </article>
                    </div>
                </section>
            {% else %}
                <section class="mt-6 grid md:grid-cols-3 gap-4 sm:gap-5">
                    {% for card in featureCards %}
                        <article data-aos="fade-up" data-aos-delay="{{ loop.index0 * 90 }}" class="rounded-[1.45rem] sm:rounded-[1.7rem] bg-white border border-blue-100 px-5 py-5 shadow-[0_18px_36px_rgba(15,23,42,0.07)]">
                            <p class="text-[0.68rem] font-bold tracking-[0.22em] text-blue-700 uppercase mb-2">{{ card.eyebrow }}</p>
                            <h2 class="text-lg sm:text-xl font-bold text-darken mb-2">{{ card.title }}</h2>
                            <p class="text-sm text-gray-500 leading-relaxed mb-0">{{ card.body }}</p>
                        </article>
                    {% endfor %}
                </section>
            {% endif %}

            {% if featureKey in ['tracer', 'profile', 'generic'] %}
                <section class="mt-6 grid lg:grid-cols-2 gap-4 sm:gap-5">
                    <article data-aos="fade-up" class="rounded-[1.6rem] sm:rounded-[1.9rem] bg-white border border-blue-100 px-5 sm:px-6 py-5 sm:py-6 shadow-[0_18px_36px_rgba(15,23,42,0.07)]">
                        <p class="text-[0.68rem] font-bold tracking-[0.22em] text-blue-700 uppercase mb-2">Account Snapshot</p>
                        <h3 class="text-xl sm:text-2xl font-bold text-darken mb-3">{{ profileSnapshot.completionPercent|default(0) }}% profile completion</h3>
                        <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                            <div class="h-full rounded-full bg-gradient-to-r from-blue-500 to-sky-400" style="width: {{ profileSnapshot.completionPercent|default(0) }}%"></div>
                        </div>

                        <div class="grid sm:grid-cols-2 gap-3 mt-5">
                            <div class="rounded-2xl bg-slate-50 border border-slate-200 px-4 py-4">
                                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500 mb-2">Account</p>
                                <p class="text-sm font-semibold text-darken mb-1">{{ profileSnapshot.accountStatus|default('Pending') }}</p>
                                <p class="text-xs text-gray-500 mb-0">Current alumni account standing inside the platform.</p>
                            </div>
                            <div class="rounded-2xl bg-slate-50 border border-slate-200 px-4 py-4">
                                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500 mb-2">Tracer</p>
                                <p class="text-sm font-semibold text-darken mb-1">{{ profileSnapshot.tracerStatus|default('Pending') }}</p>
                                <p class="text-xs text-gray-500 mb-0">Latest tracer participation status tied to your alumni account.</p>
                            </div>
                        </div>
                    </article>

                    <article data-aos="fade-up" data-aos-delay="80" class="rounded-[1.6rem] sm:rounded-[1.9rem] px-5 sm:px-6 py-5 sm:py-6" style="background: #2563eb; border: 1px solid rgba(191, 219, 254, 0.45); box-shadow: 0 24px 52px rgba(37, 99, 235, 0.22);">
                        <p class="text-[0.68rem] font-bold tracking-[0.22em] uppercase mb-2" style="color: rgba(255, 255, 255, 0.78);">Next Move</p>
                        <h3 class="text-xl sm:text-2xl font-bold mb-3" style="color: #ffffff;">{{ nextStep.title }}</h3>
                        <p class="text-sm leading-relaxed mb-5" style="color: rgba(255, 255, 255, 0.86);">{{ nextStep.body }}</p>
                        <div class="flex flex-col sm:flex-row gap-3">
                            <a href="{{ primaryAction.href }}" class="inline-flex items-center justify-center rounded-full font-semibold px-5 py-3 no-underline" style="background: #ffffff; color: #2563eb; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.14);">{{ primaryAction.label }}</a>
                            <a href="{{ secondaryAction.href }}" class="inline-flex items-center justify-center rounded-full font-semibold px-5 py-3 no-underline" style="border: 1px solid rgba(255, 255, 255, 0.32); color: #ffffff; background: rgba(255, 255, 255, 0.08);">{{ secondaryAction.label }}</a>
                        </div>
                    </article>
                </section>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}