{% extends 'home/landing_layout.html.twig' %}

{% set linkedAlumni = alumni|default(null) %}
{% set accountStatusLabel = profileSnapshot.accountStatus|default(user.accountStatus|capitalize) %}

{% block title %}Edit My Profile | NORSU Alumni Tracker{% endblock %}

{% block page_content %}
<style>
    .alumni-edit-field {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .alumni-edit-label {
        display: block;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #334155;
    }

    .alumni-edit-label-note {
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: normal;
        text-transform: none;
        color: #64748b;
    }

    .alumni-edit-input {
        width: 100%;
        min-width: 0;
        border-radius: 1rem;
        border: 1px solid #cbd5e1;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        padding: 0.95rem 1rem;
        font-size: 0.98rem;
        line-height: 1.45;
        color: #0f172a;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
        transition: border-color 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
    }

    .alumni-edit-input::placeholder {
        color: #94a3b8;
    }

    .alumni-edit-input:focus {
        outline: none;
        border-color: #818cf8;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.16);
    }

    .alumni-edit-field-card {
        border-radius: 1.15rem;
        border: 1px solid rgba(224, 231, 255, 0.95);
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
        padding: 1rem;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
    }

    .alumni-edit-side-panel {
        border-radius: 1.35rem;
        border: 1px solid #dbe4ff;
        background: linear-gradient(180deg, #f8faff 0%, #eef2ff 100%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92);
    }

    .alumni-edit-file-input {
        width: 100%;
        border-radius: 1rem;
        border: 1px dashed #a5b4fc;
        background: rgba(255, 255, 255, 0.9);
        padding: 0.75rem;
        color: #475569;
    }

    .alumni-edit-file-input::file-selector-button {
        margin-right: 0.8rem;
        border: 0;
        border-radius: 999px;
        background: #4f46e5;
        color: #ffffff;
        padding: 0.7rem 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 160ms ease;
    }

    .alumni-edit-file-input::file-selector-button:hover {
        background: #4338ca;
    }

    .alumni-edit-help {
        font-size: 0.82rem;
        line-height: 1.55;
        color: #64748b;
        margin: 0;
    }

    .alumni-edit-section-grid {
        display: grid;
        gap: 1rem;
    }

    .alumni-edit-actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .alumni-edit-action {
        min-width: 11rem;
    }

    @media (min-width: 640px) {
        .alumni-edit-actions {
            flex-direction: row;
            justify-content: flex-end;
        }
    }
</style>
<div class="pb-12 sm:pb-16" style="background: linear-gradient(180deg, #eef2ff 0%, #e6ebfb 100%);">
    <div class="max-w-screen-xl px-5 sm:px-8 mx-auto pt-10 sm:pt-14">
        <div class="max-w-5xl mx-auto space-y-6">
            <section data-aos="fade-up" data-alumni-profile-edit-hero class="rounded-[2rem] px-5 sm:px-8 py-6 sm:py-8 shadow-[0_22px_48px_rgba(15,23,42,0.08)]" style="background: linear-gradient(145deg, rgba(255,255,255,0.98) 0%, rgba(238,242,255,0.96) 54%, rgba(224,231,255,0.9) 100%); border: 1px solid rgba(165, 180, 252, 0.48);">
                <div class="grid lg:grid-cols-[1.08fr_0.92fr] gap-5 sm:gap-6 items-start">
                    <div>
                        <p class="text-[0.72rem] font-bold tracking-[0.24em] uppercase mb-3" style="color: #3730a3;">PROFILE EDIT</p>
                        <h1 class="text-3xl sm:text-4xl font-bold text-darken leading-tight">Edit My Profile</h1>
                        <p class="mt-4 text-sm sm:text-base leading-relaxed text-gray-500 max-w-3xl">Update your account details from the alumni landing experience so profile changes stay inside the new alumni UI.</p>

                        <div class="mt-6 grid sm:grid-cols-3 gap-3">
                            <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid rgba(165, 180, 252, 0.48);">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: #3730a3;">Account</p>
                                <p class="text-sm font-semibold text-darken mb-0">{{ accountStatusLabel }}</p>
                            </div>
                            <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid rgba(165, 180, 252, 0.48);">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: #3730a3;">Linked Record</p>
                                <p class="text-sm font-semibold text-darken mb-0">{{ linkedAlumni ? 'Connected' : 'Waiting for link' }}</p>
                            </div>
                            <div class="rounded-2xl px-4 py-4" style="background: rgba(255,255,255,0.82); border: 1px solid rgba(165, 180, 252, 0.48);">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] mb-1" style="color: #3730a3;">Email</p>
                                <p class="text-sm font-semibold text-darken mb-0 break-all">{{ user.email }}</p>
                            </div>
                        </div>

                        <div class="mt-6 flex flex-col sm:flex-row gap-3">
                            <a href="{{ path('app_alumni_feature_profile') }}" class="inline-flex items-center justify-center rounded-full text-white font-semibold px-6 py-3 no-underline shadow-sm" style="background: #4f46e5; box-shadow: 0 14px 30px rgba(99, 102, 241, 0.14);">Back to my profile</a>
                            <a href="#password-panel" class="inline-flex items-center justify-center rounded-full font-semibold px-6 py-3 no-underline border" style="background: rgba(255, 255, 255, 0.82); color: #3730a3; border-color: rgba(165, 180, 252, 0.48);">Jump to password</a>
                        </div>
                    </div>

                    <article class="rounded-[1.6rem] px-5 py-5 shadow-sm" style="background: rgba(255, 255, 255, 0.82); border: 1px solid rgba(165, 180, 252, 0.48);">
                        <p class="text-[0.68rem] font-bold tracking-[0.22em] uppercase mb-2" style="color: #3730a3;">Profile Snapshot</p>
                        <div class="flex items-center gap-4 mb-4">
                            {% if user.profileImage %}
                                <img src="{{ asset('uploads/profile/' ~ user.profileImage) }}" alt="{{ user.fullName }} profile photo" class="h-16 w-16 rounded-full object-cover border border-indigo-100 shadow-sm">
                            {% else %}
                                <div class="inline-flex h-16 w-16 items-center justify-center rounded-full text-white text-xl font-bold shadow-sm" style="background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);">
                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                </div>
                            {% endif %}
                            <div>
                                <h2 class="text-xl font-bold text-darken mb-1">{{ user.fullName }}</h2>
                                <p class="text-sm text-gray-500 mb-0 break-all">{{ user.email }}</p>
                            </div>
                        </div>
                        <div class="grid gap-3 text-sm">
                            <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Date Registered</p>
                                <p class="font-semibold text-darken mb-0">{{ user.dateRegistered|date('M d, Y') }}</p>
                            </div>
                            <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Last Login</p>
                                <p class="font-semibold text-darken mb-0">{{ user.lastLogin ? user.lastLogin|date('M d, Y h:i A') : 'Never' }}</p>
                            </div>
                            <div class="rounded-2xl bg-white/70 border border-white/80 px-4 py-3">
                                <p class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-slate-500 mb-1">Academic Record</p>
                                <p class="font-semibold text-darken mb-0">{{ linkedAlumni ? ((linkedAlumni.course ?: 'Course not set') ~ (linkedAlumni.yearGraduated ? ' • Batch ' ~ linkedAlumni.yearGraduated : '')) : 'No linked alumni record yet' }}</p>
                            </div>
                        </div>
                    </article>
                </div>
            </section>

            <form data-alumni-profile-edit-form method="post" action="{{ path('app_profile_edit') }}" enctype="multipart/form-data" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('profile_edit') }}">

                <section data-aos="fade-up" class="rounded-[1.6rem] sm:rounded-[1.9rem] bg-white border border-indigo-100 px-5 sm:px-6 py-5 sm:py-6 shadow-[0_18px_36px_rgba(15,23,42,0.07)]">
                    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.22em] text-indigo-700 uppercase mb-2">Account Details</p>
                            <h2 class="text-xl sm:text-2xl font-bold text-darken mb-0">Update your basic profile information</h2>
                        </div>
                        <p class="text-sm text-gray-500 mb-0">These details are the ones you can manage directly from the alumni UI.</p>
                    </div>

                    <div class="grid xl:grid-cols-2 gap-4 sm:gap-5 items-start">
                        <div class="alumni-edit-section-grid sm:grid-cols-2">
                            <div class="alumni-edit-field alumni-edit-field-card">
                                <label class="alumni-edit-label" for="profile-first-name">First Name <span class="text-red-500">*</span></label>
                                <input type="text" id="profile-first-name" name="firstName" class="alumni-edit-input" value="{{ user.firstName }}" required>
                            </div>
                            <div class="alumni-edit-field alumni-edit-field-card">
                                <label class="alumni-edit-label" for="profile-last-name">Last Name <span class="text-red-500">*</span></label>
                                <input type="text" id="profile-last-name" name="lastName" class="alumni-edit-input" value="{{ user.lastName }}" required>
                            </div>
                            <div class="alumni-edit-field alumni-edit-field-card sm:col-span-2">
                                <label class="alumni-edit-label" for="profile-email">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" id="profile-email" name="email" class="alumni-edit-input" value="{{ user.email }}" required>
                                <p class="alumni-edit-help">Use an active email address so account notifications and alumni updates reach you correctly.</p>
                            </div>
                        </div>

                        <div class="alumni-edit-side-panel px-4 py-4 sm:px-5 sm:py-5">
                            <p class="text-[0.72rem] font-bold tracking-[0.2em] text-indigo-700 uppercase mb-3">Profile Photo</p>
                            <div class="flex items-center gap-3 mb-4">
                                {% if user.profileImage %}
                                    <img src="{{ asset('uploads/profile/' ~ user.profileImage) }}" alt="Current profile photo" class="w-16 h-16 rounded-full object-cover border border-gray-200">
                                {% else %}
                                    <div class="w-16 h-16 rounded-full inline-flex items-center justify-center text-xl font-bold text-white" style="background:linear-gradient(135deg,#4f46e5,#2563eb)">
                                        {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                    </div>
                                {% endif %}
                                <div class="min-w-0">
                                    <p class="font-semibold text-darken mb-1">Update your display photo</p>
                                    <p class="alumni-edit-help">Upload a clear headshot so your profile remains easy to recognize across the alumni interface.</p>
                                </div>
                            </div>
                            <input type="file" name="profileImage" accept=".jpg,.jpeg,.png,.webp" class="alumni-edit-file-input">
                            <p class="text-xs text-gray-500 mt-3 mb-0">Allowed: JPG, PNG, WEBP. Maximum size: 2MB.</p>
                        </div>
                    </div>
                </section>

                <section id="password-panel" data-aos="fade-up" class="rounded-[1.6rem] sm:rounded-[1.9rem] bg-white border border-indigo-100 px-5 sm:px-6 py-5 sm:py-6 shadow-[0_18px_36px_rgba(15,23,42,0.07)]">
                    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.22em] text-indigo-700 uppercase mb-2">Password Update</p>
                            <h2 class="text-xl sm:text-2xl font-bold text-darken mb-0">Change your password when needed</h2>
                        </div>
                        <p class="text-sm text-gray-500 mb-0">Leave these fields blank if you are only updating your profile details.</p>
                    </div>

                    <div class="grid xl:grid-cols-2 gap-4 sm:gap-5">
                        <div class="alumni-edit-section-grid sm:grid-cols-2">
                            <div class="alumni-edit-field alumni-edit-field-card sm:col-span-2">
                                <label class="alumni-edit-label" for="currentPassword">Current Password <span class="alumni-edit-label-note">Required only when changing password</span></label>
                                <input type="password" name="currentPassword" id="currentPassword" class="alumni-edit-input" placeholder="Enter your current password">
                            </div>
                            <div class="alumni-edit-field alumni-edit-field-card">
                                <label class="alumni-edit-label" for="newPassword">New Password</label>
                                <input type="password" name="newPassword" id="newPassword" class="alumni-edit-input" placeholder="Enter new password" minlength="8">
                                <div id="passwordStrength" class="mt-2 hidden">
                                    <div class="w-full bg-gray-200 rounded-full h-2">
                                        <div id="strengthBar" class="h-2 rounded-full transition-all duration-300" style="width:0%"></div>
                                    </div>
                                    <span id="strengthText" class="text-xs mt-1 block"></span>
                                </div>
                            </div>
                            <div class="alumni-edit-field alumni-edit-field-card">
                                <label class="alumni-edit-label" for="confirmPassword">Confirm Password</label>
                                <input type="password" name="confirmPassword" id="confirmPassword" class="alumni-edit-input" placeholder="Re-enter new password">
                                <span id="matchText" class="text-xs mt-1 block hidden"></span>
                            </div>
                        </div>

                        <div id="passwordRules" class="alumni-edit-side-panel px-4 py-4 sm:px-5 sm:py-5 text-sm text-gray-500">
                            <p class="font-semibold text-gray-700 mb-3"><i class="bi bi-shield-check mr-1"></i>Password Requirements</p>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                <p id="rule-length" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> At least 8 characters</p>
                                <p id="rule-upper" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One uppercase letter</p>
                                <p id="rule-lower" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One lowercase letter</p>
                                <p id="rule-number" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One number</p>
                                <p id="rule-special" class="flex items-center gap-1 mb-0 sm:col-span-2"><i class="bi bi-x-circle text-gray-400"></i> One special character</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section data-aos="fade-up" class="rounded-[1.6rem] sm:rounded-[1.9rem] bg-white border border-indigo-100 px-5 sm:px-6 py-5 shadow-[0_18px_36px_rgba(15,23,42,0.07)]">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div>
                            <p class="text-[0.72rem] font-bold tracking-[0.22em] text-indigo-700 uppercase mb-2">Save Changes</p>
                            <p class="text-sm text-gray-500 mb-0">Once saved, you will return to your alumni profile page in this same landing experience.</p>
                        </div>
                        <div class="alumni-edit-actions">
                            <a href="{{ path('app_alumni_feature_profile') }}" class="alumni-edit-action inline-flex items-center justify-center rounded-full font-semibold px-5 py-3 no-underline border border-indigo-100 bg-indigo-50 text-indigo-800">Cancel</a>
                            <button type="submit" class="alumni-edit-action inline-flex items-center justify-center rounded-full text-white font-semibold px-5 py-3 border-0 cursor-pointer" style="background: #4f46e5; box-shadow: 0 14px 30px rgba(99, 102, 241, 0.14);">
                                <i class="bi bi-check-lg mr-1"></i>Save Changes
                            </button>
                        </div>
                    </div>
                </section>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const pw = document.getElementById('newPassword');
    const confirm = document.getElementById('confirmPassword');
    const bar = document.getElementById('strengthBar');
    const text = document.getElementById('strengthText');
    const wrap = document.getElementById('passwordStrength');
    const matchText = document.getElementById('matchText');

    if (!pw || !confirm || !bar || !text || !wrap || !matchText) {
        return;
    }

    const rules = {
        length: { el: document.getElementById('rule-length'), test: function(value) { return value.length >= 8; } },
        upper: { el: document.getElementById('rule-upper'), test: function(value) { return /[A-Z]/.test(value); } },
        lower: { el: document.getElementById('rule-lower'), test: function(value) { return /[a-z]/.test(value); } },
        number: { el: document.getElementById('rule-number'), test: function(value) { return /\d/.test(value); } },
        special: { el: document.getElementById('rule-special'), test: function(value) { return /[^a-zA-Z\d]/.test(value); } }
    };

    pw.addEventListener('input', function() {
        const value = this.value;
        if (!value) {
            wrap.classList.add('hidden');
            resetRules();
            return;
        }

        wrap.classList.remove('hidden');

        let score = 0;
        for (const key in rules) {
            const passed = rules[key].test(value);
            score += passed ? 1 : 0;
            const icon = rules[key].el.querySelector('i');
            if (passed) {
                icon.className = 'bi bi-check-circle-fill text-green-600';
                rules[key].el.classList.remove('text-gray-500');
                rules[key].el.classList.add('text-green-700');
            } else {
                icon.className = 'bi bi-x-circle text-gray-400';
                rules[key].el.classList.remove('text-green-700');
                rules[key].el.classList.add('text-gray-500');
            }
        }

        if (value.length >= 12) {
            score += 1;
        }

        const percent = Math.min(100, (score / 6) * 100);
        bar.style.width = percent + '%';

        if (score <= 2) {
            bar.className = 'h-2 rounded-full transition-all duration-300 bg-red-500';
            text.textContent = 'Weak';
            text.className = 'text-xs mt-1 block text-red-600';
        } else if (score <= 4) {
            bar.className = 'h-2 rounded-full transition-all duration-300 bg-yellow-500';
            text.textContent = 'Fair';
            text.className = 'text-xs mt-1 block text-yellow-600';
        } else {
            bar.className = 'h-2 rounded-full transition-all duration-300 bg-green-500';
            text.textContent = 'Strong';
            text.className = 'text-xs mt-1 block text-green-600';
        }

        checkMatch();
    });

    confirm.addEventListener('input', checkMatch);

    function checkMatch() {
        if (!confirm.value) {
            matchText.classList.add('hidden');
            return;
        }

        matchText.classList.remove('hidden');
        if (pw.value === confirm.value) {
            matchText.textContent = 'Passwords match';
            matchText.className = 'text-xs mt-1 block text-green-600';
        } else {
            matchText.textContent = 'Passwords do not match';
            matchText.className = 'text-xs mt-1 block text-red-600';
        }
    }

    function resetRules() {
        for (const key in rules) {
            const icon = rules[key].el.querySelector('i');
            icon.className = 'bi bi-x-circle text-gray-400';
            rules[key].el.classList.remove('text-green-700');
            rules[key].el.classList.add('text-gray-500');
        }
        matchText.classList.add('hidden');
    }
});
</script>
{% endblock %}
