{% extends 'base.html.twig' %}

{% block title %}Import Alumni Data{% endblock %}

{% block body %}
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 mb-4">
    <div>
        <h4 class="font-bold mb-0"><i class="bi bi-upload mr-2"></i>Import Alumni Data</h4>
        <p class="text-gray-500 text-sm mb-0">Upload a CSV file to bulk-import alumni records</p>
    </div>
    <div class="flex gap-2">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_analytics_hub') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-grid-1x2-fill mr-1"></i>Analytics Hub</a>
        {% endif %}
        <a href="{{ path('report_index') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-arrow-left mr-1"></i>Back to Reports</a>
    </div>
</div>

{% for flash in app.flashes('error') %}
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm">
        <i class="bi bi-exclamation-triangle-fill mr-1"></i>{{ flash }}
    </div>
{% endfor %}

{% if results %}
<div class="card mb-4">
    <div class="card-header bg-white font-semibold"><i class="bi bi-clipboard-check mr-1"></i> Import Results</div>
    <div class="card-body">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
            <div class="bg-green-50 border border-green-200 rounded p-3 text-center">
                <div class="text-2xl font-bold text-green-600">{{ results.created }}</div>
                <div class="text-sm text-green-700">New Records Created</div>
            </div>
            <div class="bg-blue-50 border border-blue-200 rounded p-3 text-center">
                <div class="text-2xl font-bold text-blue-600">{{ results.updated }}</div>
                <div class="text-sm text-blue-700">Records Updated</div>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-center">
                <div class="text-2xl font-bold text-yellow-600">{{ results.skipped }}</div>
                <div class="text-sm text-yellow-700">Rows Skipped</div>
            </div>
        </div>

        {% if results.errors|length > 0 %}
        <div class="bg-red-50 border border-red-200 rounded p-3">
            <h6 class="font-semibold text-red-700 mb-2"><i class="bi bi-exclamation-circle mr-1"></i>Errors ({{ results.errors|length }})</h6>
            <ul class="text-sm text-red-600 list-disc pl-5 max-h-48 overflow-y-auto">
                {% for error in results.errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
        </div>
        {% else %}
        <div class="bg-green-50 border border-green-200 rounded p-3 text-green-700 text-sm">
            <i class="bi bi-check-circle-fill mr-1"></i>All rows processed successfully!
        </div>
        {% endif %}
    </div>
</div>
{% endif %}

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {# Upload Form #}
    <div class="md:col-span-2">
        <div class="card">
            <div class="card-header bg-white font-semibold"><i class="bi bi-file-earmark-arrow-up mr-1"></i> Upload CSV File</div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data" action="{{ path('report_import') }}" data-turbo="false">
                    <input type="hidden" name="_token" value="{{ csrf_token('import_alumni') }}">

                    <div class="mb-4">
                        <label for="csv_file" class="block text-sm font-medium text-gray-700 mb-2">Select CSV File</label>
                        <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-norsu transition-colors" id="dropZone">
                            <i class="bi bi-cloud-arrow-up text-4xl text-gray-400 mb-2 block"></i>
                            <p class="text-sm text-gray-500 mb-2">Drag and drop your CSV file here, or click to browse</p>
                            <input type="file" name="csv_file" id="csv_file" accept=".csv" required
                                   class="block w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-norsu file:text-white hover:file:opacity-90 cursor-pointer">
                            <p class="text-xs text-gray-400 mt-2">Maximum file size: 5 MB &bull; CSV format only</p>
                        </div>
                    </div>

                    <div class="bg-blue-50 border border-blue-200 rounded p-3 mb-4 text-sm text-blue-700">
                        <i class="bi bi-info-circle-fill mr-1"></i>
                        <strong>How it works:</strong> If a record with the same <strong>Student Number</strong> already exists, it will be <strong>updated</strong>. Otherwise, a new record will be created.
                    </div>

                    <button type="submit" class="btn-norsu w-full">
                        <i class="bi bi-upload mr-1"></i> Import Alumni Data
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# Instructions Panel #}
    <div>
        <div class="card mb-4">
            <div class="card-header bg-white font-semibold"><i class="bi bi-download mr-1"></i> CSV Template</div>
            <div class="card-body">
                <p class="text-sm text-gray-600 mb-3">Download the template with the correct column headers to get started.</p>
                <a href="{{ path('report_import_template') }}" class="btn-norsu btn-sm w-full text-center block">
                    <i class="bi bi-file-earmark-spreadsheet mr-1"></i> Download Template
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-white font-semibold"><i class="bi bi-question-circle mr-1"></i> Required Columns</div>
            <div class="card-body">
                <ul class="text-sm space-y-1">
                    <li class="flex items-center text-red-600"><i class="bi bi-asterisk text-xs mr-1"></i> Student Number</li>
                    <li class="flex items-center text-red-600"><i class="bi bi-asterisk text-xs mr-1"></i> Last Name</li>
                    <li class="flex items-center text-red-600"><i class="bi bi-asterisk text-xs mr-1"></i> First Name</li>
                    <li class="flex items-center text-red-600"><i class="bi bi-asterisk text-xs mr-1"></i> Email</li>
                </ul>
                <hr class="my-3">
                <p class="text-xs text-gray-500">All other columns are optional. The file must match the exported CSV format.</p>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-white font-semibold"><i class="bi bi-list-columns mr-1"></i> All Columns</div>
            <div class="card-body">
                <ol class="text-xs text-gray-600 space-y-0.5 list-decimal pl-4">
                    <li>Student Number</li>
                    <li>Last Name</li>
                    <li>First Name</li>
                    <li>Middle Name</li>
                    <li>Suffix</li>
                    <li>Sex</li>
                    <li>Civil Status</li>
                    <li>Email</li>
                    <li>Contact Number</li>
                    <li>Province</li>
                    <li>Course</li>
                    <li>Year Graduated</li>
                    <li>College</li>
                    <li>Employment Status</li>
                    <li>Employment Type</li>
                    <li>Company</li>
                    <li>Job Title</li>
                    <li>Industry</li>
                    <li>Monthly Salary</li>
                    <li>Job Related to Course</li>
                    <li>Work Abroad</li>
                    <li>Country</li>
                </ol>
            </div>
        </div>
    </div>
</div>
{% endblock %}
