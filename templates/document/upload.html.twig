{% extends 'base.html.twig' %}

{% block title %}Upload Document{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <h4 class="font-bold mb-0"><i class="bi bi-cloud-arrow-up mr-2"></i>Upload Document</h4>
    <a href="{{ path('alumni_show', {id: alumni.id}) }}" class="btn-outline-norsu"><i class="bi bi-arrow-left mr-1"></i>Back to {{ alumni.fullName }}</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="form-label font-semibold">Document Type</label>
                    <select name="document_type" class="form-select" required>
                        <option value="">— Select Type —</option>
                        <option value="resume">Resume / CV</option>
                        <option value="transcript">Transcript of Records</option>
                        <option value="certificate">Certificate</option>
                        <option value="diploma">Diploma</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div>
                    <label class="form-label font-semibold">File</label>
                    <input type="file" name="document" class="form-input" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                    <div class="text-sm text-gray-500 mt-1">Accepted: PDF, DOC, DOCX, JPG, PNG (max 10MB)</div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn-norsu"><i class="bi bi-upload mr-1"></i>Upload Document</button>
            </div>
        </form>
    </div>
</div>

{% if alumni.documents|length > 0 %}
<div class="card mt-4">
    <div class="card-header bg-white font-semibold"><i class="bi bi-file-earmark mr-1"></i> Existing Documents</div>
    <div class="p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                <tr>
                    <th class="pl-4 py-2.5 font-semibold text-left">Type</th>
                    <th class="py-2.5 font-semibold text-left">Filename</th>
                    <th class="py-2.5 font-semibold text-left">Uploaded</th>
                    <th class="text-right pr-4 py-2.5 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for doc in alumni.documents %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-4 py-2.5"><span class="badge bg-gray-100 text-gray-700">{{ doc.documentType }}</span></td>
                    <td class="py-2.5">{{ doc.originalFilename }}</td>
                    <td class="py-2.5 text-sm">{{ doc.uploadedAt|date('M d, Y') }}</td>
                    <td class="text-right pr-4 py-2.5">
                        <div class="flex gap-1 justify-end">
                            <a href="{{ path('document_download', {id: doc.id}) }}" class="icon-action icon-action-download" title="Download" aria-label="Download document"><i class="bi bi-download"></i></a>
                            <form method="post" action="{{ path('document_delete', {id: doc.id}) }}" class="inline"
                                  onsubmit="return confirm('Delete this document?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ doc.id) }}">
                                <button type="submit" class="icon-action icon-action-delete icon-action-btn" title="Delete" aria-label="Delete document"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}
