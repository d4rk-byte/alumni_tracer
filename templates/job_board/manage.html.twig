{% extends 'base.html.twig' %}

{% block title %}Manage Job Board{% endblock %}
{% block body_class %}admin-material-page{% endblock %}

{% block body %}
<div class="flex justify-between items-center mb-3">
    <div>
        <h4 class="font-bold mb-0"><i class="bi bi-gear-fill mr-2"></i>Manage Job Board</h4>
        <p class="text-gray-500 text-sm mb-0">Create, edit, and manage job postings</p>
    </div>
    <div class="flex gap-2">
        <a href="{{ path('job_board_create') }}" class="btn-norsu"><i class="bi bi-plus-lg mr-1"></i>New Job</a>
    </div>
</div>

{% if jobs|length == 0 %}
    <div class="card"><div class="card-body text-center text-gray-500 py-10">
        <i class="bi bi-briefcase text-4xl block mb-2 opacity-25"></i>
        No job postings yet. Click "New Job" to create one.
    </div></div>
{% else %}
    <div class="card">
        <div class="p-0 overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                    <tr>
                        <th class="pl-4 py-2.5 font-semibold text-left">Title</th>
                        <th class="py-2.5 font-semibold text-left">Company</th>
                        <th class="py-2.5 font-semibold text-left">Type</th>
                        <th class="py-2.5 font-semibold text-left">Course</th>
                        <th class="py-2.5 font-semibold text-left">Deadline</th>
                        <th class="py-2.5 font-semibold text-left">Status</th>
                        <th class="py-2.5 font-semibold text-left">Posted</th>
                        <th class="text-right pr-4 py-2.5 font-semibold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for job in jobs %}
                    <tr class="hover:bg-gray-50 transition-colors {{ not job.isActive ? 'bg-gray-100 opacity-60' : '' }}">
                        <td class="pl-4 py-2.5 font-semibold">{{ job.title }}</td>
                        <td class="py-2.5">{{ job.companyName }}</td>
                        <td class="py-2.5"><span class="badge badge-info">{{ job.employmentType }}</span></td>
                        <td class="py-2.5">{{ job.relatedCourse ?? '—' }}</td>
                        <td class="py-2.5 {{ job.deadline and job.deadline < date() ? 'text-red-500' : '' }}">
                            {{ job.deadline ? job.deadline|date('M d, Y') : '—' }}
                        </td>
                        <td class="py-2.5">
                            {% if job.isActive %}
                                <span class="badge badge-employed">Active</span>
                            {% else %}
                                <span class="badge badge-secondary">Inactive</span>
                            {% endif %}
                        </td>
                        <td class="py-2.5 text-sm">{{ job.datePosted|date('M d, Y') }}</td>
                        <td class="text-right pr-4 py-2.5">
                            <div class="flex gap-1 justify-end">
                                <a href="{{ path('job_board_manage_show', {id: job.id}) }}" class="icon-action icon-action-view" title="View" aria-label="View job"><i class="bi bi-eye"></i></a>
                                <a href="{{ path('job_board_edit', {id: job.id}) }}" class="icon-action icon-action-edit" title="Edit" aria-label="Edit job"><i class="bi bi-pencil"></i></a>
                                <form method="post" action="{{ path('job_board_delete', {id: job.id}) }}" class="inline"
                                      onsubmit="return confirm('Delete this job posting?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                                    <button type="submit" class="icon-action icon-action-delete icon-action-btn" title="Delete" aria-label="Delete job"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}

{% include '_pagination.html.twig' with {
    currentPage: currentPage,
    totalPages: totalPages,
    route: 'job_board_manage',
    routeParams: {}
} %}
{% endblock %}
