{% extends 'base.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block body %}
{% set isAdmin = 'ROLE_ADMIN' in user.roles %}
{% set isStaff = 'ROLE_STAFF' in user.roles %}
{% set roleLabel = isAdmin ? 'Administrator' : (isStaff ? 'Staff' : 'Alumni') %}
{% set roleBadgeClass = isAdmin ? 'badge-danger' : (isStaff ? 'badge-info' : 'badge-success') %}

<div class="space-y-4">
    <section class="card overflow-hidden">
        <div class="card-body px-4 sm:px-5 py-4">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                <div class="flex items-center gap-4 min-w-0">
                    {% if user.profileImage %}
                        <img src="{{ asset('uploads/profile/' ~ user.profileImage) }}" alt="Profile photo" class="rounded-full object-cover border border-gray-200 shadow-sm flex-shrink-0" style="width:80px;height:80px;">
                    {% else %}
                        <div class="rounded-full inline-flex items-center justify-center text-2xl font-bold text-white shadow-sm flex-shrink-0" style="width:80px;height:80px;background:linear-gradient(135deg,#1E40AF,#059669)">
                            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                        </div>
                    {% endif %}
                    <div class="min-w-0">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700 mb-1">Edit Profile</p>
                        <h4 class="font-bold mb-1 text-darken">{{ user.fullName }}</h4>
                        <p class="text-gray-500 mb-2 break-all">{{ user.email }}</p>
                        <div class="flex flex-wrap gap-2">
                            <span class="badge {{ roleBadgeClass }}">{{ roleLabel }}</span>
                            <span class="badge badge-secondary">Update details and security</span>
                        </div>
                    </div>
                </div>
                <a href="{{ path('app_profile') }}" class="btn-outline-norsu"><i class="bi bi-arrow-left mr-1"></i>Back to Profile</a>
            </div>
        </div>
    </section>

    <form method="post" action="{{ path('app_profile_edit') }}" enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" name="_token" value="{{ csrf_token('profile_edit') }}">

        <section class="card">
            <div class="card-header bg-white font-semibold"><i class="bi bi-person mr-1"></i> Account Details</div>
            <div class="card-body">
                <div class="grid grid-cols-1 xl:grid-cols-[1.1fr_0.9fr] gap-4 items-start">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div>
                            <label class="form-label font-semibold">First Name <span class="text-red-500">*</span></label>
                            <input type="text" name="firstName" class="form-input" value="{{ user.firstName }}" required>
                        </div>
                        <div>
                            <label class="form-label font-semibold">Last Name <span class="text-red-500">*</span></label>
                            <input type="text" name="lastName" class="form-input" value="{{ user.lastName }}" required>
                        </div>
                        <div class="sm:col-span-2">
                            <label class="form-label font-semibold">Email Address <span class="text-red-500">*</span></label>
                            <input type="email" name="email" class="form-input" value="{{ user.email }}" required>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 h-full">
                        <p class="font-semibold text-darken mb-3"><i class="bi bi-camera mr-1"></i> Profile Photo</p>
                        <div class="flex items-center gap-3 mb-3">
                            {% if user.profileImage %}
                                <img src="{{ asset('uploads/profile/' ~ user.profileImage) }}" alt="Current profile photo" class="w-16 h-16 rounded-full object-cover border border-gray-200">
                            {% else %}
                                <div class="w-16 h-16 rounded-full inline-flex items-center justify-center text-xl font-bold text-white" style="background:linear-gradient(135deg,#1E40AF,#059669)">
                                    {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                                </div>
                            {% endif %}
                            <div class="text-sm text-gray-500">
                                Upload a clear headshot so your account stays easy to identify.
                            </div>
                        </div>
                        <input type="file" name="profileImage" accept=".jpg,.jpeg,.png,.webp" class="form-input">
                        <p class="text-xs text-gray-500 mt-2 mb-0">Allowed: JPG, PNG, WEBP. Maximum size: 2MB.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="password-panel" class="card">
            <div class="card-header bg-white font-semibold"><i class="bi bi-lock mr-1"></i> Password Update <span class="text-gray-400 font-normal text-sm">(optional)</span></div>
            <div class="card-body">
                <p class="text-sm text-gray-500 mb-4">Only fill in these fields if you want to change your password during this edit session.</p>
                <div class="grid grid-cols-1 xl:grid-cols-[1.05fr_0.95fr] gap-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="sm:col-span-2">
                            <label class="form-label font-semibold">Current Password <span class="text-red-500">*</span></label>
                            <input type="password" name="currentPassword" id="currentPassword" class="form-input" placeholder="Enter your current password">
                        </div>
                        <div>
                            <label class="form-label font-semibold">New Password</label>
                            <input type="password" name="newPassword" id="newPassword" class="form-input" placeholder="Enter new password" minlength="8">
                            <div id="passwordStrength" class="mt-2 hidden">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div id="strengthBar" class="h-2 rounded-full transition-all duration-300" style="width:0%"></div>
                                </div>
                                <span id="strengthText" class="text-xs mt-1 block"></span>
                            </div>
                        </div>
                        <div>
                            <label class="form-label font-semibold">Confirm Password</label>
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-input" placeholder="Re-enter new password">
                            <span id="matchText" class="text-xs mt-1 block hidden"></span>
                        </div>
                    </div>

                    <div id="passwordRules" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-gray-500">
                        <p class="font-semibold text-gray-700 mb-3"><i class="bi bi-shield-check mr-1"></i>Password Requirements</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            <p id="rule-length" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> At least 8 characters</p>
                            <p id="rule-upper" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One uppercase letter</p>
                            <p id="rule-lower" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One lowercase letter</p>
                            <p id="rule-number" class="flex items-center gap-1 mb-0"><i class="bi bi-x-circle text-gray-400"></i> One number</p>
                            <p id="rule-special" class="flex items-center gap-1 mb-0 sm:col-span-2"><i class="bi bi-x-circle text-gray-400"></i> One special character</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-body px-4 sm:px-5 py-4">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                    <p class="text-sm text-gray-500 mb-0">Save only when your basic details and password changes are ready.</p>
                    <div class="flex flex-wrap gap-2">
                        <a href="{{ path('app_profile') }}" class="btn-secondary">Cancel</a>
                        <button type="submit" class="btn-norsu"><i class="bi bi-check-lg mr-1"></i>Save Changes</button>
                    </div>
                </div>
            </div>
        </section>
    </form>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const pw = document.getElementById('newPassword');
    const confirm = document.getElementById('confirmPassword');
    const bar = document.getElementById('strengthBar');
    const text = document.getElementById('strengthText');
    const wrap = document.getElementById('passwordStrength');
    const matchText = document.getElementById('matchText');

    const rules = {
        length:  { el: document.getElementById('rule-length'),  test: v => v.length >= 8 },
        upper:   { el: document.getElementById('rule-upper'),   test: v => /[A-Z]/.test(v) },
        lower:   { el: document.getElementById('rule-lower'),   test: v => /[a-z]/.test(v) },
        number:  { el: document.getElementById('rule-number'),  test: v => /\d/.test(v) },
        special: { el: document.getElementById('rule-special'), test: v => /[^a-zA-Z\d]/.test(v) },
    };

    pw.addEventListener('input', function() {
        const v = this.value;
        if (!v) { wrap.classList.add('hidden'); resetRules(); return; }
        wrap.classList.remove('hidden');

        let score = 0;
        for (const key in rules) {
            const passed = rules[key].test(v);
            score += passed ? 1 : 0;
            const icon = rules[key].el.querySelector('i');
            if (passed) {
                icon.className = 'bi bi-check-circle-fill text-green-600';
                rules[key].el.classList.remove('text-gray-500'); rules[key].el.classList.add('text-green-700');
            } else {
                icon.className = 'bi bi-x-circle text-gray-400';
                rules[key].el.classList.remove('text-green-700'); rules[key].el.classList.add('text-gray-500');
            }
        }
        if (v.length >= 12) score += 1;

        const pct = Math.min(100, (score / 6) * 100);
        bar.style.width = pct + '%';
        if (score <= 2) { bar.className = 'h-2 rounded-full transition-all duration-300 bg-red-500'; text.textContent = 'Weak'; text.className = 'text-xs mt-1 block text-red-600'; }
        else if (score <= 4) { bar.className = 'h-2 rounded-full transition-all duration-300 bg-yellow-500'; text.textContent = 'Fair'; text.className = 'text-xs mt-1 block text-yellow-600'; }
        else { bar.className = 'h-2 rounded-full transition-all duration-300 bg-green-500'; text.textContent = 'Strong'; text.className = 'text-xs mt-1 block text-green-600'; }

        checkMatch();
    });

    confirm.addEventListener('input', checkMatch);

    function checkMatch() {
        if (!confirm.value) { matchText.classList.add('hidden'); return; }
        matchText.classList.remove('hidden');
        if (pw.value === confirm.value) {
            matchText.textContent = 'Passwords match';
            matchText.className = 'text-xs mt-1 block text-green-600';
        } else {
            matchText.textContent = 'Passwords do not match';
            matchText.className = 'text-xs mt-1 block text-red-600';
        }
    }

    function resetRules() {
        for (const key in rules) {
            const icon = rules[key].el.querySelector('i');
            icon.className = 'bi bi-x-circle text-gray-400';
            rules[key].el.classList.remove('text-green-700'); rules[key].el.classList.add('text-gray-500');
        }
        matchText.classList.add('hidden');
    }
});
</script>
{% endblock %}
