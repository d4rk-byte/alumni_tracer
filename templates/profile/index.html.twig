{% extends 'base.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
{% set isAdmin = 'ROLE_ADMIN' in user.roles %}
{% set isStaff = 'ROLE_STAFF' in user.roles %}
{% set roleLabel = isAdmin ? 'Administrator' : (isStaff ? 'Staff' : 'Alumni') %}
{% set roleBadgeClass = isAdmin ? 'badge-danger' : (isStaff ? 'badge-info' : 'badge-success') %}
{% set accountBadgeClass = user.accountStatus == 'active' ? 'badge-success' : (user.accountStatus == 'pending' ? 'badge-warning' : 'badge-danger') %}

<div class="space-y-4">
    <section class="card overflow-hidden">
        <div class="card-body px-4 sm:px-5 py-4">
            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                <div class="flex items-center gap-4 min-w-0">
                    {% if user.profileImage %}
                        <img src="{{ asset('uploads/profile/' ~ user.profileImage) }}" alt="Profile photo" class="rounded-full object-cover border border-gray-200 shadow-sm flex-shrink-0" style="width:84px;height:84px;">
                    {% else %}
                        <div class="rounded-full inline-flex items-center justify-center text-2xl font-bold text-white shadow-sm flex-shrink-0" style="width:84px;height:84px;background:linear-gradient(135deg,#1E40AF,#059669)">
                            {{ user.firstName|first|upper }}{{ user.lastName|first|upper }}
                        </div>
                    {% endif %}
                    <div class="min-w-0">
                        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700 mb-1">My Profile</p>
                        <h4 class="font-bold mb-1 text-darken">{{ user.fullName }}</h4>
                        <p class="text-gray-500 mb-2 break-all">{{ user.email }}</p>
                        <div class="flex flex-wrap gap-2">
                            <span class="badge {{ roleBadgeClass }}">{{ roleLabel }}</span>
                            <span class="badge {{ accountBadgeClass }}">{{ user.accountStatus|capitalize }} account</span>
                        </div>
                    </div>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="{{ path('app_profile_edit') }}" class="btn-norsu"><i class="bi bi-pencil-square mr-1"></i>Edit Profile</a>
                    <a href="{{ path('app_profile_edit') }}#password-panel" class="btn-outline-norsu"><i class="bi bi-key mr-1"></i>Change Password</a>
                </div>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 xl:grid-cols-[1.15fr_0.85fr] gap-4">
        <section class="card">
            <div class="card-header bg-white font-semibold"><i class="bi bi-info-circle mr-1"></i> Account Overview</div>
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">First Name</p>
                        <p class="font-semibold text-darken mb-0">{{ user.firstName }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Last Name</p>
                        <p class="font-semibold text-darken mb-0">{{ user.lastName }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 sm:col-span-2">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Email Address</p>
                        <p class="font-semibold text-darken mb-0 break-all">{{ user.email }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Role</p>
                        <p class="font-semibold text-darken mb-0">{{ roleLabel }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Account Status</p>
                        <p class="font-semibold text-darken mb-0">{{ user.accountStatus|capitalize }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Date Registered</p>
                        <p class="font-semibold text-darken mb-0">{{ user.dateRegistered|date('F d, Y \\a\\t h:i A') }}</p>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Last Login</p>
                        <p class="font-semibold text-darken mb-0">{{ user.lastLogin ? user.lastLogin|date('F d, Y \\a\\t h:i A') : 'Never' }}</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="space-y-4">
            <section class="card">
                <div class="card-header bg-white font-semibold"><i class="bi bi-lightning-charge mr-1"></i> Quick Actions</div>
                <div class="card-body space-y-3">
                    <div class="rounded-2xl border border-slate-200 px-4 py-3">
                        <p class="font-semibold text-darken mb-1">Profile Details</p>
                        <p class="text-sm text-gray-500 mb-3">Update your name, email, and profile photo from one edit screen.</p>
                        <a href="{{ path('app_profile_edit') }}" class="btn-outline-norsu btn-sm"><i class="bi bi-pencil-square mr-1"></i>Open Edit Profile</a>
                    </div>
                    <div class="rounded-2xl border border-slate-200 px-4 py-3">
                        <p class="font-semibold text-darken mb-1">Security</p>
                        <p class="text-sm text-gray-500 mb-3">Change your password from the same compact form when needed.</p>
                        <a href="{{ path('app_profile_edit') }}#password-panel" class="btn-outline-norsu btn-sm"><i class="bi bi-key mr-1"></i>Go to Password</a>
                    </div>
                </div>
            </section>

            <section class="card">
                <div class="card-header bg-white font-semibold"><i class="bi bi-shield-lock mr-1"></i> Data Privacy</div>
                <div class="card-body space-y-3">
                    <p class="text-sm text-gray-600 mb-0">You can review your consent status and request erasure of your personal data from this panel.</p>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 mb-1">Consent Status</p>
                        {% if user.dpaConsent %}
                            <p class="font-semibold text-green-700 mb-0"><i class="bi bi-check-circle mr-1"></i>DPA consent recorded{% if user.dpaConsentDate %} on {{ user.dpaConsentDate|date('F d, Y') }}{% endif %}</p>
                        {% else %}
                            <p class="font-semibold text-amber-600 mb-0"><i class="bi bi-exclamation-triangle mr-1"></i>No DPA consent on record.</p>
                        {% endif %}
                    </div>
                    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                        <div>
                            <p class="font-semibold text-red-700 mb-1">Request Data Erasure</p>
                            <p class="text-sm text-red-700/80 mb-0">This permanently anonymizes your account and signs you out immediately.</p>
                        </div>
                        <form method="post" action="{{ path('app_profile_erase') }}" onsubmit="return confirm('Are you sure you want to erase all your personal data? This action is PERMANENT and cannot be undone. You will be logged out immediately.')">
                            <input type="hidden" name="_token" value="{{ csrf_token('erase_data') }}">
                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-lg whitespace-nowrap">
                                <i class="bi bi-trash mr-1"></i>Erase My Data
                            </button>
                        </form>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
{% endblock %}
